---
// Sikh University mark: two crossed talwars (curved swords) standing within a
// surrounding mala (rosary). Single colour via currentColor, so set a text-* class.
interface Props { class?: string; }
const { class: cls = '' } = Astro.props;
---
<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={cls}>
  <!-- Mala (rosary): a ring of beads, with a larger sumeru bead at the bottom -->
  <circle cx="32" cy="31" r="27.5" stroke-width="2.3" stroke-dasharray="0.1 5.4" />
  <circle cx="32" cy="58.5" r="2.9" fill="currentColor" stroke="none" />
  <!-- Two crossed talwars (curved blades) forming a stand -->
  <path d="M17.5 47 Q22 28 44 16.5" stroke-width="3.1" />
  <path d="M46.5 47 Q42 28 20 16.5" stroke-width="3.1" />
  <!-- Hilt guards (cross-pieces) -->
  <path d="M12.5 43.5 L22.5 47.5" stroke-width="2.4" />
  <path d="M51.5 43.5 L41.5 47.5" stroke-width="2.4" />
  <!-- Pommels at the base of each hilt -->
  <circle cx="17" cy="48.5" r="2.5" fill="currentColor" stroke="none" />
  <circle cx="47" cy="48.5" r="2.5" fill="currentColor" stroke="none" />
</svg>
