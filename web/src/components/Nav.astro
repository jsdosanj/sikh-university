---
import Logo from './Logo.astro';
const links = [
  { href: '/catalog', label: 'Courses', m: '/catalog' },
  { href: '/santhiya', label: 'Santhya', m: '/santhiya' },
  { href: '/professors', label: 'Professors', m: '/professor' },
  { href: '/about', label: 'About', m: '/about' },
];
const path = Astro.url.pathname;
const isActive = (m: string) => path === m || path.startsWith(m + '/') || (m !== '/' && path.startsWith(m));
---
<nav aria-label="Primary" class="bg-brand text-white sticky top-0 z-40 shadow-md" style="padding-top: env(safe-area-inset-top)">
  <div class="wrap flex items-center gap-x-3 py-3">
    <!-- Logo -->
    <a href="/" aria-label="Sikh University — home" class="flex shrink-0 items-center gap-2 font-serif text-xl font-bold tracking-tight">
      <Logo class="h-7 w-7 shrink-0 text-saffron" />
      <span class="text-white">Sikh <span class="text-saffron">University</span></span>
    </a>

    <!-- Search (desktop only — appears between logo and nav links) -->
    <form id="nav-search-form" action="/search" method="get" role="search" class="hidden md:block mx-4 w-52 xl:w-64 shrink-0">
      <label class="sr-only" for="nav-search-input">Search courses</label>
      <div class="relative">
        <svg aria-hidden="true" class="pointer-events-none absolute left-2.5 top-1/2 -translate-y-1/2 h-4 w-4 text-white/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
        </svg>
        <input
          id="nav-search-input"
          type="search"
          name="q"
          placeholder="Search in English or ਪੰਜਾਬੀ…"
          autocomplete="off"
          class="w-full rounded-full bg-white/10 pl-8 pr-3 py-1.5 font-sans text-sm text-white placeholder-white/50 outline-none ring-1 ring-white/20 focus:bg-white/20 focus:ring-saffron/60 transition"
        />
      </div>
    </form>

    <!-- Spacer pushes nav links to the right -->
    <div class="flex-1"></div>

    <!-- Nav links + auth (desktop) -->
    <div class="hidden md:flex items-center gap-x-5">
      {links.map((l) => (
        <a
          href={l.href}
          aria-current={isActive(l.m) ? 'page' : undefined}
          class={`font-sans text-sm border-b-2 pb-0.5 transition whitespace-nowrap ${isActive(l.m) ? 'border-saffron text-white' : 'border-transparent text-white/80 hover:text-white'}`}
        >{l.label}</a>
      ))}
      <a href="/dashboard" aria-current={isActive('/dashboard') ? 'page' : undefined} class="font-sans text-sm whitespace-nowrap text-white/80 hover:text-white">My Learning</a>
      <button id="theme-toggle" type="button" aria-label="Toggle light or dark theme" title="Toggle light/dark"
        class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-base text-white/90 hover:bg-white/10 hover:text-white transition"><span data-theme-icon>◐</span></button>
      <a id="nav-auth" href="/login" class="rounded-full bg-saffron px-4 py-1.5 font-sans text-sm font-semibold text-[#2a1c06] hover:brightness-105 whitespace-nowrap">Sign in</a>
    </div>

    <!-- Hamburger (mobile) -->
    <button id="nav-toggle" type="button" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="nav-menu"
      class="md:hidden ml-2 inline-flex items-center justify-center rounded-lg p-2 text-white/90 hover:bg-white/10 hover:text-white transition">
      <svg aria-hidden="true" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu (full-width dropdown) -->
  <div id="nav-menu" class="hidden md:hidden border-t border-white/10">
    <div class="wrap py-3 flex flex-col gap-y-1">
      <!-- Search on mobile -->
      <form action="/search" method="get" role="search" class="mb-2">
        <div class="relative">
          <svg aria-hidden="true" class="pointer-events-none absolute left-2.5 top-1/2 -translate-y-1/2 h-4 w-4 text-white/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
          </svg>
          <input type="search" name="q" placeholder="Search in English or ਪੰਜਾਬੀ…" autocomplete="off"
            class="w-full rounded-full bg-white/10 pl-8 pr-3 py-1.5 font-sans text-sm text-white placeholder-white/50 outline-none ring-1 ring-white/20" />
        </div>
      </form>
      {links.map((l) => (
        <a href={l.href} class={`font-sans text-sm py-1.5 px-2 rounded ${isActive(l.m) ? 'text-white font-semibold' : 'text-white/80'}`}>{l.label}</a>
      ))}
      <a href="/dashboard" class="font-sans text-sm py-1.5 px-2 rounded text-white/80">My Learning</a>
      <div class="mt-2 flex items-center gap-x-3 px-2">
        <button id="theme-toggle-mobile" type="button" aria-label="Toggle theme" class="inline-flex h-8 w-8 items-center justify-center rounded-full text-white/90 hover:bg-white/10 transition"><span data-theme-icon-mobile>◐</span></button>
        <a id="nav-auth-mobile" href="/login" class="rounded-full bg-saffron px-4 py-1.5 font-sans text-sm font-semibold text-[#2a1c06]">Sign in</a>
      </div>
    </div>
  </div>
</nav>
<script>
  (function () {
    function syncIcon(icon, theme) { if (icon) icon.textContent = theme === 'dark' ? '☀' : '☾'; }
    const theme = () => document.documentElement.getAttribute('data-theme');
    const icon = document.querySelector('[data-theme-icon]');
    const iconM = document.querySelector('[data-theme-icon-mobile]');
    syncIcon(icon, theme()); syncIcon(iconM, theme());
    function toggle() {
      const next = theme() === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('su_v1_theme', next); } catch (e) {}
      syncIcon(icon, next); syncIcon(iconM, next);
    }
    document.getElementById('theme-toggle')?.addEventListener('click', toggle);
    document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggle);
  })();
</script>
<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      menu.classList.toggle('hidden', open);
    });
  }
</script>
<script>
  (function () {
    const input = document.getElementById('nav-search-input') as HTMLInputElement | null;
    if (input && location.pathname === '/search') {
      const q = new URLSearchParams(location.search).get('q');
      if (q) input.value = q;
    }
  })();
</script>
<script>
  fetch('/api/me', { credentials: 'same-origin' }).then((r) => (r.ok ? r.json() : { user: null })).then((d) => {
    const updateAuth = (authEl: HTMLElement | null, isMobile: boolean) => {
      if (!authEl || !d || !d.user) return;
      const u = d.user;
      authEl.textContent = 'Sign out';
      authEl.href = '#';
      authEl.className = isMobile
        ? 'rounded-full bg-white/20 px-4 py-1.5 font-sans text-sm font-semibold text-white'
        : 'font-sans text-sm text-white/80 hover:text-white';
      authEl.addEventListener('click', (e) => {
        e.preventDefault();
        fetch('/api/auth/logout', { method: 'POST', credentials: 'same-origin' }).then(() => (location.href = '/'));
      });
      if (u.role === 'admin') {
        const ad = document.createElement('a');
        ad.href = '/admin';
        ad.textContent = 'Admin';
        ad.className = isMobile ? 'font-sans text-sm py-1.5 px-2 text-white/80' : 'font-sans text-sm text-white/80 hover:text-white whitespace-nowrap';
        authEl.parentNode!.insertBefore(ad, authEl);
      }
    };
    updateAuth(document.getElementById('nav-auth'), false);
    updateAuth(document.getElementById('nav-auth-mobile'), true);
  }).catch(() => {});
</script>
