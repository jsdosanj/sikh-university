---
import Base from '../layouts/Base.astro';
---
<Base title="My Learning — Sikh University" description="Your progress, certificates, streak and badges at Sikh University.">
  <section class="wrap py-12">
    <div id="dash"><p class="text-muted">Loading your learning…</p></div>
  </section>
  <script>
    const esc = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const get = (k, d) => { try { const v = localStorage.getItem('su_v1_' + k); return v == null ? d : JSON.parse(v); } catch { return d; } };
    const set = (k, v) => { try { localStorage.setItem('su_v1_' + k, JSON.stringify(v)); } catch {} };
    const passed = (id) => !!get('passed_' + id, false);
    function progress(c) { if (!c.lessons || !c.lessons.length) return 0; const d = get('done_' + c.id, {}); let n = 0; for (const k in d) if (d[k]) n++; return Math.round((n / c.lessons.length) * 100); }
    function streak() { const a = get('activity', []); if (!a.length) return 0; const s = {}; a.forEach((d) => (s[d] = 1)); const key = (dt) => dt.getFullYear() + '-' + (dt.getMonth() + 1) + '-' + dt.getDate(); let d = new Date(); if (!s[key(d)]) { d.setDate(d.getDate() - 1); if (!s[key(d)]) return 0; } let n = 0; while (s[key(d)]) { n++; d.setDate(d.getDate() - 1); } return n; }

    fetch('/assets/data/courses.json').then((r) => r.json()).then((data) => {
      const root = document.getElementById('dash');
      const tn = (t) => (data.topics.find((x) => x.id === t) || {}).name || t;
      const pub = data.courses.filter((c) => c.status === 'published');
      const completed = [], started = [], fresh = [];
      pub.forEach((c) => { if (passed(c.id)) completed.push(c); else if (progress(c) > 0) started.push(c); else fresh.push(c); });
      let lessonsDone = 0; pub.forEach((c) => { const d = get('done_' + c.id, {}); for (const k in d) if (d[k]) lessonsDone++; });
      const name = (get('profile', {}) || {}).name || '';
      const points = lessonsDone * 10 + completed.length * 100;
      const st = streak();
      let topicMaster = false;
      data.topics.forEach((t) => { const inT = pub.filter((c) => c.topic === t.id); if (inT.length && inT.every((c) => passed(c.id))) topicMaster = true; });
      const badges = [
        ['First Step', '🌱', lessonsDone >= 1, 'Complete a lesson'], ['Graduate', '🎓', completed.length >= 1, 'Pass a course'],
        ['Dedicated', '📚', completed.length >= 5, 'Pass 5 courses'], ['Scholar', '🏅', completed.length >= 10, 'Pass 10 courses'],
        ['Vidwan', '👑', completed.length >= 20, 'Pass 20 courses'], ['Steady', '🔥', st >= 7, '7-day streak'], ['Topic Master', '⭐', topicMaster, 'Finish a topic'],
      ];
      const stat = (n, l) => `<div class="rounded-xl2 border border-line border-t-4 border-t-saffron bg-surface p-4 text-center shadow-card"><div class="text-3xl font-bold text-navy">${n}</div><div class="font-sans text-xs text-muted">${l}</div></div>`;
      const cardCls = 'card';
      function section(title, list, mode) {
        if (!list.length) return '';
        return `<h3 class="mt-10 text-xl font-bold">${title}</h3><div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">${list.map((c) => {
          const p = progress(c);
          const extra = mode === 'completed' ? `<a class="btn btn-primary mt-3" href="/cert.html?course=${c.id}">View certificate →</a>`
            : mode === 'started' ? `<div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-paper"><div class="h-full bg-saffron" style="width:${p}%"></div></div><div class="font-sans text-xs text-muted mt-1">${p}% complete</div>` : '';
          return `<a href="/course/${c.id}.html" class="${cardCls}"><div class="flex flex-wrap gap-2 font-sans text-xs text-muted"><span class="pill bg-[#e7ecf5] text-navy">${esc(tn(c.topic))}</span><span class="pill bg-paper text-muted">${c.level} level</span></div><h3 class="mt-1 text-lg font-bold text-navy">${esc(c.title)}</h3>${extra}</a>`;
        }).join('')}</div>`;
      }
      root.innerHTML = `
        <h1 class="text-3xl font-bold">${name ? 'Welcome back, ' + esc(name) : 'My Learning'}</h1>
        <div class="mt-4 flex flex-wrap items-center gap-2 rounded-xl2 border border-line bg-surface p-4">
          <span class="font-sans text-sm text-muted">Your name (shown on certificates):</span>
          <input id="nm" type="text" value="${esc(name)}" placeholder="Your full name" class="min-w-[180px] flex-1 rounded-lg border border-line px-3 py-2 font-sans" />
          <button id="save-nm" class="btn btn-primary">Save</button>
        </div>
        <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">${stat(points, 'Points')}${stat(st, 'Day streak')}${stat(completed.length, 'Completed')}${stat(lessonsDone, 'Lessons done')}</div>
        <h3 class="mt-10 text-xl font-bold">Badges</h3>
        <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">${badges.map((b) => `<div class="rounded-xl2 border ${b[2] ? 'border-saffron shadow-card' : 'border-line opacity-50 grayscale'} bg-surface p-4 text-center"><div class="text-3xl">${b[1]}</div><div class="mt-1 font-sans text-sm font-bold text-navy">${b[0]}</div><div class="font-sans text-xs text-muted">${b[3]}</div></div>`).join('')}</div>
        <div class="mt-6"><button id="exp" class="btn">⬇ Export my notes (.md)</button></div>
        ${!completed.length && !started.length ? '<div class="mt-8 rounded-xl2 border border-line bg-surface p-4">You have not started a course yet. <a class="underline" href="/catalog.html">Browse the catalogue</a> and begin — your progress and certificates appear here.</div>' : ''}
        ${section('Continue learning', started, 'started')}
        ${section('Completed — certificates earned', completed, 'completed')}
        ${section('Start something new', fresh.slice(0, 6), 'fresh')}`;
      document.getElementById('save-nm').addEventListener('click', () => { const p = get('profile', {}); p.name = document.getElementById('nm').value.trim(); set('profile', p); location.reload(); });
      document.getElementById('exp').addEventListener('click', () => {
        const lines = ['# My Sikh University notes', ''];
        data.courses.forEach((c) => (c.lessons || []).forEach((ls, i) => { const n = get('note_' + c.id + '_' + i, ''); if (n && n.trim()) lines.push('## ' + c.title + ' — ' + ls.title, '', n.trim(), ''); }));
        if (lines.length <= 2) lines.push('_No notes yet._');
        const a = document.createElement('a'); a.href = URL.createObjectURL(new Blob([lines.join('\n')], { type: 'text/markdown' })); a.download = 'sikh-university-notes.md'; a.click();
      });
    }).catch(() => { document.getElementById('dash').innerHTML = '<p class="text-muted">Could not load.</p>'; });
  </script>
</Base>
