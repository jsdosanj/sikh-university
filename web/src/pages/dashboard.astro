---
import Base from '../layouts/Base.astro';
---
<Base title="My Learning — Sikh University" description="Your progress, certificates, streak and badges at Sikh University.">
  <section class="wrap py-12">
    <div id="bar"></div>
    <div id="dash"><p class="text-muted">Loading your learning…</p></div>
  </section>
  <script>
    const esc = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const get = (k, d) => { try { const v = localStorage.getItem('su_v1_' + k); return v == null ? d : JSON.parse(v); } catch { return d; } };
    const set = (k, v) => { try { localStorage.setItem('su_v1_' + k, JSON.stringify(v)); } catch {} };
    const passed = (id) => !!get('passed_' + id, false);
    function progress(c) { if (!c.lessons || !c.lessons.length) return 0; const d = get('done_' + c.id, {}); let n = 0; for (const k in d) if (d[k]) n++; return Math.round((n / c.lessons.length) * 100); }
    function streak() { const a = get('activity', []); if (!a.length) return 0; const s = {}; a.forEach((d) => (s[d] = 1)); const key = (dt) => dt.getFullYear() + '-' + (dt.getMonth() + 1) + '-' + dt.getDate(); let d = new Date(); if (!s[key(d)]) { d.setDate(d.getDate() - 1); if (!s[key(d)]) return 0; } let n = 0; while (s[key(d)]) { n++; d.setDate(d.getDate() - 1); } return n; }

    const fmtRel = (ts) => { if (!ts) return '—'; const s = (Date.now() - ts) / 1000; if (s < 86400) return 'today'; const d = Math.floor(s / 86400); if (d < 7) return d + 'd ago'; if (d < 30) return Math.floor(d / 7) + 'w ago'; return Math.floor(d / 30) + 'mo ago'; };
    const grade = (s) => s >= 90 ? 'A' : s >= 80 ? 'B' : s >= 70 ? 'C' : s >= 60 ? 'D' : 'F';
    const api = (p, o) => fetch(p, { credentials: 'same-origin', headers: o ? { 'content-type': 'application/json' } : undefined, ...(o || {}) }).then((r) => (r.ok ? r.json() : { user: null, error: true })).catch(() => ({ user: null, error: true }));
    // Profile allowlists — keep in sync with functions/api/_profile-options.js.
    const COUNTRIES = ['Afghanistan','Albania','Algeria','Argentina','Armenia','Australia','Austria','Azerbaijan','Bahrain','Bangladesh','Belgium','Bhutan','Bolivia','Bosnia and Herzegovina','Brazil','Brunei','Bulgaria','Cambodia','Cameroon','Canada','Chile','China','Colombia','Croatia','Cyprus','Czechia','Denmark','Ecuador','Egypt','Estonia','Ethiopia','Fiji','Finland','France','Georgia','Germany','Ghana','Greece','Guatemala','Hong Kong','Hungary','Iceland','India','Indonesia','Iran','Iraq','Ireland','Israel','Italy','Jamaica','Japan','Jordan','Kazakhstan','Kenya','Kuwait','Kyrgyzstan','Laos','Latvia','Lebanon','Libya','Lithuania','Luxembourg','Malaysia','Maldives','Malta','Mauritius','Mexico','Moldova','Mongolia','Morocco','Myanmar','Nepal','Netherlands','New Zealand','Nigeria','North Macedonia','Norway','Oman','Pakistan','Panama','Paraguay','Peru','Philippines','Poland','Portugal','Qatar','Romania','Russia','Rwanda','Saudi Arabia','Serbia','Singapore','Slovakia','Slovenia','South Africa','South Korea','Spain','Sri Lanka','Sweden','Switzerland','Syria','Taiwan','Tanzania','Thailand','Tunisia','Turkey','Turkmenistan','Uganda','Ukraine','United Arab Emirates','United Kingdom','United States','Uruguay','Uzbekistan','Venezuela','Vietnam','Yemen','Zambia','Zimbabwe','Other'];
    const LANGUAGES = ['Punjabi','English','Hindi','Urdu','Gurmukhi','Shahmukhi','Bengali','Tamil','Telugu','Marathi','Gujarati','Kannada','Malayalam','Sindhi','Pashto','Farsi','Arabic','Spanish','French','German','Portuguese','Italian','Dutch','Russian','Mandarin','Cantonese','Japanese','Korean','Thai','Vietnamese','Indonesian','Malay','Swahili','Turkish','Other'];
    Promise.all([api('/api/me'), fetch('/assets/data/courses.json').then((r) => r.json()), api('/api/progress'), api('/api/enrollments')]).then(([me, data, prog, enrollRes]) => {
      // Server is the source of truth for grades: merge it into the local cache before rendering.
      if (prog && prog.progress) prog.progress.forEach((row) => {
        if (row.passed_score != null) { set('score_' + row.course_id, row.passed_score); if (row.passed_score >= 80) set('passed_' + row.course_id, row.passed_score); }
        try { const arr = JSON.parse(row.done || '[]'); if (arr.length) { const d = get('done_' + row.course_id, {}); arr.forEach((i) => { d[i] = true; }); set('done_' + row.course_id, d); } } catch (e) {}
      });
      const user = me && me.user;
      // Explicit registrations (server is source of truth for signed-in users).
      const enr = (enrollRes && enrollRes.enrollments) || [];
      const enrolledCourses = new Set(enr.filter((e) => e.kind === 'course').map((e) => e.target_id));
      const registeredPrograms = new Set(enr.filter((e) => e.kind === 'program').map((e) => e.target_id));
      const isAdmin = !!(user && user.role === 'admin');
      const demo = new URLSearchParams(location.search).get('demo');
      const viewAs = (isAdmin && (demo === 'student' || demo === 'teacher')) ? demo : (user ? user.role : 'student');
      const root = document.getElementById('dash');
      const bar = document.getElementById('bar');

      if (isAdmin) {
        const link = (label, d, on) => `<a href="/dashboard${d ? '?demo=' + d : ''}" class="rounded-lg px-3 py-1.5 font-sans text-sm ${on ? 'bg-brand text-white' : 'border border-line hover:border-saffron'}">${label}</a>`;
        bar.innerHTML = `<div class="mb-6 flex flex-wrap items-center gap-2 rounded-xl2 border border-line bg-surface p-3">
          <span class="font-sans text-sm font-semibold text-navy">Admin preview:</span>
          ${link('Student view', 'student', viewAs === 'student')}
          ${link('Teacher view', 'teacher', viewAs === 'teacher')}
          <a href="/admin" class="ml-auto rounded-lg px-3 py-1.5 font-sans text-sm border border-line hover:border-saffron">← Admin dashboard</a>
        </div>` + (demo ? `<div class="mb-6 rounded-xl2 border-l-4 border-saffron bg-saffron-soft/40 p-3 font-sans text-sm">Demo mode — a sample <strong>${esc(demo)}</strong> dashboard for testing. The figures shown are illustrative.</div>` : '');
      }

      const tn = (t) => (data.topics.find((x) => x.id === t) || {}).name || t;
      const pub = data.courses.filter((c) => c.status === 'published');

      // Tabs: My Learning | Profile. Any signed-in user can edit their account.
      function renderLearning() { if (viewAs === 'teacher') renderTeacher(); else renderStudent(); }
      let view = (user && location.hash === '#profile') ? 'profile' : 'learning';
      function drawView() {
        const nav = document.getElementById('dash-tabs');
        if (nav) Array.from(nav.children).forEach((b) => { const on = b.dataset.v === view; b.className = 'px-4 py-2 font-sans text-sm border-b-2 ' + (on ? 'border-saffron text-navy font-semibold' : 'border-transparent text-muted'); });
        if (view === 'profile') renderProfile(); else renderLearning();
      }
      if (user) {
        const nav = document.createElement('div');
        nav.id = 'dash-tabs';
        nav.className = 'mb-6 flex gap-1 border-b border-line';
        nav.innerHTML = [['learning', 'My Learning'], ['profile', 'Profile']].map(([k, l]) => `<button data-v="${k}" class="px-4 py-2 font-sans text-sm border-b-2 border-transparent text-muted">${l}</button>`).join('');
        bar.appendChild(nav);
        nav.querySelectorAll('button').forEach((b) => b.addEventListener('click', () => { view = b.dataset.v; location.hash = view === 'profile' ? '#profile' : ''; drawView(); }));
      }
      drawView();
      return;

      function renderProfile() {
        const cur = user || {};
        const curLangs = new Set(((cur.languages || '') + '').split(',').map((s) => s.trim()).filter(Boolean));
        const countryOpts = ['<option value="">— Select country —</option>'].concat(COUNTRIES.map((c) => `<option value="${esc(c)}" ${cur.country === c ? 'selected' : ''}>${esc(c)}</option>`)).join('');
        const langChecks = LANGUAGES.map((l) => `<label class="inline-flex cursor-pointer items-center gap-1.5 rounded-lg border border-line bg-paper px-2.5 py-1 font-sans text-xs has-[:checked]:border-saffron has-[:checked]:bg-saffron-soft/40"><input type="checkbox" value="${esc(l)}" ${curLangs.has(l) ? 'checked' : ''} class="pf-lang" /> ${esc(l)}</label>`).join('');
        root.innerHTML = `
          <h1 class="text-3xl font-bold">Profile</h1>
          <p class="mt-2 font-sans text-sm text-muted">Update your account details. Please don't include sensitive personal information — see our <a class="underline" href="/legal">Terms &amp; Privacy</a>.</p>
          <div id="pf-msg" class="mt-4"></div>
          <div class="mt-6 max-w-xl space-y-5">
            <label class="block"><span class="font-sans text-sm font-semibold">Sign-in email</span>
              <input type="email" value="${esc(cur.email || '')}" disabled class="mt-1 w-full rounded-xl border border-line bg-paper px-4 py-2.5 font-sans text-muted" />
              <span class="font-sans text-xs text-muted">Your magic-link sign-in address — it can't be changed here.</span>
            </label>
            <label class="block"><span class="font-sans text-sm font-semibold">Full name</span>
              <input id="pf-name" type="text" maxlength="80" value="${esc(cur.name || '')}" placeholder="Your full name" class="mt-1 w-full rounded-xl border border-line bg-surface px-4 py-2.5 font-sans focus:border-saffron focus:outline-none" />
              <span class="font-sans text-xs text-muted">Shown on your certificates and to your teachers.</span>
            </label>
            <label class="block"><span class="font-sans text-sm font-semibold">Country</span>
              <select id="pf-country" class="mt-1 w-full rounded-xl border border-line bg-surface px-4 py-2.5 font-sans focus:border-saffron focus:outline-none">${countryOpts}</select>
            </label>
            <div><span class="font-sans text-sm font-semibold">Languages</span>
              <div class="mt-2 flex flex-wrap gap-2">${langChecks}</div>
            </div>
            <button id="pf-save" class="btn btn-primary">Save profile</button>
          </div>
          <div class="mt-10 max-w-xl border-t border-line pt-6">
            <h2 class="text-xl font-bold">Your data</h2>
            <p class="mt-1 font-sans text-sm text-muted">Download everything we hold for your account, or permanently delete it.</p>
            <div class="mt-4 flex flex-wrap gap-3">
              <button id="pf-export" class="btn">⬇ Export my data (.json)</button>
              <button id="pf-delete" class="btn border border-danger/40 text-danger hover:bg-danger/10">Delete my account…</button>
            </div>
            <div id="pf-del-confirm" class="mt-4 hidden rounded-xl2 border-l-4 border-danger bg-surface p-4">
              <p class="font-sans text-sm">This permanently erases your profile, progress, enrolments, certificates, ratings and posts. <strong>It cannot be undone.</strong> Type <strong>DELETE</strong> to confirm.</p>
              <div class="mt-3 flex flex-wrap items-center gap-2">
                <input id="pf-del-input" type="text" placeholder="DELETE" class="rounded-lg border border-line bg-surface px-3 py-2 font-sans" />
                <button id="pf-del-go" class="btn border border-danger/40 text-danger hover:bg-danger/10">Permanently delete</button>
                <button id="pf-del-cancel" class="btn">Cancel</button>
              </div>
            </div>
          </div>`;
        document.getElementById('pf-export').addEventListener('click', () => { window.location.href = '/api/account/export'; });
        const delConfirm = document.getElementById('pf-del-confirm');
        document.getElementById('pf-delete').addEventListener('click', () => { delConfirm.classList.remove('hidden'); document.getElementById('pf-del-input').focus(); });
        document.getElementById('pf-del-cancel').addEventListener('click', () => { delConfirm.classList.add('hidden'); document.getElementById('pf-del-input').value = ''; });
        document.getElementById('pf-del-go').addEventListener('click', () => {
          const confirm = document.getElementById('pf-del-input').value.trim();
          const btn = document.getElementById('pf-del-go');
          if (confirm !== 'DELETE') { document.getElementById('pf-del-input').focus(); return; }
          btn.disabled = true; btn.textContent = 'Deleting…';
          api('/api/account/delete', { method: 'POST', body: JSON.stringify({ confirm: 'DELETE' }) }).then((res) => {
            if (res && res.ok) { try { Object.keys(localStorage).filter((k) => k.indexOf('su_v1_') === 0).forEach((k) => localStorage.removeItem(k)); } catch (e) {} location.href = '/?deleted=1'; }
            else { btn.disabled = false; btn.textContent = 'Permanently delete'; }
          });
        });
        document.getElementById('pf-save').addEventListener('click', () => {
          const btn = document.getElementById('pf-save'); btn.disabled = true; btn.textContent = 'Saving…';
          const name = document.getElementById('pf-name').value.trim();
          const country = document.getElementById('pf-country').value;
          const languages = Array.from(document.querySelectorAll('.pf-lang:checked')).map((c) => c.value);
          api('/api/me', { method: 'POST', body: JSON.stringify({ name, country, languages }) }).then((res) => {
            btn.disabled = false; btn.textContent = 'Save profile';
            const msg = document.getElementById('pf-msg');
            if (res && res.user) {
              user.name = res.user.name; user.country = res.user.country; user.languages = res.user.languages;
              const p = get('profile', {}); p.name = res.user.name || ''; set('profile', p); // keep cert.astro in sync
              if (msg) msg.innerHTML = '<div class="rounded-xl border-l-4 border-ok bg-surface p-3 font-sans text-sm"><strong>Saved.</strong> Your profile is up to date.</div>';
            } else if (msg) {
              msg.innerHTML = '<div class="rounded-xl border-l-4 border-saffron bg-surface p-3 font-sans text-sm">Could not save your profile. Please try again.</div>';
            }
          });
        });
      }

      function renderStudent() {
        const completed = [], started = [], fresh = [];
        pub.forEach((c) => { if (passed(c.id)) completed.push(c); else if (progress(c) > 0 || enrolledCourses.has(c.id)) started.push(c); else fresh.push(c); });
        let lessonsDone = 0; pub.forEach((c) => { const d = get('done_' + c.id, {}); for (const k in d) if (d[k]) lessonsDone++; });
        const name = (user && user.name) || (get('profile', {}) || {}).name || '';
        const points = lessonsDone * 10 + completed.length * 100;
        const st = streak();
        let topicMaster = false;
        data.topics.forEach((t) => { const inT = pub.filter((c) => c.topic === t.id); if (inT.length && inT.every((c) => passed(c.id))) topicMaster = true; });
        // Academic standing badges — based on completing all courses at each level tier
        const lvl = (min, max) => pub.filter((c) => c.level >= min && c.level < max);
        const lvl1 = lvl(100, 200), lvl2 = lvl(200, 300), lvl3 = lvl(300, 400), lvl4 = lvl(400, 500), lvl5 = lvl(500, 600);
        const allPassed = (cs) => cs.length > 0 && cs.every((c) => passed(c.id));
        const levelProg = (cs) => `${cs.filter((c) => passed(c.id)).length}/${cs.length}`;
        const badges = [
          ['First Step', '🌱', lessonsDone >= 1, 'Complete your first lesson'],
          ['Freshman', '🎒', allPassed(lvl1), 'Pass all 100-level courses'],
          ['Sophomore', '📖', allPassed(lvl2), 'Pass all 200-level courses'],
          ['Junior', '🔬', allPassed(lvl3), 'Pass all 300-level courses'],
          ['Senior', '🎖️', allPassed(lvl4), 'Pass all 400-level courses'],
          ['Graduate', '🏛️', allPassed(lvl5), 'Pass all 500-level courses'],
          ['Dedicated', '📚', completed.length >= 25, 'Pass 25 courses'],
          ['Scholar', '🏅', completed.length >= 100, 'Pass 100 courses'],
          ['Vidhvaan', '👑', completed.length >= 250, 'Pass 250 courses'],
          ['Steady', '🔥', st >= 7, '7-day streak'],
          ['Topic Master', '⭐', topicMaster, 'Finish an entire topic'],
        ];
        const stat = (n, l) => `<div class="rounded-xl2 border border-line border-t-4 border-t-saffron bg-surface p-4 text-center shadow-card"><div class="text-3xl font-bold text-navy">${n}</div><div class="font-sans text-xs text-muted">${l}</div></div>`;
        function section(title, list, mode) {
          if (!list.length) return '';
          return `<h3 class="mt-10 text-xl font-bold">${title}</h3><div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 xl:grid-cols-4">${list.map((c) => {
            const p = progress(c);
            const extra = mode === 'completed' ? `<a class="btn btn-primary mt-3" href="/cert?course=${c.id}">View certificate →</a>`
              : mode === 'started' ? `<div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-paper"><div class="h-full bg-saffron" style="width:${p}%"></div></div><div class="font-sans text-xs text-muted mt-1">${p}% complete</div>` : '';
            return `<a href="/course/${c.id}" class="card"><div class="flex flex-wrap gap-2 font-sans text-xs text-muted"><span class="pill bg-paper text-navy">${esc(tn(c.topic))}</span><span class="pill bg-paper text-muted">${c.level} level</span></div><h3 class="mt-1 text-lg font-bold text-navy">${esc(c.title)}</h3>${extra}</a>`;
          }).join('')}</div>`;
        }
        const graded = pub.filter((c) => passed(c.id) || progress(c) > 0 || get('score_' + c.id, null) != null);
        const gradesHtml = graded.length ? `<h3 class="mt-10 text-xl font-bold">My grades</h3><div class="mt-4 overflow-x-auto rounded-xl2 border border-line"><table class="w-full font-sans text-sm"><thead><tr class="text-left text-muted"><th class="px-3 py-2">Course</th><th>Progress</th><th>Test score</th><th>Status</th></tr></thead><tbody>${graded.map((c) => { const sc = get('score_' + c.id, null); const p = progress(c); const ok = passed(c.id); return `<tr class="border-t border-line"><td class="px-3 py-2 font-semibold text-navy"><a href="/course/${c.id}" class="hover:underline">${esc(c.title)}</a></td><td>${p}%</td><td>${sc != null ? sc + '%' : '—'}</td><td>${ok ? '<span class="pill bg-saffron-soft text-saffron-deep">Passed</span>' : (p > 0 || sc != null ? '<span class="pill bg-paper text-muted">In progress</span>' : '—')}</td></tr>`; }).join('')}</tbody></table></div>` : '';
        let applyCta = '';
        if (user && user.role === 'learner' && get('signup_intent', '') === 'teacher') applyCta = `<div class="mt-4 rounded-xl2 border-l-4 border-saffron bg-saffron-soft/40 p-4 font-sans text-sm">You signed up to teach. <a class="underline font-semibold" href="/teach">Complete your teacher application →</a></div>`;
        root.innerHTML = `
          <h1 class="text-3xl font-bold">${name ? 'Welcome back, ' + esc(name) : 'My Learning'}</h1>
          ${applyCta}
          <div id="ann-feed"></div>
          ${user ? `<p class="mt-3 font-sans text-sm text-muted">Set your name, country and languages in the <a class="underline" href="#profile" id="go-profile">Profile</a> tab — your name appears on certificates.</p>` : ''}
          <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">${stat(points, 'Points')}${stat(st, 'Day streak')}${stat(completed.length, 'Completed')}${stat(lessonsDone, 'Lessons done')}</div>
          <a href="/baal-updesh#flashcards" class="mt-6 flex items-center gap-4 rounded-xl2 border border-line bg-surface p-4 shadow-card transition hover:border-saffron"><span class="text-3xl">🃏</span><span><span class="block font-bold text-navy">Review flashcards</span><span class="block font-sans text-sm text-muted">Lock in Gurmukhi terms and the most-used words of Gurbani with spaced repetition.</span></span><span class="ml-auto font-sans text-sm text-saffron-deep">Study →</span></a>
          <h3 class="mt-10 text-xl font-bold">Badges</h3>
          <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">${badges.map((b) => {
            let prog = '';
            if (b[0] === 'Freshman') prog = `<div class="mt-1 font-sans text-xs text-muted/70">${levelProg(lvl1)} courses</div>`;
            else if (b[0] === 'Sophomore') prog = `<div class="mt-1 font-sans text-xs text-muted/70">${levelProg(lvl2)} courses</div>`;
            else if (b[0] === 'Junior') prog = `<div class="mt-1 font-sans text-xs text-muted/70">${levelProg(lvl3)} courses</div>`;
            else if (b[0] === 'Senior') prog = `<div class="mt-1 font-sans text-xs text-muted/70">${levelProg(lvl4)} courses</div>`;
            else if (b[0] === 'Graduate') prog = lvl5.length ? `<div class="mt-1 font-sans text-xs text-muted/70">${levelProg(lvl5)} courses</div>` : `<div class="mt-1 font-sans text-xs text-muted/70">Coming soon</div>`;
            else if (b[0] === 'Dedicated') prog = `<div class="mt-1 font-sans text-xs text-muted/70">${Math.min(completed.length,25)}/25</div>`;
            else if (b[0] === 'Scholar') prog = `<div class="mt-1 font-sans text-xs text-muted/70">${Math.min(completed.length,100)}/100</div>`;
            else if (b[0] === 'Vidhvaan') prog = `<div class="mt-1 font-sans text-xs text-muted/70">${Math.min(completed.length,250)}/250</div>`;
            else if (b[0] === 'Steady') prog = `<div class="mt-1 font-sans text-xs text-muted/70">${Math.min(st,7)}/7 days</div>`;
            return `<div class="rounded-xl2 border ${b[2] ? 'border-saffron shadow-card' : 'border-line opacity-50 grayscale'} bg-surface p-4 text-center"><div class="text-3xl">${b[1]}</div><div class="mt-1 font-sans text-sm font-bold text-navy">${b[0]}</div><div class="font-sans text-xs text-muted">${b[3]}</div>${b[2] ? '<div class="mt-1 font-sans text-xs text-saffron-deep font-semibold">✓ Earned</div>' : prog}</div>`;
          }).join('')}</div>
          ${gradesHtml}
          <div id="prog-summary-section"></div>
          <div class="mt-6"><button id="exp" class="btn">⬇ Export my notes (.md)</button></div>
          ${!completed.length && !started.length ? '<div class="mt-8 rounded-xl2 border border-line bg-surface p-4">You have not started a course yet. <a class="underline" href="/catalog">Browse the catalogue</a> and begin — your progress and certificates appear here.</div>' : ''}
          ${section('Continue learning', started, 'started')}
          ${section('Completed — certificates earned', completed, 'completed')}
          ${section('Start something new', fresh.slice(0, 6), 'fresh')}`;
        // Announcements from teachers of the courses this student is taking.
        const enrolled = new Set(pub.filter((c) => passed(c.id) || progress(c) > 0).map((c) => c.id));
        if (enrolled.size) api('/api/announcements').then((d) => {
          const list = ((d && d.announcements) || []).filter((a) => enrolled.has(a.course_id)).slice(0, 5);
          const fe = document.getElementById('ann-feed'); if (!fe || !list.length) return;
          fe.innerHTML = `<h3 class="mt-8 text-xl font-bold">Announcements</h3><div class="mt-4 space-y-3">${list.map((a) => { const c = pub.find((x) => x.id === a.course_id); return `<div class="rounded-xl2 border-l-4 border-saffron bg-surface p-4"><div class="font-sans text-xs text-muted">${esc(c ? c.title : a.course_id)} · ${esc(a.author_name || '')} · ${fmtRel(a.created_at)}</div>${a.title ? `<div class="mt-1 font-bold text-navy">${esc(a.title)}</div>` : ''}<p class="mt-1 text-sm">${esc(a.body)}</p></div>`; }).join('')}</div>`;
        });
        // Program progress summary
        fetch('/assets/data/programs.json').then(r => r.json()).then(pd => {
          const el = document.getElementById('prog-summary-section'); if (!el) return;
          const active = pd.programs.filter(p => {
            const done = p.courseIds.filter(id => passed(id)).length;
            return done > 0 || registeredPrograms.has(p.id);
          });
          if (!active.length) return;
          el.innerHTML = `<h3 class="mt-10 text-xl font-bold">My Degree Programs</h3>
          <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          ${active.map(p => {
            const done = p.courseIds.filter(id => passed(id)).length;
            const total = p.courseIds.length;
            const pct = Math.round((done/total)*100);
            const cumDone = get('cum_passed_' + p.id, false);
            const reg = registeredPrograms.has(p.id);
            return `<a href="/program/${p.id}" class="card hover:border-saffron transition">
              <div class="flex items-center gap-2"><span class="text-2xl">${p.icon}</span><div><div class="font-sans text-xs text-muted font-bold">${esc(p.abbreviation)}${reg ? ' · <span class="text-saffron-deep">Registered</span>' : ''}</div><div class="font-semibold text-navy text-sm leading-tight">${esc(p.title)}</div></div></div>
              <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-paper border border-line"><div class="h-full bg-saffron" style="width:${pct}%"></div></div>
              <div class="mt-1 font-sans text-xs text-muted">${done}/${total} courses ${cumDone ? '· <span class="text-saffron-deep font-semibold">✓ Credential earned</span>' : ''}</div>
            </a>`;
          }).join('')}</div>
          <a href="/programs" class="mt-3 inline-block font-sans text-sm text-saffron-deep underline">Browse all degree programs →</a>`;
        }).catch(() => {});
        const goP = document.getElementById('go-profile');
        if (goP) goP.addEventListener('click', (e) => { e.preventDefault(); view = 'profile'; location.hash = '#profile'; drawView(); });
        document.getElementById('exp').addEventListener('click', () => {
          const lines = ['# My Sikh University notes', ''];
          data.courses.forEach((c) => (c.lessons || []).forEach((ls, i) => { const n = get('note_' + c.id + '_' + i, ''); if (n && n.trim()) lines.push('## ' + c.title + ' — ' + ls.title, '', n.trim(), ''); }));
          if (lines.length <= 2) lines.push('_No notes yet._');
          const a = document.createElement('a'); a.href = URL.createObjectURL(new Blob([lines.join('\n')], { type: 'text/markdown' })); a.download = 'sikh-university-notes.md'; a.click();
        });
      }

      function renderTeacher() {
        const stat = (n, l) => `<div class="rounded-xl2 border border-line border-t-4 border-t-saffron bg-surface p-4 text-center shadow-card"><div class="text-3xl font-bold text-navy">${n}</div><div class="font-sans text-xs text-muted">${l}</div></div>`;
        const lessonCount = (id) => { const c = pub.find((x) => x.id === id); return (c && c.lessons) ? c.lessons.length : 0; };
        const slugTitle = (id) => String(id || '').replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
        const ctitle = (id) => { const c = pub.find((x) => x.id === id); return c ? c.title : slugTitle(id); };

        if (demo) { renderTeacherDemo(stat); return; }

        root.innerHTML = '<h1 class="text-3xl font-bold">Teacher dashboard</h1><p class="mt-6 text-muted">Loading your gradebook…</p>';
        api('/api/gradebook').then((g) => {
          const tcourses = g.courses || [];
          const rows = g.rows || [];
          if (!tcourses.length) {
            root.innerHTML = `<h1 class="text-3xl font-bold">Teacher dashboard</h1>
              <div class="mt-6 rounded-xl2 border border-line bg-surface p-6 text-muted">You are not assigned to any courses yet. An admin assigns teachers to courses.</div>
              <div class="mt-6"><a class="btn" href="/dashboard?demo=teacher">Preview a sample teacher dashboard →</a></div>`;
            return;
          }
          const students = new Set(rows.map((r) => r.user_id));
          const completions = rows.filter((r) => r.score != null && r.score >= 80).length;
          const scored = rows.filter((r) => r.score != null);
          const avg = scored.length ? Math.round(scored.reduce((a, r) => a + r.score, 0) / scored.length) : 0;

          root.innerHTML = `<h1 class="text-3xl font-bold">Teacher dashboard</h1>
            <p class="mt-1 font-sans text-sm text-muted">Real grades and progress for your students.</p>
            <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">${stat(tcourses.length, 'Courses you teach')}${stat(students.size, 'Students')}${stat(completions, 'Completions')}${stat(avg ? avg + '%' : '—', 'Avg. score')}</div>
            <div class="mt-6 flex flex-wrap gap-2 items-end">
              <input id="t-search" type="search" placeholder="Search students…" class="rounded-lg border border-line bg-paper px-3 py-1.5 font-sans text-sm w-48" />
              <select id="t-status" class="rounded-lg border border-line bg-paper px-2 py-1.5 font-sans text-sm">
                <option value="">All statuses</option><option value="passed">Passed</option><option value="inprogress">In progress</option><option value="notstarted">Not started</option>
              </select>
              <select id="t-sort" class="rounded-lg border border-line bg-paper px-2 py-1.5 font-sans text-sm">
                <option value="score">Sort: Score ↓</option><option value="progress">Sort: Progress ↓</option><option value="name">Sort: Name A→Z</option><option value="active">Sort: Recently active</option>
              </select>
              <button id="t-exp-all" class="btn font-sans text-xs px-3 py-1.5">Expand all</button>
              <button id="t-col-all" class="btn font-sans text-xs px-3 py-1.5">Collapse all</button>
            </div>
            <div id="t-body" class="mt-2"></div>
            <div class="mt-10"><a class="btn" href="/dashboard?demo=student">View the student experience →</a></div>`;

          function renderCourses() {
            const q = (document.getElementById('t-search').value || '').toLowerCase();
            const statusF = document.getElementById('t-status').value;
            const sortF = document.getElementById('t-sort').value;
            const tbody = document.getElementById('t-body');
            if (!tbody) return;

            tbody.innerHTML = tcourses.map((cid) => {
              let cr = rows.filter((r) => r.course_id === cid);
              if (q) cr = cr.filter((r) => (r.name || r.email || '').toLowerCase().includes(q));
              if (statusF === 'passed') cr = cr.filter((r) => r.score != null && r.score >= 80);
              else if (statusF === 'inprogress') cr = cr.filter((r) => r.done > 0 && !(r.score != null && r.score >= 80));
              else if (statusF === 'notstarted') cr = cr.filter((r) => r.done === 0);
              const lc = lessonCount(cid);
              if (sortF === 'score') cr.sort((a, b) => (b.score == null ? -1 : b.score) - (a.score == null ? -1 : a.score));
              else if (sortF === 'progress') cr.sort((a, b) => b.done - a.done);
              else if (sortF === 'name') cr.sort((a, b) => (a.name || a.email || '').localeCompare(b.name || b.email || ''));
              else if (sortF === 'active') cr.sort((a, b) => (b.last_active || 0) - (a.last_active || 0));
              const cs = cr.filter((r) => r.score != null);
              const cavg = cs.length ? Math.round(cs.reduce((a, r) => a + r.score, 0) / cs.length) : 0;
              const passRate = cr.length ? Math.round(cr.filter((r) => r.score != null && r.score >= 80).length / cr.length * 100) : 0;
              const rows_html = cr.map((r, i) => {
                const pct = lc ? Math.round(r.done / lc * 100) : 0;
                const st = (r.score != null && r.score >= 80) ? '<span class="pill bg-saffron-soft text-saffron-deep">Passed</span>' : (r.done > 0 ? '<span class="pill bg-paper text-muted">In progress</span>' : '—');
                return `<tr class="${i % 2 ? 'bg-paper' : ''}" data-u="${esc(r.user_id)}" data-c="${esc(cid)}"><td class="px-3 py-2 font-semibold text-navy">${esc(r.name || r.email)}${r.override ? ' <span title="Grade overridden" class="text-saffron-deep">✎</span>' : ''}</td><td>${pct}%</td><td>${r.score != null ? r.score + '%' : '—'}</td><td>${r.score != null ? grade(r.score) : '—'}</td><td>${st}</td><td class="whitespace-nowrap text-muted">${fmtRel(r.last_active)}</td><td><button class="rounded-lg border border-line px-2 py-1 hover:border-saffron font-sans text-xs" data-ovr>Override</button></td></tr>`;
              }).join('');
              return `<details class="mt-4 rounded-xl2 border border-line bg-surface" open>
                <summary class="cursor-pointer select-none px-4 py-3 flex flex-wrap items-baseline gap-2">
                  <span class="font-bold text-navy">${esc(ctitle(cid))}</span>
                  <span class="font-sans text-xs text-muted">${cr.length} enrolled · avg ${cavg}% · ${passRate}% passed</span>
                  <span class="ml-auto flex gap-2 font-sans text-xs"><button class="underline" data-ann="${esc(cid)}">Announce</button> <button class="underline" data-csv="${esc(cid)}">Export CSV</button></span>
                </summary>
                ${!cr.length ? '<div class="px-4 pb-4 text-muted font-sans text-sm">No students match the current filter.</div>' : `<div class="overflow-x-auto"><table class="w-full font-sans text-sm"><thead><tr class="bg-brand text-left text-white"><th class="px-3 py-2">Student</th><th>Progress</th><th>Score</th><th>Grade</th><th>Status</th><th>Last active</th><th></th></tr></thead><tbody>${rows_html}</tbody></table></div>`}
              </details>`;
            }).join('');

            root.querySelectorAll('[data-csv]').forEach((b) => b.addEventListener('click', (e) => { e.preventDefault(); window.location = '/api/gradebook?format=csv&course=' + encodeURIComponent(b.dataset.csv); }));
            root.querySelectorAll('[data-ann]').forEach((b) => b.addEventListener('click', (e) => { e.preventDefault(); const cid = b.dataset.ann; const title = prompt('Announcement title (optional):'); if (title === null) return; const body = prompt('Message to your students:'); if (!body || !body.trim()) return; api('/api/announcements', { method: 'POST', body: JSON.stringify({ courseId: cid, title, body }) }).then((d) => { alert(d && !d.error ? 'Announcement posted.' : 'Could not post.'); }); }));
            root.querySelectorAll('[data-ovr]').forEach((b) => b.addEventListener('click', () => { const tr = b.closest('[data-u]'); const cur = prompt('Override final score (0–100), or leave blank to clear:'); if (cur === null) return; const blank = cur.trim() === ''; const reason = blank ? '' : (prompt('Reason (optional):') || ''); api('/api/gradebook', { method: 'POST', body: JSON.stringify({ courseId: tr.dataset.c, userId: tr.dataset.u, score: blank ? null : Number(cur), reason }) }).then((d) => { if (d && !d.error) renderCourses(); else alert('Could not save.'); }); }));
          }

          renderCourses();
          ['t-search', 't-status', 't-sort'].forEach((id) => { const el = document.getElementById(id); if (el) { el.addEventListener('input', renderCourses); el.addEventListener('change', renderCourses); } });
          document.getElementById('t-exp-all').addEventListener('click', () => { document.querySelectorAll('#t-body details').forEach((d) => d.open = true); });
          document.getElementById('t-col-all').addEventListener('click', () => { document.querySelectorAll('#t-body details').forEach((d) => d.open = false); });
        });
      }

      function renderTeacherDemo(stat) {
        const taught = pub.slice(0, 4);
        const names = ['Harpreet Kaur', 'Gurmeet Singh', 'Simran Kaur', 'Arjan Singh', 'Manvir Kaur', 'Jasdeep Singh', 'Noor Kaur', 'Ravi Singh'];
        const dscore = (i, j) => 60 + ((i * 7 + j * 13) % 41);
        const roster = names.map((nm, i) => ({ name: nm, email: nm.toLowerCase().replace(/[^a-z]+/g, '.') + '@example.com', active: ['today', '2d ago', '1w ago', 'today', '3d ago', '5d ago', '1d ago', '2w ago'][i] }));
        const cell = (v) => `<td class="border-t border-line px-2 py-1.5">${v}</td>`;
        const gradebook = `<div class="mt-4 overflow-x-auto rounded-xl2 border border-line"><table class="w-full font-sans text-sm"><thead><tr class="bg-brand text-left text-white"><th class="px-2 py-2">Student</th>${taught.map((c) => `<th class="px-2 py-2" title="${esc(c.title)}">${esc(c.title.split(/[:—]/)[0].slice(0, 14))}…</th>`).join('')}<th class="px-2 py-2">Avg</th></tr></thead><tbody>${roster.map((st, i) => { const scores = taught.map((c, j) => dscore(i, j)); const avg = Math.round(scores.reduce((a, b) => a + b, 0) / scores.length); return `<tr class="${i % 2 ? 'bg-paper' : ''}">${cell('<strong>' + esc(st.name) + '</strong>')}${scores.map((s) => `<td class="border-t border-line px-2 py-1.5">${s}% <span class="text-muted">(${grade(s)})</span></td>`).join('')}${cell('<strong>' + avg + '%</strong>')}</tr>`; }).join('')}</tbody></table></div>`;
        const analytics = `<h3 class="mt-10 text-xl font-bold">Course analytics</h3><div class="mt-4 space-y-3">${taught.map((c, j) => { const comp = 35 + ((j * 17) % 55); const avg = 70 + ((j * 9) % 25); return `<div class="rounded-xl2 border border-line bg-surface p-4"><div class="flex flex-wrap items-baseline justify-between gap-2"><span class="font-semibold text-navy">${esc(c.title)}</span><span class="font-sans text-xs text-muted">${(j + 1) * 9} enrolled · avg score ${avg}%</span></div><div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-paper"><div class="h-full bg-saffron" style="width:${comp}%"></div></div><div class="mt-1 font-sans text-xs text-muted">${comp}% completion</div></div>`; }).join('')}</div>`;
        root.innerHTML = `
          <h1 class="text-3xl font-bold">Teacher dashboard</h1>
          <p class="mt-1 font-sans text-sm text-muted">Sample view for testing — figures and students are illustrative.</p>
          <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">${stat(taught.length, 'Courses you teach')}${stat(96, 'Students')}${stat(38, 'Completions')}${stat('4.8★', 'Avg. rating')}</div>
          <h3 class="mt-10 text-xl font-bold">Gradebook</h3>
          <p class="font-sans text-sm text-muted">Each student's test score per course, with a letter grade and class average.</p>
          ${gradebook}
          ${analytics}
          <h3 class="mt-10 text-xl font-bold">Class roster</h3><div class="mt-4 overflow-x-auto rounded-xl2 border border-line"><table class="w-full font-sans text-sm"><thead><tr class="text-left text-muted"><th class="px-3 py-2">Student</th><th>Email</th><th>Last active</th></tr></thead><tbody>${roster.map((st) => `<tr class="border-t border-line"><td class="px-3 py-2 font-semibold text-navy">${esc(st.name)}</td><td>${esc(st.email)}</td><td class="text-muted">${esc(st.active)}</td></tr>`).join('')}</tbody></table></div>
          <div class="mt-8"><a class="btn" href="/dashboard?demo=student">View the student experience →</a></div>`;
      }
    }).catch(() => { document.getElementById('dash').innerHTML = '<p class="text-muted">Could not load.</p>'; });
  </script>
</Base>
