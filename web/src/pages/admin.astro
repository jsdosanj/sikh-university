---
import Base from '../layouts/Base.astro';
---
<Base title="Admin — Sikh University" description="Sikh University admin dashboard.">
  <section class="wrap py-12">
    <div id="admin"><p class="text-muted">Loading…</p></div>
  </section>
  <script>
    const esc = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const api = (p, o = {}) => fetch(p, { credentials: 'same-origin', headers: { 'content-type': 'application/json' }, ...o }).then((r) => r.json().then((d) => ({ ok: r.ok, d })).catch(() => ({ ok: r.ok, d: {} })));
    const fmt = (ts) => { try { return new Date(ts).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }); } catch { return ''; } };
    const root = document.getElementById('admin');
    let courses = [], topics = [];

    api('/api/me').then(({ ok, d }) => {
      const u = ok && d.user;
      if (!u || u.role !== 'admin') { root.innerHTML = '<div class="rounded-xl border-l-4 border-saffron bg-surface p-4">Admins only. <a class="underline" href="/login.html">Sign in</a> with an admin account.</div>'; return; }
      root.innerHTML = `<h1 class="text-3xl font-bold">Admin dashboard</h1><p class="font-sans text-sm text-muted">Signed in as ${esc(u.email)}</p>
        <div id="tabs" class="mt-4 flex flex-wrap gap-1 border-b border-line"></div><div id="panel" class="mt-6"></div>`;
      const tabs = [['overview', 'Overview'], ['courses', 'Courses'], ['applications', 'Applications'], ['feedback', 'Feedback']];
      let cur = 'overview';
      const tabsEl = document.getElementById('tabs'); const panel = document.getElementById('panel');
      tabs.forEach(([k, label]) => { const b = document.createElement('button'); b.textContent = label; b.dataset.k = k; b.className = 'px-4 py-2 font-sans text-sm border-b-2 border-transparent text-muted'; b.onclick = () => { cur = k; draw(); }; tabsEl.appendChild(b); });
      function setActive() { Array.from(tabsEl.children).forEach((b) => { const on = b.dataset.k === cur; b.classList.toggle('border-saffron', on); b.classList.toggle('text-navy', on); b.classList.toggle('font-semibold', on); }); }
      function draw() { setActive(); panel.innerHTML = '<p class="text-muted">Loading…</p>'; ({ overview, courses: coursesTab, applications, feedback })[cur](); }

      function overview() {
        api('/api/admin/stats').then(({ ok, d }) => {
          if (!ok) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4">Could not load stats.</div>'; return; }
          const t = d.totals || {};
          const stat = (n, l) => `<div class="rounded-xl2 border border-line border-t-4 border-t-saffron bg-surface p-4 text-center"><div class="text-3xl font-bold text-navy">${n || 0}</div><div class="font-sans text-xs text-muted">${l}</div></div>`;
          let html = `<div class="grid grid-cols-2 gap-3 sm:grid-cols-4">${stat(t.users, 'Total users')}${stat(t.enrollments, 'Enrollments')}${stat(t.completions, 'Completions')}${stat(t.activeSessions, 'Active sessions')}${stat(t.teachers, 'Teachers')}${stat(t.pendingApplications, 'Pending apps')}${stat(t.newFeedback, 'New feedback')}${stat(t.admins, 'Admins')}</div>`;
          const pop = d.popular || [];
          const title = {}; courses.forEach((c) => (title[c.id] = c.title));
          if (pop.length) { const max = pop[0].learners || 1; html += `<h3 class="mt-8 text-xl font-bold">Most popular courses</h3><table class="mt-3 w-full font-sans text-sm"><thead><tr class="text-left text-muted"><th class="py-1">Course</th><th>Learners</th><th>Completions</th><th></th></tr></thead><tbody>${pop.map((p) => `<tr class="border-t border-line"><td class="py-1">${esc(title[p.course_id] || p.course_id)}</td><td>${p.learners}</td><td>${p.completions}</td><td class="w-1/3"><div class="h-2 rounded bg-saffron" style="width:${Math.max(6, Math.round((p.learners / max) * 100))}%"></div></td></tr>`).join('')}</tbody></table>`; }
          else html += '<div class="mt-6 rounded-xl bg-surface p-4 text-muted">No enrollments yet.</div>';
          panel.innerHTML = html;
        });
      }
      function coursesTab() {
        panel.innerHTML = `<p class="font-sans text-sm text-muted">${courses.length} courses · ${courses.filter((c) => c.status === 'published').length} published · ${topics.length} topics</p>` +
          topics.map((tp) => { const list = courses.filter((c) => c.topic === tp.id).sort((a, b) => a.level - b.level); if (!list.length) return ''; return `<h3 class="mt-6 text-lg font-bold">${esc(tp.name)} (${list.length})</h3><ul class="mt-2 divide-y divide-line">${list.map((c) => `<li class="py-2"><details><summary class="cursor-pointer font-semibold text-navy">${esc(c.title)} <span class="font-sans text-xs font-normal text-muted">· L${c.level} · ${esc(c.professor)} · ${c.status}</span></summary><div class="mt-2 rounded-xl border border-line bg-paper p-3"><p class="text-sm">${esc(c.summary)}</p>${(c.lessons || []).map((ls, i) => `<details class="mt-2"><summary class="cursor-pointer text-sm font-semibold">Lesson ${i + 1}: ${esc(ls.title)}</summary><div class="lesson-prose mt-1 text-sm">${ls.html}</div></details>`).join('')}${c.quiz && c.quiz.length ? `<div class="mt-2 font-sans text-xs text-muted">Test: ${c.quiz.length} questions (answers: ${c.quiz.map((q, i) => (i + 1) + '→' + (q.answer + 1)).join(', ')})</div>` : ''}</div></details></li>`).join('')}</ul>`; }).join('');
      }
      function applications() {
        api('/api/admin/applications').then(({ ok, d }) => {
          if (!ok) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4">Could not load.</div>'; return; }
          const apps = d.applications || [];
          if (!apps.length) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4 text-muted">No pending applications.</div>'; return; }
          panel.innerHTML = apps.map((a) => `<div class="mb-4 rounded-xl2 border border-line bg-surface p-4" data-id="${a.id}"><h3 class="font-bold">${esc(a.name || a.email)}</h3><div class="font-sans text-xs text-muted">${esc(a.email)} · ${fmt(a.created_at)}</div><p class="mt-2 text-sm"><strong>Background:</strong> ${esc(a.background || '')}</p>${a.courses ? `<p class="text-sm"><strong>Wants to teach:</strong> ${esc(a.courses)}</p>` : ''}<div class="mt-3 flex gap-2"><button class="btn btn-primary" data-d="approve">Approve</button><button class="btn" data-d="deny">Deny</button></div></div>`).join('');
          panel.querySelectorAll('[data-d]').forEach((b) => b.addEventListener('click', () => { const card = b.closest('[data-id]'); api('/api/admin/applications', { method: 'POST', body: JSON.stringify({ id: card.dataset.id, decision: b.dataset.d }) }).then(({ ok }) => { if (ok) card.innerHTML = `<div class="rounded-xl border-l-4 border-ok p-3">Application ${b.dataset.d}d.</div>`; }); }));
        });
      }
      function feedback() {
        api('/api/admin/feedback').then(({ ok, d }) => {
          if (!ok) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4">Could not load.</div>'; return; }
          const fb = d.feedback || [];
          if (!fb.length) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4 text-muted">No feedback yet.</div>'; return; }
          panel.innerHTML = `<table class="w-full font-sans text-sm"><thead><tr class="text-left text-muted"><th class="py-1">Date</th><th>Type</th><th>From</th><th>Course</th><th>Message</th></tr></thead><tbody>${fb.map((f) => `<tr class="border-t border-line align-top"><td class="py-1 whitespace-nowrap">${fmt(f.created_at)}</td><td>${esc(f.category || '')}</td><td>${esc(f.email || '—')}</td><td>${esc(f.course_id || '—')}</td><td>${esc(f.message || '')}</td></tr>`).join('')}</tbody></table>`;
        });
      }
      fetch('/assets/data/courses.json').then((r) => r.json()).then((data) => { courses = data.courses; topics = data.topics; draw(); }).catch(draw);
    });
  </script>
</Base>
