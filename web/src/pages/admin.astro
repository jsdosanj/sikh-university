---
import Base from '../layouts/Base.astro';
---
<Base title="Admin — Sikh University" description="Sikh University admin dashboard.">
  <section class="wrap py-12">
    <div id="admin"><p class="text-muted">Loading…</p></div>
  </section>
  <script>
    const esc = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const slugToTitle = (id) => String(id || '').replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
    const ctitle = (id, courses) => { const c = (courses || []).find((x) => x.id === id); return c ? c.title : slugToTitle(id); };
    const api = (p, o = {}) => fetch(p, { credentials: 'same-origin', headers: { 'content-type': 'application/json' }, ...o }).then((r) => r.json().then((d) => ({ ok: r.ok, d })).catch(() => ({ ok: r.ok, d: {} })));
    const fmt = (ts) => { try { return new Date(ts).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }); } catch { return ''; } };
    const grade = (s) => s >= 90 ? 'A' : s >= 80 ? 'B' : s >= 70 ? 'C' : s >= 60 ? 'D' : 'F';
    const root = document.getElementById('admin');
    let courses = [], topics = [], programs = [];

    api('/api/me').then(({ ok, d }) => {
      const u = ok && d.user;
      if (!u || u.role !== 'admin') { root.innerHTML = '<div class="rounded-xl border-l-4 border-saffron bg-surface p-4">Admins only. <a class="underline" href="/login">Sign in</a> with an admin account.</div>'; return; }
      root.innerHTML = `<h1 class="text-3xl font-bold">Admin dashboard</h1><p class="font-sans text-sm text-muted">Signed in as ${esc(u.email)}</p>
        <div id="tabs" class="mt-4 flex flex-wrap gap-1 border-b border-line"></div><div id="panel" class="mt-6"></div>`;
      const tabs = [['overview', 'Overview'], ['users', 'Users'], ['gradebook', 'Gradebook'], ['teachers', 'Teachers'], ['courses', 'Courses'], ['applications', 'Applications'], ['feedback', 'Feedback'], ['audit', 'Audit log']];
      let cur = 'overview';
      const tabsEl = document.getElementById('tabs'); const panel = document.getElementById('panel');
      tabs.forEach(([k, label]) => { const b = document.createElement('button'); b.textContent = label; b.dataset.k = k; b.className = 'px-4 py-2 font-sans text-sm border-b-2 border-transparent text-muted'; b.onclick = () => { cur = k; draw(); }; tabsEl.appendChild(b); });
      function setActive() { Array.from(tabsEl.children).forEach((b) => { const on = b.dataset.k === cur; b.classList.toggle('border-saffron', on); b.classList.toggle('text-navy', on); b.classList.toggle('font-semibold', on); }); }
      function draw() { setActive(); panel.innerHTML = '<p class="text-muted">Loading…</p>'; ({ overview, users, gradebook, teachers, courses: coursesTab, applications, feedback, audit })[cur](); }

      // ── Gradebook ──────────────────────────────────────────────────────────
      function gradebook() {
        Promise.all([api('/api/gradebook'), Promise.resolve(programs)]).then(([{ ok, d }]) => {
          if (!ok) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4">Could not load the gradebook.</div>'; return; }
          const rows = d.rows || [], cids = d.courses || [];
          const lc = (id) => { const c = courses.find((x) => x.id === id); return (c && c.lessons) ? c.lessons.length : 0; };
          if (!rows.length) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4 text-muted">No enrolments yet.</div>'; return; }

          // Build program options
          const progOpts = programs.map((p) => `<option value="${esc(p.id)}">${esc(p.abbreviation || p.title)}</option>`).join('');

          let html = `<div class="mb-4 flex flex-wrap items-end gap-3">
            <p class="font-sans text-sm text-muted grow">${rows.length} enrolment record(s) across ${cids.length} course(s).</p>
            <div class="flex flex-wrap gap-2">
              <input id="gb-search" type="search" placeholder="Filter by student…" class="rounded-lg border border-line bg-paper px-3 py-1.5 font-sans text-xs w-44" />
              <select id="gb-prog" class="rounded-lg border border-line bg-paper px-2 py-1.5 font-sans text-xs">
                <option value="">All programs</option>${progOpts}
              </select>
              <select id="gb-sort" class="rounded-lg border border-line bg-paper px-2 py-1.5 font-sans text-xs">
                <option value="name">Sort: Course A→Z</option>
                <option value="learners">Sort: Learners ↓</option>
                <option value="avg">Sort: Avg score ↓</option>
                <option value="pass">Sort: Pass rate ↓</option>
              </select>
              <a class="btn font-sans text-xs px-3 py-1.5" href="/api/gradebook?format=csv">⬇ Export CSV</a>
            </div>
          </div><div id="gb-body"></div>`;
          panel.innerHTML = html;

          function renderGradebook() {
            const search = (document.getElementById('gb-search') || {}).value || '';
            const progId = (document.getElementById('gb-prog') || {}).value || '';
            const sortBy = (document.getElementById('gb-sort') || {}).value || 'name';
            const q = search.toLowerCase();

            let filteredCids = cids;
            if (progId) {
              const prog = programs.find((p) => p.id === progId);
              if (prog) filteredCids = filteredCids.filter((cid) => prog.courseIds.includes(cid));
            }

            let courseData = filteredCids.map((cid) => {
              const cr = rows.filter((r) => r.course_id === cid);
              const filtered = q ? cr.filter((r) => (r.name || r.email || '').toLowerCase().includes(q)) : cr;
              const cs = cr.filter((r) => r.score != null);
              const cavg = cs.length ? Math.round(cs.reduce((a, r) => a + r.score, 0) / cs.length) : 0;
              const pass = cr.length ? Math.round(cr.filter((r) => r.score != null && r.score >= 80).length / cr.length * 100) : 0;
              return { cid, cr, filtered, cavg, pass };
            }).filter((x) => x.filtered.length > 0 || !q);

            if (sortBy === 'learners') courseData.sort((a, b) => b.cr.length - a.cr.length);
            else if (sortBy === 'avg') courseData.sort((a, b) => b.cavg - a.cavg);
            else if (sortBy === 'pass') courseData.sort((a, b) => b.pass - a.pass);
            else courseData.sort((a, b) => ctitle(a.cid, courses).localeCompare(ctitle(b.cid, courses)));

            const body = document.getElementById('gb-body');
            if (!body) return;
            body.innerHTML = courseData.map(({ cid, cr, filtered, cavg, pass }) => {
              const l = lc(cid);
              const displayRows = q ? filtered : cr;
              const rows_html = displayRows.sort((a, b) => (b.score == null ? -1 : b.score) - (a.score == null ? -1 : a.score)).map((r) => {
                const pct = l ? Math.round(r.done / l * 100) : 0;
                return `<tr class="border-t border-line"><td class="py-1">${esc(r.name || r.email)}${r.override ? ' <span title="Overridden">✎</span>' : ''}</td><td>${pct}%</td><td>${r.score != null ? r.score + '%' : '—'}</td><td>${r.score != null ? grade(r.score) : '—'}</td></tr>`;
              }).join('');
              return `<details class="mt-3 rounded-xl2 border border-line bg-surface p-3">
                <summary class="cursor-pointer font-semibold text-navy select-none">${esc(ctitle(cid, courses))} <span class="font-sans text-xs font-normal text-muted">· ${cr.length} learners · avg ${cavg}% · ${pass}% passed</span></summary>
                <div class="mt-3 overflow-x-auto"><table class="w-full font-sans text-sm"><thead><tr class="text-left text-muted"><th class="py-1">Student</th><th>Progress</th><th>Score</th><th>Grade</th></tr></thead><tbody>${rows_html}</tbody></table></div>
              </details>`;
            }).join('');
          }

          renderGradebook();
          ['gb-search', 'gb-prog', 'gb-sort'].forEach((id) => {
            const el = document.getElementById(id);
            if (el) el.addEventListener('input', renderGradebook);
            if (el) el.addEventListener('change', renderGradebook);
          });
        });
      }

      // ── Teachers ───────────────────────────────────────────────────────────
      function teachers() {
        Promise.all([api('/api/admin/course-teachers'), api('/api/admin/users')]).then(([a, u]) => {
          const assigns = (a.ok && a.d.assignments) || [], usersList = (u.ok && u.d.users) || [];
          const courseOpts = courses.filter((c) => c.status === 'published').slice().sort((x, y) => x.title.localeCompare(y.title)).map((c) => `<option value="${esc(c.id)}">${esc(c.title)}</option>`).join('');
          const userOpts = usersList.filter((x) => x.role !== 'admin').map((x) => `<option value="${esc(x.id)}">${esc(x.email)} (${esc(x.role)})</option>`).join('');
          let html = `<p class="font-sans text-sm text-muted">Assign a teacher to a course.</p>
            <div class="mt-4 flex flex-wrap items-end gap-3 rounded-xl2 border border-line bg-surface p-4">
              <label class="font-sans text-sm">Teacher<br><select id="t-user" class="mt-1 rounded-lg border border-line bg-paper px-2 py-1.5">${userOpts || '<option value="">No eligible users</option>'}</select></label>
              <label class="font-sans text-sm">Course<br><select id="t-course" class="mt-1 rounded-lg border border-line bg-paper px-2 py-1.5">${courseOpts}</select></label>
              <button id="t-assign" class="btn btn-primary">Assign</button>
            </div>
            <h3 class="mt-8 text-lg font-bold">Current assignments (${assigns.length})</h3>`;
          if (!assigns.length) html += '<div class="mt-2 rounded-xl bg-surface p-4 text-muted">No teachers assigned yet.</div>';
          else {
            const byTeacher = {};
            assigns.forEach((x) => { if (!byTeacher[x.email]) byTeacher[x.email] = []; byTeacher[x.email].push(x); });
            html += `<div class="mt-3 grid gap-4 sm:grid-cols-2">${Object.entries(byTeacher).map(([email, ass]) => `<div class="rounded-xl2 border border-line bg-surface p-4"><div class="font-semibold text-navy">${esc(email)}</div><div class="font-sans text-xs text-muted mt-0.5">${ass.length} course${ass.length !== 1 ? 's' : ''} assigned</div><ul class="mt-2 divide-y divide-line">${ass.map((x) => `<li class="py-1 flex items-center justify-between"><span class="text-sm">${esc(ctitle(x.course_id, courses))}</span><button class="rounded border border-line px-2 py-0.5 font-sans text-xs hover:border-saffron" data-unassign data-c="${esc(x.course_id)}" data-u="${esc(x.user_id)}">Unassign</button></li>`).join('')}</ul></div>`).join('')}</div>`;
          }
          panel.innerHTML = html;
          const ab = document.getElementById('t-assign');
          if (ab) ab.addEventListener('click', () => { const userId = document.getElementById('t-user').value; const courseId = document.getElementById('t-course').value; if (!userId || !courseId) return; api('/api/admin/course-teachers', { method: 'POST', body: JSON.stringify({ userId, courseId, action: 'assign' }) }).then(({ ok }) => { if (ok) draw(); }); });
          panel.querySelectorAll('[data-unassign]').forEach((b) => b.addEventListener('click', () => { api('/api/admin/course-teachers', { method: 'POST', body: JSON.stringify({ courseId: b.dataset.c, userId: b.dataset.u, action: 'unassign' }) }).then(({ ok }) => { if (ok) draw(); }); }));
        });
      }

      // ── Audit ──────────────────────────────────────────────────────────────
      function audit() {
        api('/api/admin/events').then(({ ok, d }) => {
          if (!ok) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4">Could not load the audit log.</div>'; return; }
          const ev = d.events || [];
          if (!ev.length) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4 text-muted">No events logged yet.</div>'; return; }
          const fmtT = (ts) => { try { return new Date(ts).toLocaleString(); } catch { return ''; } };
          panel.innerHTML = `<p class="font-sans text-sm text-muted">${ev.length} most recent events.</p><div class="mt-3 overflow-x-auto"><table class="w-full font-sans text-sm"><thead><tr class="text-left text-muted"><th class="py-1">When</th><th>Who</th><th>Action</th><th>Target</th><th>Detail</th></tr></thead><tbody>${ev.map((e) => `<tr class="border-t border-line align-top"><td class="py-1 whitespace-nowrap">${fmtT(e.ts)}</td><td>${esc(e.email || e.user_id || '—')}</td><td><span class="pill bg-paper text-navy">${esc(e.action)}</span></td><td>${esc(e.target || '—')}</td><td>${esc(e.detail || '')}</td></tr>`).join('')}</tbody></table></div>`;
        });
      }

      // ── Users ──────────────────────────────────────────────────────────────
      function users() {
        Promise.all([api('/api/admin/users'), api('/api/gradebook')]).then(([u, g]) => {
          if (!u.ok) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4">Could not load users.</div>'; return; }
          const list = u.d.users || [];
          const gbRows = (g.ok && g.d.rows) || [];
          const userCourses = {}; gbRows.forEach((r) => { userCourses[r.user_id] = (userCourses[r.user_id] || 0) + 1; });
          const userPassed = {}; gbRows.forEach((r) => { if (r.score != null && r.score >= 80) userPassed[r.user_id] = (userPassed[r.user_id] || 0) + 1; });
          const badge = (r) => `<span class="pill ${r === 'admin' ? 'bg-saffron-soft text-saffron-deep' : r === 'teacher' ? 'bg-paper text-navy' : 'bg-paper text-muted'}">${esc(r)}</span>`;
          const renderList = (items) => items.map((u2) => {
            const passed2 = userPassed[u2.id] || 0; const enrolled = userCourses[u2.id] || 0;
            return `<tr class="border-t border-line align-middle" data-id="${esc(u2.id)}">
              <td class="py-2"><div class="font-semibold">${esc(u2.name || '—')}</div><div class="font-sans text-xs text-muted">${esc(u2.email)}</div></td>
              <td>${badge(u2.role)}</td>
              <td class="whitespace-nowrap text-muted font-sans text-xs">${fmt(u2.created_at)}</td>
              <td class="font-sans text-xs">${enrolled ? `${passed2}/${enrolled} passed` : '—'}</td>
              <td>${u2.role === 'admin' ? '<span class="text-muted">—</span>' : `<button class="rounded-lg border border-line px-2 py-1 font-sans text-xs ${u2.role === 'learner' ? 'opacity-40' : 'hover:border-saffron'}" data-set="learner" ${u2.role === 'learner' ? 'disabled' : ''}>Learner</button> <button class="rounded-lg border border-line px-2 py-1 font-sans text-xs ${u2.role === 'teacher' ? 'opacity-40' : 'hover:border-saffron'}" data-set="teacher" ${u2.role === 'teacher' ? 'disabled' : ''}>Teacher</button>`}</td>
            </tr>`;
          }).join('');
          const wireRoleButtons = () => panel.querySelectorAll('[data-set]').forEach((b) => b.addEventListener('click', () => { const row = b.closest('[data-id]'); api('/api/admin/users', { method: 'POST', body: JSON.stringify({ id: row.dataset.id, role: b.dataset.set }) }).then(({ ok }) => { if (ok) draw(); }); }));
          panel.innerHTML = `
            <div class="flex flex-wrap items-center gap-3 justify-between">
              <p class="font-sans text-sm text-muted">${list.length} user(s).</p>
              <div class="flex flex-wrap gap-2">
                <input id="user-search" type="search" placeholder="Filter by name or email…" class="rounded-lg border border-line bg-paper px-3 py-1.5 font-sans text-sm w-full sm:w-64" />
                <select id="user-role" class="rounded-lg border border-line bg-paper px-2 py-1.5 font-sans text-sm">
                  <option value="">All roles</option><option value="admin">Admin</option><option value="teacher">Teacher</option><option value="learner">Learner</option>
                </select>
                <select id="user-sort" class="rounded-lg border border-line bg-paper px-2 py-1.5 font-sans text-sm">
                  <option value="joined">Sort: Newest first</option><option value="name">Sort: Name A→Z</option><option value="passed">Sort: Most passed</option>
                </select>
              </div>
            </div>
            <div class="mt-4 overflow-x-auto"><table class="w-full font-sans text-sm" id="users-table">
              <thead><tr class="text-left text-muted"><th class="py-1">Name / Email</th><th>Role</th><th>Joined</th><th>Progress</th><th>Set role</th></tr></thead>
              <tbody id="users-body">${renderList(list)}</tbody>
            </table></div>`;
          wireRoleButtons();
          const rerender = () => {
            const q = (document.getElementById('user-search').value || '').toLowerCase();
            const roleF = document.getElementById('user-role').value;
            const sortF = document.getElementById('user-sort').value;
            let filtered = q ? list.filter((u2) => (u2.email || '').toLowerCase().includes(q) || (u2.name || '').toLowerCase().includes(q)) : [...list];
            if (roleF) filtered = filtered.filter((u2) => u2.role === roleF);
            if (sortF === 'name') filtered.sort((a, b) => (a.name || a.email || '').localeCompare(b.name || b.email || ''));
            else if (sortF === 'passed') filtered.sort((a, b) => (userPassed[b.id] || 0) - (userPassed[a.id] || 0));
            else filtered.sort((a, b) => (b.created_at || '').localeCompare(a.created_at || ''));
            document.getElementById('users-body').innerHTML = renderList(filtered);
            wireRoleButtons();
          };
          ['user-search', 'user-role', 'user-sort'].forEach((id) => { const el = document.getElementById(id); if (el) { el.addEventListener('input', rerender); el.addEventListener('change', rerender); } });
        });
      }

      // ── Overview ───────────────────────────────────────────────────────────
      function overview() {
        Promise.all([api('/api/admin/stats'), api('/api/gradebook')]).then(([s, g]) => {
          if (!s.ok) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4">Could not load stats.</div>'; return; }
          const t = s.d.totals || {};
          const stat = (n, l) => `<div class="rounded-xl2 border border-line border-t-4 border-t-saffron bg-surface p-4 text-center"><div class="text-3xl font-bold text-navy">${n || 0}</div><div class="font-sans text-xs text-muted">${l}</div></div>`;
          let html = `<div class="grid grid-cols-2 gap-3 sm:grid-cols-4">${stat(t.users, 'Total users')}${stat(t.enrollments, 'Enrollments')}${stat(t.completions, 'Completions')}${stat(t.activeSessions, 'Active sessions')}${stat(t.teachers, 'Teachers')}${stat(t.pendingApplications, 'Pending apps')}${stat(t.newFeedback, 'New feedback')}${stat(t.admins, 'Admins')}</div>`;
          html += `<div class="mt-6 rounded-xl2 border border-line bg-surface p-4"><h3 class="text-lg font-bold">Preview dashboards</h3><p class="font-sans text-sm text-muted">See exactly what a student and a teacher see.</p><div class="mt-3 flex flex-wrap gap-2"><a class="btn" href="/dashboard?demo=student">View student dashboard →</a><a class="btn" href="/dashboard?demo=teacher">View teacher dashboard →</a></div></div>`;
          if (g.ok) {
            const rows = g.d.rows || [];
            const byUser = {}; rows.forEach((r) => { if (r.score != null && r.score >= 80) byUser[r.user_id] = (byUser[r.user_id] || 0) + 1; });
            const counts = Object.values(byUser);
            const badgeCounts = { 'Graduate (1+)': counts.filter((n) => n >= 1).length, 'Dedicated (25+)': counts.filter((n) => n >= 25).length, 'Scholar (100+)': counts.filter((n) => n >= 100).length, 'Vidhvaan (250+)': counts.filter((n) => n >= 250).length };
            html += `<h3 class="mt-8 text-xl font-bold">Badge distribution</h3><div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-4">${Object.entries(badgeCounts).map(([name, count]) => stat(count, name)).join('')}</div>`;
          }
          const pop = s.d.popular || [];
          if (pop.length) { const max = pop[0].learners || 1; html += `<h3 class="mt-8 text-xl font-bold">Most popular courses</h3><table class="mt-3 w-full font-sans text-sm"><thead><tr class="text-left text-muted"><th class="py-1">Course</th><th>Learners</th><th>Completions</th><th></th></tr></thead><tbody>${pop.map((p) => `<tr class="border-t border-line"><td class="py-1">${esc(ctitle(p.course_id, courses))}</td><td>${p.learners}</td><td>${p.completions}</td><td class="w-1/3"><div class="h-2 rounded bg-saffron" style="width:${Math.max(6, Math.round((p.learners / max) * 100))}%"></div></td></tr>`).join('')}</tbody></table>`; }
          else html += '<div class="mt-6 rounded-xl bg-surface p-4 text-muted">No enrollments yet.</div>';
          panel.innerHTML = html;
        });
      }

      // ── Courses ────────────────────────────────────────────────────────────
      function coursesTab() {
        const pub = courses.filter((c) => c.status === 'published');
        const topicCounts = {};
        topics.forEach((tp) => { topicCounts[tp.id] = courses.filter((c) => c.topic === tp.id).length; });

        panel.innerHTML = `
          <div class="mb-4 flex flex-wrap items-end gap-3">
            <p class="font-sans text-sm text-muted grow">${courses.length} courses · ${pub.length} published · ${topics.length} topics</p>
            <div class="flex flex-wrap gap-2">
              <input id="c-search" type="search" placeholder="Search courses…" class="rounded-lg border border-line bg-paper px-3 py-1.5 font-sans text-xs w-48" />
              <select id="c-topic" class="rounded-lg border border-line bg-paper px-2 py-1.5 font-sans text-xs">
                <option value="">All topics</option>${topics.map((tp) => `<option value="${esc(tp.id)}">${esc(tp.name)} (${topicCounts[tp.id] || 0})</option>`).join('')}
              </select>
              <select id="c-level" class="rounded-lg border border-line bg-paper px-2 py-1.5 font-sans text-xs">
                <option value="">All levels</option>
                <option value="100">100</option><option value="150">150</option><option value="200">200</option>
                <option value="250">250</option><option value="300">300</option><option value="400">400</option><option value="500">500+</option>
              </select>
              <select id="c-sort" class="rounded-lg border border-line bg-paper px-2 py-1.5 font-sans text-xs">
                <option value="topic">Group: By topic</option>
                <option value="level">Sort: Level ↑</option>
                <option value="name">Sort: Name A→Z</option>
                <option value="prof">Sort: Professor A→Z</option>
              </select>
              <button id="c-expand-all" class="btn font-sans text-xs px-3 py-1.5">Expand all</button>
              <button id="c-collapse-all" class="btn font-sans text-xs px-3 py-1.5">Collapse all</button>
            </div>
          </div>
          <div id="c-body"></div>`;

        function renderCourses() {
          const q = (document.getElementById('c-search').value || '').toLowerCase();
          const topicF = document.getElementById('c-topic').value;
          const levelF = document.getElementById('c-level').value;
          const sortF = document.getElementById('c-sort').value;
          let filtered = courses.filter((c) => {
            if (topicF && c.topic !== topicF) return false;
            if (levelF) { if (levelF === '500') { if (c.level < 500) return false; } else if (String(c.level) !== levelF) return false; }
            if (q && !(c.title || '').toLowerCase().includes(q) && !(c.professor || '').toLowerCase().includes(q) && !(c.id || '').toLowerCase().includes(q)) return false;
            return true;
          });

          const body = document.getElementById('c-body');
          if (!body) return;

          if (sortF === 'topic') {
            body.innerHTML = topics.map((tp) => {
              const list = filtered.filter((c) => c.topic === tp.id).sort((a, b) => a.level - b.level);
              if (!list.length) return '';
              return `<details class="mt-4 rounded-xl2 border border-line bg-surface">
                <summary class="cursor-pointer select-none px-4 py-3 font-bold text-navy">${esc(tp.name)} <span class="font-sans text-xs font-normal text-muted">(${list.length})</span></summary>
                <ul class="divide-y divide-line px-4 pb-3">${list.map((c) => courseRow(c)).join('')}</ul>
              </details>`;
            }).join('');
          } else {
            if (sortF === 'level') filtered.sort((a, b) => a.level - b.level);
            else if (sortF === 'name') filtered.sort((a, b) => (a.title || '').localeCompare(b.title || ''));
            else if (sortF === 'prof') filtered.sort((a, b) => (a.professor || '').localeCompare(b.professor || ''));
            body.innerHTML = filtered.length ? `<ul class="divide-y divide-line rounded-xl2 border border-line bg-surface px-4 pb-3">${filtered.map((c) => courseRow(c)).join('')}</ul>` : '<div class="rounded-xl bg-surface p-4 text-muted">No courses match.</div>';
          }
        }

        function courseRow(c) {
          return `<li class="py-2"><details><summary class="cursor-pointer select-none font-semibold text-navy">${esc(c.title)} <span class="font-sans text-xs font-normal text-muted">· L${c.level} · ${esc(c.professor)} · ${c.status}${c.aiCreated ? ' · AI' : ''}</span></summary>
            <div class="mt-2 rounded-xl border border-line bg-paper p-3"><p class="text-sm">${esc(c.summary)}</p>
            <div class="mt-2 flex flex-wrap gap-2">
              <a class="btn font-sans text-xs px-2 py-1" href="/course/${esc(c.id)}" target="_blank">View course →</a>
            </div>
            <div class="mt-2 font-sans text-xs text-muted">${(c.lessons || []).length} lessons${c.quiz && c.quiz.length ? ' · ' + c.quiz.length + ' quiz questions' : ''}</div>
            </div></details></li>`;
        }

        renderCourses();
        ['c-search', 'c-topic', 'c-level', 'c-sort'].forEach((id) => {
          const el = document.getElementById(id);
          if (el) { el.addEventListener('input', renderCourses); el.addEventListener('change', renderCourses); }
        });
        document.getElementById('c-expand-all').addEventListener('click', () => { document.querySelectorAll('#c-body details').forEach((d) => d.open = true); });
        document.getElementById('c-collapse-all').addEventListener('click', () => { document.querySelectorAll('#c-body details').forEach((d) => d.open = false); });
      }

      // ── Applications ───────────────────────────────────────────────────────
      function applications() {
        api('/api/admin/applications').then(({ ok, d }) => {
          if (!ok) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4">Could not load.</div>'; return; }
          const apps = d.applications || [];
          if (!apps.length) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4 text-muted">No pending applications.</div>'; return; }
          panel.innerHTML = apps.map((a) => `<div class="mb-4 rounded-xl2 border border-line bg-surface p-4" data-id="${a.id}"><h3 class="font-bold">${esc(a.name || a.email)}</h3><div class="font-sans text-xs text-muted">${esc(a.email)} · ${fmt(a.created_at)}</div><p class="mt-2 text-sm"><strong>Background:</strong> ${esc(a.background || '')}</p>${a.courses ? `<p class="text-sm"><strong>Wants to teach:</strong> ${esc(a.courses)}</p>` : ''}<div class="mt-3 flex gap-2"><button class="btn btn-primary" data-d="approve">Approve</button><button class="btn" data-d="deny">Deny</button></div></div>`).join('');
          panel.querySelectorAll('[data-d]').forEach((b) => b.addEventListener('click', () => { const card = b.closest('[data-id]'); api('/api/admin/applications', { method: 'POST', body: JSON.stringify({ id: card.dataset.id, decision: b.dataset.d }) }).then(({ ok }) => { if (ok) card.innerHTML = `<div class="rounded-xl border-l-4 border-ok p-3">Application ${b.dataset.d}d.</div>`; }); }));
        });
      }

      // ── Feedback ───────────────────────────────────────────────────────────
      function feedback() {
        api('/api/admin/feedback').then(({ ok, d }) => {
          if (!ok) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4">Could not load.</div>'; return; }
          const fb = d.feedback || [];
          if (!fb.length) { panel.innerHTML = '<div class="rounded-xl bg-surface p-4 text-muted">No feedback yet.</div>'; return; }
          panel.innerHTML = `<table class="w-full font-sans text-sm"><thead><tr class="text-left text-muted"><th class="py-1">Date</th><th>Type</th><th>From</th><th>Course</th><th>Message</th></tr></thead><tbody>${fb.map((f) => `<tr class="border-t border-line align-top"><td class="py-1 whitespace-nowrap">${fmt(f.created_at)}</td><td>${esc(f.category || '')}</td><td>${esc(f.email || '—')}</td><td>${esc(ctitle(f.course_id, courses))}</td><td>${esc(f.message || '')}</td></tr>`).join('')}</tbody></table>`;
        });
      }

      // ── Bootstrap: load courses, topics, programs then draw ────────────────
      Promise.all([
        fetch('/assets/data/courses.json').then((r) => r.json()),
        fetch('/assets/data/programs.json').then((r) => r.json()).catch(() => ({ programs: [] })),
      ]).then(([data, pd]) => {
        courses = data.courses || [];
        topics = data.topics || [];
        programs = (pd && pd.programs) || [];
        draw();
      }).catch(draw);
    });
  </script>
</Base>
