---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
import { topics, published, paths, TOPIC_ICONS } from '../lib/data';
const SITE = 'https://sikh-university.dosanjhlabs.com';
const ld = {
  '@context': 'https://schema.org', '@type': 'CollegeOrUniversity',
  name: 'Sikh University', url: SITE + '/', description: 'A free, open online university for Sikhi and modern skills.', logo: SITE + '/assets/icon-512.png', image: SITE + '/assets/og-image.png',
  sameAs: ['https://sikharchive.net'],
};
const websiteLd = {
  '@context': 'https://schema.org', '@type': 'WebSite',
  name: 'Sikh University', url: SITE + '/',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: SITE + '/search?q={search_term_string}' },
    'query-input': 'required name=search_term_string',
  },
};
---
<Base title="Sikh University — free, open learning in Sikhi & modern skills">
  <script type="application/ld+json" set:html={JSON.stringify(ld)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} slot="head" />

  <!-- Hero -->
  <header class="relative overflow-hidden bg-gradient-to-br from-brand via-brand-strong to-blue text-white">
    <div class="pointer-events-none absolute -right-24 -top-24 h-80 w-80 rounded-full bg-saffron/30 blur-3xl"></div>
    <div class="pointer-events-none absolute -left-20 bottom-0 h-72 w-72 rounded-full bg-blue-bright/30 blur-3xl"></div>
    <div class="wrap relative grid items-center gap-12 py-20 lg:grid-cols-[minmax(0,1fr)_auto]">
      <div>
        <p class="font-sans text-sm uppercase tracking-[0.2em] text-saffron">Free · Open · Worldwide</p>
        <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-white sm:text-5xl">Dive into the depths of <span class="text-saffron">Sikhi</span>.</h1>
        <p class="mt-5 max-w-2xl text-lg text-white/85">A free, open university anyone, anywhere can attend. Start at the surface and keep going — Sikh history, theology, philosophy, language, music and the arts, taught from authentic sources. The deeper you go, the more there is.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn btn-primary" href="/catalog">Browse courses</a>
          <a class="btn btn-ghost" href="https://sikharchive.net" target="_blank" rel="noopener noreferrer">Visit Sikh Archive →</a>
        </div>
        <div class="mt-12 flex flex-wrap gap-x-12 gap-y-4">
          {[[published.length + '+', 'courses'], [topics.length, 'subjects'], ['100%', 'free'], ['Open', 'to all, worldwide']].map((s) => (
            <div><div class="text-3xl font-bold text-saffron">{s[0]}</div><div class="font-sans text-sm text-white/70">{s[1]}</div></div>
          ))}
        </div>
      </div>
      <div class="hidden justify-self-center lg:block">
        <Logo class="h-72 w-72 text-saffron/90 drop-shadow-[0_8px_40px_rgba(244,178,26,0.35)] xl:h-[22rem] xl:w-[22rem]" />
      </div>
    </div>
  </header>

  <!-- Mission -->
  <section class="bg-gradient-to-b from-blue to-brand text-white">
    <div class="wrap py-16">
      <p class="text-center font-sans text-sm uppercase tracking-[0.2em] text-saffron">Our mission</p>
      <h2 class="mx-auto mt-3 max-w-3xl text-center text-2xl font-bold text-white sm:text-3xl">From the wisdom of our ancestors to a living bond with Waheguru</h2>
      <p class="mx-auto mt-4 max-w-3xl text-center text-lg text-white/90">We learn from those who came before us — the Gurus, the scholars, the saints and the soldiers — and carry their light forward. We begin with the basics of Sikhi and keep going into its depths, until one truth becomes unmistakable: that <strong>Sri Guru Granth Sahib Ji</strong> is the living Guru and the one universal Truth. And the real aim of all of it is simple — to build an intimate, personal relationship with <strong>Waheguru</strong>.</p>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          ['🪔', 'Learn from our ancestors', 'The Gurus, scholars, saints and soldiers whose lives and writings light the way — taught from authentic sources.'],
          ['🌊', 'From the basics to the depths', 'Start with the simplest questions and follow them as far as you dare. The deeper you go, the more there is.'],
          ['📖', 'Sri Guru Granth Sahib Ji', 'The living Guru and the universal Truth. Every path here leads back to the Shabad — read it for yourself in our reader.'],
          ['🪯', 'A relationship with Waheguru', 'Not just knowledge, but Naam, Simran and seva — a living, personal bond with the Divine.'],
        ].map((m) => (
          <div class="rounded-xl2 bg-white/10 p-5 backdrop-blur">
            <div class="text-3xl">{m[0]}</div>
            <h3 class="mt-2 text-lg font-bold text-white">{m[1]}</h3>
            <p class="mt-1 text-[0.95rem] text-white/80">{m[2]}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <a class="btn btn-primary" href="/santhiya?src=sggs">Read Sri Guru Granth Sahib Ji</a>
        <a class="btn btn-ghost" href="/catalog#paths">Start a learning path</a>
        <a class="btn btn-ghost" href="/about">Why we built this</a>
      </div>
    </div>
    <div aria-hidden="true" class="pointer-events-none -mt-px -mb-px h-32 bg-gradient-to-b from-brand to-paper"></div>
  </section>

  <!-- First of its kind -->
  <section class="wrap py-16">
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-sans text-sm uppercase tracking-[0.2em] text-saffron-deep">First of its kind</p>
      <h2 class="mt-3 text-3xl font-bold sm:text-4xl">Nothing like this has ever existed<br class="hidden sm:block" /> for Sikhi.</h2>
      <p class="mt-4 text-lg text-muted">For generations, serious study of Sikhi required access to rare books, a living scholar, or years of searching. Sikh University changes that — permanently. Every course, every seminar, every lesson is here, free, for anyone on Earth.</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {[
        {
          icon: '📐',
          title: 'A complete academic ladder',
          body: '100-level introductions to 500-level graduate seminars — the only Sikh learning platform with a full university-style curriculum, from your first question to doctoral depth.',
        },
        {
          icon: '🏛️',
          title: 'Scholar-attributed courses',
          body: 'Every course is taught by a named scholar — Prof. Sahib Singh, Kavi Santokh Singh, Dr. Kamalroop Singh, Bhai Vir Singh and more — grounding each lesson in authentic, authoritative scholarship.',
        },
        {
          icon: '🌍',
          title: 'Open to the whole world',
          body: 'No fees. No visa. No Gurdwara nearby required. A Sikh in Kenya, Canada, Chile, or Australia gets the same world-class education as one sitting in Amritsar.',
        },
        {
          icon: '📚',
          title: `${published.length}+ courses across 23 subjects`,
          body: 'Theology, philosophy, history, language, music, the arts, economics, science, health, parenting — Sikhi touches every dimension of life, and we cover all of it.',
        },
        {
          icon: '🔬',
          title: 'Graduate seminars that go all the way',
          body: 'Sikh hermeneutics. Manuscript paleography. Gurmat metaphysics. Comparative mysticism. For students who refuse to stop at the surface — we go as deep as there is to go.',
        },
        {
          icon: '🪯',
          title: 'Rooted in authentic sources',
          body: 'Every course draws from the Sri Guru Granth Sahib Ji, authenticated scholarly works, and the SikhLibrary dataset — not Wikipedia summaries or secondhand summaries.',
        },
      ].map((f) => (
        <div class="rounded-xl2 border border-line bg-surface p-6 shadow-card">
          <div class="text-3xl">{f.icon}</div>
          <h3 class="mt-3 text-lg font-bold text-navy">{f.title}</h3>
          <p class="mt-2 text-[0.95rem] text-muted leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Built for current and future generations -->
  <section class="bg-gradient-to-br from-navy-strong to-brand text-white">
    <div class="wrap py-16">
      <div class="mx-auto max-w-4xl">
        <div class="grid gap-10 lg:grid-cols-2 items-center">
          <div>
            <p class="font-sans text-sm uppercase tracking-[0.2em] text-saffron">For every generation</p>
            <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">Built for Sikhs of today<br />and tomorrow.</h2>
            <p class="mt-4 text-lg text-white/85 leading-relaxed">The Sikh diaspora spans every continent. Our children grow up in Toronto, London, Nairobi, Sydney, and São Paulo. They have questions that deserve real answers — not surface-level summaries, but deep, honest, scholarly engagement with Sikhi.</p>
            <p class="mt-4 text-white/80 leading-relaxed">Sikh University was built so that the next generation never has to choose between their heritage and their intellectual rigour. They can have both. They deserve both.</p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a class="btn btn-primary" href="/catalog">Start learning free</a>
              <a class="btn border-white/30 text-white hover:border-white" href="/about">Our story →</a>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            {[
              ['🌱', '100-level', 'Complete beginners — no background needed'],
              ['📖', '200–300 level', 'Growing students ready to go deeper'],
              ['🔬', '400-level', 'Advanced learners in serious study'],
              ['🎓', '500-level', 'Graduate seminars for scholars'],
            ].map((t) => (
              <div class="rounded-xl2 bg-white/10 p-4 backdrop-blur">
                <div class="text-2xl">{t[0]}</div>
                <div class="mt-2 font-bold text-white text-sm">{t[1]}</div>
                <div class="mt-1 text-xs text-white/70">{t[2]}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proof points / differentiators -->
  <section class="border-y border-line bg-surface">
    <div class="wrap py-12">
      <div class="grid gap-6 text-center sm:grid-cols-2 lg:grid-cols-4">
        {[
          [published.length + '+', 'Courses published'],
          ['23', 'Academic subjects'],
          ['100–500', 'Course levels'],
          ['100%', 'Free, forever'],
        ].map((s) => (
          <div class="rounded-xl2 border border-line bg-paper p-6">
            <div class="text-4xl font-bold text-navy">{s[0]}</div>
            <div class="mt-1 font-sans text-sm text-muted">{s[1]}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Call to action -->
  <section class="wrap py-16 text-center">
    <h2 class="text-3xl font-bold sm:text-4xl">Start your journey today.</h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-muted">It takes thirty seconds to begin. No sign-up required. Pick a course, start a lesson — and see how deep Sikhi really goes.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a class="btn btn-primary" href="/catalog">Browse all courses</a>
      <a class="btn" href="/catalog#paths">Follow a learning path</a>
      <a class="btn" href="/santhiya?src=sggs">Read the Guru Granth Sahib Ji</a>
    </div>
  </section>

</Base>
