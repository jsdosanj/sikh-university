---
import Base from '../layouts/Base.astro';
import CourseCard from '../components/CourseCard.astro';
import { topics, published, paths, TOPIC_ICONS } from '../lib/data';
const featured = published.slice(0, 6);
const SITE = 'https://sikh-university.jasvant-dosanjh.workers.dev';
const ld = {
  '@context': 'https://schema.org', '@type': 'EducationalOrganization',
  name: 'Sikh University', url: SITE + '/', description: 'A free, open online university for Sikhi and modern skills.', logo: SITE + '/assets/icon.svg',
};
---
<Base title="Sikh University — free, open learning in Sikhi & modern skills">
  <script type="application/ld+json" set:html={JSON.stringify(ld)} slot="head" />

  <header class="relative overflow-hidden bg-gradient-to-br from-navy to-navy-strong text-white">
    <div class="pointer-events-none absolute -right-24 -top-24 h-80 w-80 rounded-full bg-saffron/25 blur-3xl"></div>
    <div class="wrap relative py-20">
      <p class="font-sans text-sm uppercase tracking-[0.2em] text-saffron">Free · Open · Worldwide</p>
      <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-white sm:text-5xl">Learn <span class="text-saffron">Sikhi</span> — and the skills of today.</h1>
      <p class="mt-5 max-w-2xl text-lg text-white/85">A free, open university anyone, anywhere can attend. Study Sikh history, theology, philosophy, language, music and the arts — taught from authentic sources — alongside modern skills like AI.</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/catalog.html">Browse courses</a>
        <a class="btn btn-ghost" href="/paths.html">Follow a learning path</a>
      </div>
      <div class="mt-12 flex flex-wrap gap-x-12 gap-y-4">
        {[[published.length + '+', 'courses'], [topics.length, 'subjects'], ['100%', 'free'], ['Open', 'to all, worldwide']].map((s) => (
          <div><div class="text-3xl font-bold text-saffron">{s[0]}</div><div class="font-sans text-sm text-white/70">{s[1]}</div></div>
        ))}
      </div>
    </div>
  </header>

  <section class="wrap py-14">
    <h2 class="text-2xl font-bold">Browse by topic</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {topics.map((t) => (
        <a href={`/catalog.html#${t.id}`} class="card border-t-4 border-t-saffron">
          <div class="text-3xl">{TOPIC_ICONS[t.id] || '📘'}</div>
          <h3 class="mt-1 text-lg font-bold">{t.name}</h3>
          <p class="mt-1 text-[0.95rem] text-muted">{t.blurb}</p>
        </a>
      ))}
    </div>
  </section>

  {paths.length > 0 && (
    <section class="bg-surface border-y border-line">
      <div class="wrap py-14">
        <h2 class="text-2xl font-bold">Guided learning paths</h2>
        <p class="mt-1 text-muted">Not sure where to start? Follow a path from the basics to deeper study.</p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {paths.slice(0, 6).map((p) => (
            <a href="/paths.html" class="card border-l-4 border-l-saffron">
              <span class="pill bg-paper text-muted">{p.courseIds.length} courses</span>
              <h3 class="mt-2 text-lg font-bold">{p.name}</h3>
              <p class="mt-1 text-[0.95rem] text-muted">{p.blurb}</p>
              <div class="mt-3 font-sans text-sm font-bold text-saffron-deep">Start path →</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="wrap py-14">
    <div class="flex items-end justify-between">
      <h2 class="text-2xl font-bold">Featured courses</h2>
      <a href="/catalog.html" class="font-sans text-sm font-semibold text-saffron-deep">All {published.length} courses →</a>
    </div>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((c) => <CourseCard course={c} />)}
    </div>
  </section>

  <section class="bg-navy text-white">
    <div class="wrap py-14 text-center">
      <h2 class="text-2xl font-bold text-white">A space to dig deeper into Sikhi</h2>
      <p class="mx-auto mt-3 max-w-2xl text-white/85">Sikh University was built so anyone can study Sikhi seriously — from authentic sources, at their own pace, for free. Learn alongside the Sikh Archive.</p>
      <div class="mt-6 flex justify-center gap-3"><a class="btn btn-primary" href="/about.html">Why we built this</a></div>
    </div>
  </section>
</Base>
