---
import Base from '../../layouts/Base.astro';
import Avatar from '../../components/Avatar.astro';
import { published, courses, topicName, profSlug, profBio } from '../../lib/data';
export function getStaticPaths() { return published.map((c) => ({ params: { id: c.id }, props: { c } })); }
const { c } = Astro.props;
const profCourseCount = courses.filter((x) => x.professor === c.professor && x.status === 'published').length;
const bio = profBio(c.professor);
const bioShort = bio ? (bio.split('. ').slice(0, 2).join('. ').replace(/\.?$/, '.')) : '';
const SITE = 'https://sikh-university.dosanjhlabs.com';
const archive = c.topic === 'modern-skills'
  ? { url: 'https://sikharchive.net/courses', label: 'Free AI courses on Sikh Archive' }
  : { url: 'https://sikharchive.net', label: 'Dig deeper in the Sikh Archive' };
const lessons = c.lessons || [];
const quiz = c.quiz || [];
const ld = {
  '@context': 'https://schema.org', '@type': 'Course', name: c.title, description: c.summary,
  url: `${SITE}/course/${c.id}`,
  inLanguage: 'en', isAccessibleForFree: true, educationalLevel: c.level,
  provider: { '@type': 'EducationalOrganization', name: 'Sikh University', sameAs: SITE + '/' },
  author: { '@type': 'Person', name: c.professor },
  offers: { '@type': 'Offer', price: 0, priceCurrency: 'USD', category: 'Free', availability: 'https://schema.org/InStock' },
  hasCourseInstance: {
    '@type': 'CourseInstance', courseMode: 'online',
    courseWorkload: `PT${Math.max(1, lessons.length) * 15}M`,
    instructor: { '@type': 'Person', name: c.professor },
  },
};
const breadcrumb = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Sikh University', item: SITE + '/' },
    { '@type': 'ListItem', position: 2, name: 'Catalogue', item: SITE + '/catalog' },
    { '@type': 'ListItem', position: 3, name: topicName(c.topic), item: `${SITE}/catalog#${c.topic}` },
    { '@type': 'ListItem', position: 4, name: c.title, item: `${SITE}/course/${c.id}` },
  ],
};
---
<Base title={`${c.title} — Sikh University`} description={c.summary} ogType="article">
  <script type="application/ld+json" set:html={JSON.stringify(ld)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} slot="head" />

  <header class="relative overflow-hidden bg-gradient-to-br from-brand to-navy-strong text-white">
    <div class="wrap py-12">
      <div class="flex flex-wrap items-center gap-2 font-sans text-xs">
        <a href="/catalog" class="text-white/70 hover:text-white">← Catalogue</a>
        <span class="pill bg-white/15 text-white">{topicName(c.topic)}</span>
        <span class="pill bg-white/15 text-white">{c.level} level</span>
        {c.aiCreated && <span class="pill bg-saffron text-[#2a1c06]">Created by AI</span>}
      </div>
      <h1 class="mt-3 max-w-3xl text-3xl font-bold text-white sm:text-4xl">{c.title}</h1>
      <p class="mt-2 font-sans text-sm text-white/75">Professor: <a class="font-semibold text-saffron underline hover:text-white" href={`/professor/${profSlug(c.professor)}`}>{c.professor}</a> · Source: {c.source || 'Sikh University'}</p>
      <p class="mt-4 max-w-2xl text-lg text-white/90">{c.summary}</p>
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <a href="#lesson-0" class="btn btn-primary">Begin course</a>
        <span class="font-sans text-sm text-white/70">{lessons.length} lessons · {quiz.length}-question test · 80% to pass</span>
      </div>
    </div>
    <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-b from-transparent to-paper"></div>
  </header>

  <div class="wrap grid gap-10 py-12 lg:grid-cols-[1fr_280px]">
    <div>
      {c.aiCreated && (
        <div class="mb-6 rounded-xl2 border border-line bg-saffron-soft/50 p-4 font-sans text-sm">
          <strong>Created by AI.</strong> Drafted with AI and reviewed for accuracy. Spotted an error? <a class="underline" href="/feedback">Tell us</a>.
        </div>
      )}

      {c.outcomes && c.outcomes.length > 0 && (
        <section class="mb-8">
          <h2 class="border-b-2 border-saffron-soft pb-1 text-xl font-bold">What you'll learn</h2>
          <ul class="mt-3 grid gap-2 sm:grid-cols-2">
            {c.outcomes.map((o) => <li class="relative pl-6 before:absolute before:left-0 before:text-ok before:content-['✓']" set:html={o} />)}
          </ul>
        </section>
      )}

      {c.terms && c.terms.length > 0 && (
        <section class="mb-8">
          <h2 class="border-b-2 border-saffron-soft pb-1 text-xl font-bold">Key terms — ਸ਼ਬਦਾਵਲੀ</h2>
          <table class="mt-3 w-full border-collapse text-[0.95rem]">
            <thead><tr><th class="border border-line bg-brand p-2 text-left font-sans text-xs text-white">Term</th><th class="border border-line bg-brand p-2 text-left font-sans text-xs text-white">Academic context</th></tr></thead>
            <tbody>{c.terms.map((t) => <tr class="even:bg-paper"><td class="border border-line p-2 align-top"><span class="font-semibold" set:html={t.t} /></td><td class="border border-line p-2 align-top">{t.m}</td></tr>)}</tbody>
          </table>
        </section>
      )}

      {c.terms && c.terms.length > 0 && (
        <section id="flashcards" class="mb-8">
          <h2 class="border-b-2 border-saffron-soft pb-1 text-xl font-bold">Flashcards — ਕਾਰਡ ਅਭਿਆਸ</h2>
          <p class="mt-1 font-sans text-sm text-muted">Click a card to flip it and reveal the definition.</p>
          <div class="mt-4 relative">
            <!-- Card display -->
            <div id="fc-card" class="cursor-pointer select-none rounded-xl2 border border-line bg-surface shadow-card min-h-[160px] flex flex-col items-center justify-center p-8 text-center transition-all hover:border-saffron" role="button" aria-label="Flip card" tabindex="0">
              <div id="fc-front" class="text-lg font-bold text-navy"></div>
              <div id="fc-back" class="hidden mt-3 text-[0.95rem] text-muted leading-relaxed"></div>
              <div id="fc-hint" class="mt-4 font-sans text-xs text-muted/60">Click to reveal</div>
            </div>
            <!-- Navigation -->
            <div class="mt-4 flex items-center justify-between gap-3">
              <button id="fc-prev" class="btn font-sans text-sm px-4 py-1.5">← Prev</button>
              <div class="flex items-center gap-3">
                <span id="fc-counter" class="font-sans text-sm text-muted"></span>
                <button id="fc-known" class="btn btn-primary font-sans text-sm px-4 py-1.5">Mark learned ✓</button>
              </div>
              <button id="fc-next" class="btn font-sans text-sm px-4 py-1.5">Next →</button>
            </div>
            <div class="mt-3 flex items-center justify-between">
              <div id="fc-progress" class="font-sans text-xs text-muted"></div>
              <button id="fc-reset" class="font-sans text-xs text-muted hover:text-saffron-deep underline">Reset progress</button>
            </div>
          </div>
        </section>
      )}

      <div id="course-ann" class="mb-8 empty:mb-0"></div>

      <section class="mb-8">
        <h2 class="border-b-2 border-saffron-soft pb-1 text-xl font-bold">Lessons</h2>
        <div class="mt-4 space-y-4">
          {lessons.map((ls, i) => (
            <article id={`lesson-${i}`} class="rounded-xl2 border border-line bg-surface p-5 shadow-card">
              <h3 class="text-lg font-bold text-navy">{i + 1}. {ls.title}</h3>
              <div class="lesson-prose mt-3 leading-relaxed" set:html={ls.html} />
              <div class="mt-4 border-t border-dashed border-line pt-3">
                <label class="font-sans text-xs text-muted">📝 Your notes — saved on this device</label>
                <textarea data-note={i} aria-label={`Your notes for lesson ${i + 1}`} rows="3" class="mt-1 w-full rounded-lg border border-line bg-paper p-2 text-[0.95rem]" placeholder="Write your notes…"></textarea>
                <button data-done={i} class="mt-2 rounded-lg border border-line px-3 py-1.5 font-sans text-sm hover:border-saffron">Mark complete</button>
              </div>
            </article>
          ))}
        </div>
      </section>

      {quiz.length > 0 && (
        <section id="test" class="mb-8 rounded-xl2 border border-line bg-surface p-6 shadow-card">
          <h2 class="text-xl font-bold">Course test</h2>
          <p class="font-sans text-sm text-muted">Pass with 80% or higher to complete the course and unlock the next one.</p>
          <form id="quiz" class="mt-4 space-y-5">
            {quiz.map((qq, i) => (
              <fieldset><legend class="font-semibold">{i + 1}. {qq.q}</legend>
                {qq.options.map((o, oi) => (
                  <label class="mt-1 block cursor-pointer"><input type="radio" name={`q${i}`} value={oi} class="mr-2" />{o}</label>
                ))}
              </fieldset>
            ))}
          </form>
          <button id="quiz-submit" class="btn btn-primary mt-4">Submit test</button>
          <div id="quiz-result" class="mt-4"></div>
        </section>
      )}

      {c.references && c.references.length > 0 && (
        <section class="mb-8">
          <h2 class="border-b-2 border-saffron-soft pb-1 text-xl font-bold">References &amp; further reading</h2>
          <ol class="mt-3 list-decimal space-y-2 pl-5 font-sans text-sm text-muted">{c.references.map((r) => <li>{r}</li>)}</ol>
        </section>
      )}

      {c.sourceText && (
        <section class="mb-8">
          <h2 class="border-b-2 border-saffron-soft pb-1 text-xl font-bold">From the source text</h2>
          <figure class="mt-3 rounded-xl2 border border-line bg-paper p-5">
            {c.sourceText.gurmukhi && (
              <blockquote lang="pa" class="border-l-4 border-saffron pl-4 text-lg leading-loose text-navy">{c.sourceText.gurmukhi}</blockquote>
            )}
            {c.sourceText.english && (
              <blockquote class={`pl-4 text-[0.97rem] italic leading-relaxed text-muted ${c.sourceText.gurmukhi ? 'mt-3 border-l-4 border-line' : 'border-l-4 border-saffron text-navy'}`}>{c.sourceText.english}</blockquote>
            )}
            <figcaption class="mt-3 font-sans text-xs text-muted">
              — from <strong>{c.sourceText.work}</strong>.
              {c.sourceText.gurmukhi && c.sourceText.english
                ? " Gurmukhi is the author's original text (OCR); the English is a machine translation. Both are short study excerpts — refer to the original for an authoritative reading."
                : c.sourceText.gurmukhi
                  ? " This is the author's original Gurmukhi text (OCR), shown as a study excerpt — OCR may contain errors."
                  : ' Shown as a short study excerpt — refer to the original for an authoritative reading.'}
              {c.sourceText.sikhArchiveUrl
                ? <a class="ml-1 font-semibold text-navy underline" href={c.sourceText.sikhArchiveUrl} target="_blank" rel="noopener">Read the full work on Sikh Archive ↗</a>
                : <a class="ml-1 font-semibold text-navy underline" href={c.sourceText.url} target="_blank" rel="noopener">Read the full work on SikhLibrary ↗</a>}
              {c.sourceText.sikhArchiveUrl && (
                <a class="ml-1 text-muted underline" href={c.sourceText.url} target="_blank" rel="noopener">(or on SikhLibrary ↗)</a>
              )}
            </figcaption>
          </figure>
        </section>
      )}

      <section class="rounded-xl2 border border-line bg-gradient-to-br from-saffron-soft to-surface p-6">
        <h2 class="text-xl font-bold">Read the source texts</h2>
        <p class="mt-1">Read the primary sources for yourself — the Gurbani in our read-along reader, and the original works in the source library.</p>
        <div class="mt-3 flex flex-wrap gap-3">
          <a class="btn" href="/santhiya?src=sggs">📖 Read Gurbani (reader)</a>
          {c.sourceText?.sikhArchiveUrl && (
            <a class="btn" href={c.sourceText.sikhArchiveUrl} target="_blank" rel="noopener">📚 Read this work on Sikh Archive ↗</a>
          )}
          {c.sourceText && c.sourceText.url && (
            <a class="btn" href={c.sourceText.url} target="_blank" rel="noopener">This work on SikhLibrary ↗</a>
          )}
          {(c.sourceText || (c.source && c.source.indexOf('SikhLibrary') !== -1)) && (
            <a class="btn" href="https://huggingface.co/datasets/jsdosanj/SikhLibrary" target="_blank" rel="noopener">SikhLibrary dataset ↗</a>
          )}
          <a class="btn" href={archive.url} target="_blank" rel="noopener">{archive.label} →</a>
        </div>
      </section>
    </div>

    <aside class="lg:sticky lg:top-20 lg:self-start">
      <div class="mb-4 rounded-xl2 border border-line bg-surface p-5 shadow-card">
        <div class="font-sans text-xs uppercase tracking-wide text-muted">Your professor</div>
        <div class="mt-3 flex items-center gap-3">
          <a href={`/professor/${profSlug(c.professor)}`} class="shrink-0"><Avatar name={c.professor} size={56} /></a>
          <div class="min-w-0">
            <a href={`/professor/${profSlug(c.professor)}`} class="block font-bold text-navy hover:text-saffron-deep">{c.professor}</a>
            <div class="font-sans text-xs text-muted">{profCourseCount} course{profCourseCount === 1 ? '' : 's'} at Sikh University</div>
          </div>
        </div>
        {bioShort && <p class="mt-3 text-[0.9rem] leading-relaxed text-muted">{bioShort}</p>}
        <a href={`/professor/${profSlug(c.professor)}`} class="mt-3 inline-block font-sans text-sm font-semibold text-saffron-deep hover:underline">View profile →</a>
      </div>
      <div class="rounded-xl2 border border-line bg-surface p-5 shadow-card">
        <div class="font-sans text-xs uppercase tracking-wide text-muted">Your progress</div>
        <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-paper"><div id="prog-bar" class="h-full bg-saffron" style="width:0%"></div></div>
        <div id="prog-text" class="mt-1 font-sans text-xs text-muted">0% complete</div>
        <ol class="mt-4 space-y-1 font-sans text-sm">
          {lessons.map((ls, i) => <li><a href={`#lesson-${i}`} class="text-navy hover:text-saffron-deep">{i + 1}. {ls.title}</a></li>)}
        </ol>
      </div>
    </aside>
  </div>

  <section class="wrap pb-14">
    <div class="grid gap-10 lg:grid-cols-2">
      <div>
        <h2 class="text-xl font-bold">Rate this course</h2>
        <div id="rate-summary" class="mt-1 font-sans text-sm text-muted">…</div>
        <div id="rate-stars" role="group" aria-label="Rate this course from 1 to 5 stars" class="mt-2 flex gap-1 text-3xl text-saffron">
          <button type="button" data-s="1" aria-label="1 star">☆</button><button type="button" data-s="2" aria-label="2 stars">☆</button><button type="button" data-s="3" aria-label="3 stars">☆</button><button type="button" data-s="4" aria-label="4 stars">☆</button><button type="button" data-s="5" aria-label="5 stars">☆</button>
        </div>
        <textarea id="rate-review" rows="2" aria-label="Optional written review" placeholder="Optional review…" class="mt-2 w-full rounded-lg border border-line p-2 font-sans text-sm"></textarea>
        <button id="rate-submit" class="btn btn-primary mt-2">Submit rating</button>
        <div id="rate-msg" class="mt-2 font-sans text-sm"></div>
      </div>
      <div>
        <h2 class="text-xl font-bold">Discussion &amp; Q&amp;A</h2>
        <div id="disc-list" class="mt-3 space-y-2"></div>
        <textarea id="disc-msg" rows="2" aria-label="Your question or comment" placeholder="Ask a question or share a thought…" class="mt-3 w-full rounded-lg border border-line p-2 font-sans text-sm"></textarea>
        <button id="disc-submit" class="btn mt-2">Post</button>
        <div id="disc-note" class="mt-1 font-sans text-xs text-muted">Sign in to post.</div>
      </div>
    </div>
  </section>

  <script type="application/json" id="course-data" set:html={JSON.stringify({ id: c.id, nLessons: lessons.length, nQuiz: quiz.length, terms: (c.terms || []).map((t) => ({ t: t.t, m: t.m })) })}></script>
  <script>
    const __d = JSON.parse(document.getElementById('course-data').textContent);
    const id = __d.id, nLessons = __d.nLessons, nQuiz = __d.nQuiz;
    const P = 'su_v1_';
    const get = (k, d) => { try { const v = localStorage.getItem(P + k); return v == null ? d : JSON.parse(v); } catch { return d; } };
    const set = (k, v) => { try { localStorage.setItem(P + k, JSON.stringify(v)); } catch {} };
    const doneKey = 'done_' + id, scoreKey = 'score_' + id; let done = get(doneKey, {});
    // Write progress + grade to the server (the source of truth); localStorage is a cache.
    function push() {
      return fetch('/api/progress', { method: 'POST', credentials: 'same-origin', headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ courseId: id, done: Object.keys(done).filter((k) => done[k]).map(Number) }) }).catch(() => {});
    }
    // Cross-device pull: the server's record wins, so grades survive a cleared device.
    fetch('/api/progress', { credentials: 'same-origin' }).then((r) => (r.ok ? r.json() : null)).then((d) => {
      if (!d || !d.progress) return;
      const row = d.progress.filter((p) => p.course_id === id)[0]; if (!row) return;
      try { JSON.parse(row.done || '[]').forEach((i) => { done[i] = true; }); set(doneKey, done); } catch {}
      if (row.passed_score != null) { set(scoreKey, row.passed_score); if (row.passed_score >= 80) set('passed_' + id, row.passed_score); }
      refresh();
    }).catch(() => {});
    // Announcements posted by this course's teacher(s).
    fetch('/api/announcements?course=' + encodeURIComponent(id), { credentials: 'same-origin' }).then((r) => (r.ok ? r.json() : null)).then((d) => {
      const list = (d && d.announcements) || []; const el = document.getElementById('course-ann'); if (!el || !list.length) return;
      const esc = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
      el.innerHTML = `<h2 class="border-b-2 border-saffron-soft pb-1 text-xl font-bold">Announcements</h2><div class="mt-3 space-y-3">${list.slice(0, 5).map((a) => `<div class="rounded-xl2 border-l-4 border-saffron bg-surface p-4"><div class="font-sans text-xs text-muted">${esc(a.author_name || '')}</div>${a.title ? `<div class="mt-1 font-bold text-navy">${esc(a.title)}</div>` : ''}<p class="mt-1 text-[0.97rem]">${esc(a.body)}</p></div>`).join('')}</div>`;
    }).catch(() => {});
    function recordActivity() { const a = get('activity', []); const d = new Date(); const t = d.getFullYear() + '-' + (d.getMonth() + 1) + '-' + d.getDate(); if (a[a.length - 1] !== t) { a.push(t); set('activity', a); } }
    function refresh() {
      let n = 0; for (let i = 0; i < nLessons; i++) if (done[i]) n++;
      const pct = nLessons ? Math.round((n / nLessons) * 100) : 0;
      document.getElementById('prog-bar').style.width = pct + '%';
      document.getElementById('prog-text').textContent = pct + '% complete';
      document.querySelectorAll('[data-done]').forEach((b) => { const i = b.dataset.done; b.textContent = done[i] ? '✓ Completed' : 'Mark complete'; b.classList.toggle('border-saffron', !!done[i]); });
    }
    document.querySelectorAll('[data-note]').forEach((t) => { const k = 'note_' + id + '_' + t.dataset.note; t.value = get(k, ''); t.addEventListener('input', () => set(k, t.value)); });
    document.querySelectorAll('[data-done]').forEach((b) => b.addEventListener('click', () => { const i = b.dataset.done; done[i] = !done[i]; if (!done[i]) delete done[i]; else recordActivity(); set(doneKey, done); refresh(); push(); }));
    const submit = document.getElementById('quiz-submit');
    if (submit) submit.addEventListener('click', async () => {
      // Collect the chosen option index per question; the SERVER grades it.
      const answers = [];
      for (let i = 0; i < nQuiz; i++) { const s = document.querySelector(`input[name="q${i}"]:checked`); answers.push(s ? +s.value : -1); }
      const r = document.getElementById('quiz-result');
      submit.disabled = true; submit.textContent = 'Submitting…';
      let res;
      try { res = await fetch('/api/quiz', { method: 'POST', credentials: 'same-origin', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ courseId: id, answers }) }).then((x) => x.json()); } catch (e) { res = null; }
      submit.disabled = false; submit.textContent = 'Submit test';
      if (!res || typeof res.score !== 'number') { r.innerHTML = '<div class="rounded-xl border-l-4 border-saffron bg-surface p-3 font-sans text-sm">Could not submit your test — please try again.</div>'; return; }
      const score = res.score, correct = res.correct, total = res.total;
      set(scoreKey, Math.max(score, get(scoreKey, 0)));
      if (res.passed) set('passed_' + id, score);
      recordActivity();
      if (res.passed) {
        const cert = res.signedIn ? ` <a class="underline" href="/cert?course=${id}">View your certificate →</a>` : ' <a class="underline" href="/login">Sign in</a> to save this and earn a certificate.';
        r.innerHTML = `<div class="rounded-xl border-l-4 border-ok bg-surface p-3 font-sans text-sm"><strong>Passed — ${score}% (${correct}/${total}).</strong> Course complete.${cert}</div>`;
      } else r.innerHTML = `<div class="rounded-xl border-l-4 border-saffron bg-surface p-3 font-sans text-sm"><strong>Not yet — ${score}% (${correct}/${total}).</strong> You need 80%. Review the lessons and try again.</div>`;
      r.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
    refresh();

    // --- Flashcards ---
    (function () {
      const __fc = JSON.parse(document.getElementById('course-data').textContent);
      const terms = __fc.terms || [];
      if (!terms.length) return;
      const fcKey = P + 'fc_known_' + id;
      let idx = 0, flipped = false;
      let known = get(fcKey, {});
      const card = document.getElementById('fc-card');
      const front = document.getElementById('fc-front');
      const back = document.getElementById('fc-back');
      const hint = document.getElementById('fc-hint');
      const counter = document.getElementById('fc-counter');
      const progress = document.getElementById('fc-progress');
      if (!card) return;
      function stripHtml(s) { const d = document.createElement('div'); d.innerHTML = s; return d.textContent || d.innerText || s; }
      function renderCard() {
        flipped = false;
        const t = terms[idx];
        front.innerHTML = t.t;
        back.textContent = t.m;
        back.classList.add('hidden');
        hint.textContent = known[idx] ? '✓ Learned — click to review' : 'Click to reveal';
        hint.className = known[idx] ? 'mt-4 font-sans text-xs text-ok' : 'mt-4 font-sans text-xs text-muted/60';
        card.classList.toggle('border-ok', !!known[idx]);
        card.classList.toggle('bg-ok/5', !!known[idx]);
        counter.textContent = `${idx + 1} / ${terms.length}`;
        progress.textContent = `${Object.keys(known).length} / ${terms.length} learned`;
      }
      function flip() {
        flipped = !flipped;
        back.classList.toggle('hidden', !flipped);
        hint.textContent = flipped ? '' : (known[idx] ? '✓ Learned' : 'Click to reveal');
      }
      card.addEventListener('click', flip);
      card.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); flip(); } });
      document.getElementById('fc-prev')?.addEventListener('click', () => { idx = (idx - 1 + terms.length) % terms.length; renderCard(); });
      document.getElementById('fc-next')?.addEventListener('click', () => { idx = (idx + 1) % terms.length; renderCard(); });
      document.getElementById('fc-known')?.addEventListener('click', () => {
        if (known[idx]) { delete known[idx]; } else { known[idx] = true; }
        set(fcKey, known); renderCard();
      });
      document.getElementById('fc-reset')?.addEventListener('click', () => { known = {}; set(fcKey, known); idx = 0; renderCard(); });
      renderCard();
    })();
  </script>

  <script>
    (function () {
      var id = JSON.parse(document.getElementById('course-data').textContent).id;
      var esc = function (s) { return String(s == null ? '' : s).replace(/[&<>"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); };
      var api = function (p, o) { return fetch(p, Object.assign({ credentials: 'same-origin', headers: { 'content-type': 'application/json' } }, o || {})).then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }).catch(function () { return { ok: r.ok, d: {} }; }); }); };
      // Ratings
      var stars = 0;
      function paint(n) { document.querySelectorAll('#rate-stars button').forEach(function (x, i) { x.textContent = i < n ? '★' : '☆'; }); }
      document.querySelectorAll('#rate-stars button').forEach(function (b) { b.onclick = function () { stars = +b.dataset.s; paint(stars); }; });
      function loadRating() { api('/api/ratings?courseId=' + encodeURIComponent(id)).then(function (r) { if (r.ok) document.getElementById('rate-summary').textContent = r.d.count ? ('★ ' + r.d.avg + ' · ' + r.d.count + ' rating' + (r.d.count == 1 ? '' : 's')) : 'No ratings yet — be the first.'; }); }
      loadRating();
      document.getElementById('rate-submit').onclick = function () {
        if (!stars) { document.getElementById('rate-msg').textContent = 'Pick a star rating.'; return; }
        api('/api/ratings', { method: 'POST', body: JSON.stringify({ courseId: id, stars: stars, review: document.getElementById('rate-review').value }) }).then(function (r) {
          document.getElementById('rate-msg').innerHTML = r.ok ? '<span class="text-ok">Thank you for rating.</span>' : esc((r.d && r.d.error) || 'Please sign in to rate.');
          if (r.ok) loadRating();
        });
      };
      // Discussion
      function loadDisc() {
        api('/api/discussions?courseId=' + encodeURIComponent(id)).then(function (r) {
          var m = (r.d && r.d.messages) || [];
          document.getElementById('disc-list').innerHTML = m.length ? m.map(function (x) { return '<div class="rounded-lg border border-line bg-surface p-3"><div class="font-sans text-xs text-muted">' + esc(x.name || 'Learner') + '</div><div class="mt-0.5 text-sm">' + esc(x.message) + '</div></div>'; }).join('') : '<p class="text-sm text-muted">No messages yet — start the conversation.</p>';
        });
      }
      loadDisc();
      document.getElementById('disc-submit').onclick = function () {
        var msg = document.getElementById('disc-msg').value.trim(); if (!msg) return;
        api('/api/discussions', { method: 'POST', body: JSON.stringify({ courseId: id, message: msg }) }).then(function (r) {
          if (r.ok) { document.getElementById('disc-msg').value = ''; document.getElementById('disc-note').textContent = ''; loadDisc(); }
          else document.getElementById('disc-note').textContent = (r.d && r.d.error) || 'Please sign in to post.';
        });
      };
    })();
  </script>
</Base>
