---
import Base from '../layouts/Base.astro';
import { paths, courses } from '../lib/data';
const byId = Object.fromEntries(courses.map((c) => [c.id, c]));
---
<Base title="Learning paths — Sikh University" description="Guided, ordered learning paths through Sikh University courses — from foundations to advanced study.">
  <section class="wrap py-12">
    <h1 class="text-3xl font-bold">Guided learning paths</h1>
    <p class="mt-2 max-w-2xl text-lg text-muted">Follow a path from foundations to advanced study. Each path is an ordered set of courses — finish one to light up the next.</p>
    <div class="mt-8 space-y-10">
      {paths.map((p) => (
        <section>
          <h2 class="text-xl font-bold">{p.name}</h2>
          <p class="text-muted">{p.blurb}</p>
          <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-paper"><div class="path-bar h-full bg-saffron" data-path={p.id} style="width:0%"></div></div>
          <div class="path-count font-sans text-xs text-muted" data-path={p.id}>{p.courseIds.length} courses</div>
          <ol class="mt-3 list-decimal space-y-2 pl-5">
            {p.courseIds.map((id) => byId[id] && (
              <li><a class="font-semibold text-navy hover:text-saffron-deep" href={`/course/${id}.html`} data-course={id}>{byId[id].title}</a><div class="text-[0.9rem] text-muted">{byId[id].summary}</div></li>
            ))}
          </ol>
        </section>
      ))}
    </div>
  </section>
  <script define:vars={{ paths }}>
    const passed = (id) => { try { return !!localStorage.getItem('su_v1_passed_' + id); } catch { return false; } };
    paths.forEach((p) => {
      const done = p.courseIds.filter(passed).length;
      const bar = document.querySelector(`.path-bar[data-path="${p.id}"]`);
      const cnt = document.querySelector(`.path-count[data-path="${p.id}"]`);
      if (bar) bar.style.width = (p.courseIds.length ? Math.round((done / p.courseIds.length) * 100) : 0) + '%';
      if (cnt) cnt.textContent = `${done} of ${p.courseIds.length} complete`;
    });
    document.querySelectorAll('a[data-course]').forEach((a) => { if (passed(a.dataset.course)) a.innerHTML += ' <span class="text-ok">✓</span>'; });
  </script>
</Base>
