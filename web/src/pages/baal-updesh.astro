---
import Base from '../layouts/Base.astro';
import gurbaniWords from '../data/gurbani-words.json';
// The Painti — 35 letters of the Gurmukhi alphabet (3 vowel-bearers + 32 consonants).
const akhar = [
  ['ੳ', 'Ura'], ['ਅ', 'Aira'], ['ੲ', 'Iri'], ['ਸ', 'Sassa'], ['ਹ', 'Haha'],
  ['ਕ', 'Kakka'], ['ਖ', 'Khakha'], ['ਗ', 'Gagga'], ['ਘ', 'Ghagha'], ['ਙ', 'Nganga'],
  ['ਚ', 'Chacha'], ['ਛ', 'Chhachha'], ['ਜ', 'Jajja'], ['ਝ', 'Jhajha'], ['ਞ', 'Njanja'],
  ['ਟ', 'Tainka'], ['ਠ', 'Tthattha'], ['ਡ', 'Dadda'], ['ਢ', 'Dhadha'], ['ਣ', 'Nanha'],
  ['ਤ', 'Tatta'], ['ਥ', 'Thatha'], ['ਦ', 'Dadda'], ['ਧ', 'Dhadha'], ['ਨ', 'Nanna'],
  ['ਪ', 'Pappa'], ['ਫ', 'Phapha'], ['ਬ', 'Babba'], ['ਭ', 'Bhabha'], ['ਮ', 'Mamma'],
  ['ਯ', 'Yaiya'], ['ਰ', 'Rara'], ['ਲ', 'Lalla'], ['ਵ', 'Vava'], ['ੜ', 'Rrarra'],
];
const navin = [['ਸ਼', 'Shasha'], ['ਖ਼', 'Khhakha'], ['ਗ਼', 'Ghhagha'], ['ਜ਼', 'Zazza'], ['ਫ਼', 'Faffa'], ['ਲ਼', 'Llalla']];
// Muharni: each consonant sounded through the vowel signs (laga-matra).
const consonants = ['ਸ', 'ਹ', 'ਕ', 'ਖ', 'ਗ', 'ਘ', 'ਙ', 'ਚ', 'ਛ', 'ਜ', 'ਝ', 'ਞ', 'ਟ', 'ਠ', 'ਡ', 'ਢ', 'ਣ', 'ਤ', 'ਥ', 'ਦ', 'ਧ', 'ਨ', 'ਪ', 'ਫ', 'ਬ', 'ਭ', 'ਮ', 'ਯ', 'ਰ', 'ਲ', 'ਵ', 'ੜ'];
const matras = ['', 'ਾ', 'ਿ', 'ੀ', 'ੁ', 'ੂ', 'ੇ', 'ੈ', 'ੋ', 'ੌ'];
const matraNames = ['ਮੁਕਤਾ', 'ਕੰਨਾ', 'ਸਿਹਾਰੀ', 'ਬਿਹਾਰੀ', 'ਔਂਕੜ', 'ਦੁਲੈਂਕੜ', 'ਲਾਂ', 'ਦੁਲਾਵਾਂ', 'ਹੋੜਾ', 'ਕਨੌੜਾ'];
// Reading practice: words of growing length [Gurmukhi, transliteration, meaning].
const words2 = [['ਘਰ', 'ghar', 'house'], ['ਜਲ', 'jal', 'water'], ['ਮਨ', 'man', 'mind'], ['ਤਨ', 'tan', 'body'], ['ਪਲ', 'pal', 'moment'], ['ਡਰ', 'ḍar', 'fear'], ['ਰਸ', 'ras', 'essence'], ['ਸਚ', 'sach', 'truth']];
const words3 = [['ਕਮਲ', 'kamal', 'lotus'], ['ਚਰਨ', 'charan', 'feet'], ['ਸਬਦ', 'shabad', 'word'], ['ਅਮਰ', 'amar', 'immortal'], ['ਸਹਜ', 'sahaj', 'calm/poise'], ['ਨਾਨਕ', 'Nanak', 'Guru Nanak'], ['ਪਾਣੀ', 'paaṇi', 'water'], ['ਧਰਮ', 'dharam', 'righteousness']];
const words4 = [['ਸਤਿਗੁਰ', 'satgur', 'the True Guru'], ['ਗੁਰਮੁਖ', 'gurmukh', 'Guru-facing one'], ['ਸੰਗਤ', 'sangat', 'congregation'], ['ਪਰਮੇਸਰ', 'parmesar', 'the Supreme Lord'], ['ਅਕਾਲ', 'akaal', 'the Timeless'], ['ਵਾਹਿਗੁਰੂ', 'Waheguru', 'the Wondrous Lord']];
const sentences = [
  ['ੴ', 'Ik Onkar', 'There is One Creator.'],
  ['ਸਤਿ ਸ੍ਰੀ ਅਕਾਲ ॥', 'Sat Sri Akaal', 'A common Sikh greeting — "Truth is the Timeless One".'],
  ['ਵਾਹਿਗੁਰੂ ਜੀ ਕਾ ਖਾਲਸਾ ॥ ਵਾਹਿਗੁਰੂ ਜੀ ਕੀ ਫ਼ਤਿਹ ॥', 'Waheguru ji ka Khalsa, Waheguru ji ki Fateh', 'The Khalsa belongs to Waheguru; victory belongs to Waheguru.'],
];
// Graded reading practice, by length.
const shortS = [
  ['ਇਹ ਘਰ ਹੈ ॥', 'ih ghar hai', 'This is a house.'],
  ['ਪਾਣੀ ਠੰਢਾ ਹੈ ॥', 'paaṇi ṭhanḍha hai', 'The water is cold.'],
  ['ਬੱਚਾ ਖੇਡਦਾ ਹੈ ॥', 'bachcha kheḍda hai', 'The child plays.'],
  ['ਫੁੱਲ ਸੋਹਣਾ ਹੈ ॥', 'phull sohṇa hai', 'The flower is beautiful.'],
];
const medS = [
  ['ਅਸੀਂ ਗੁਰਦੁਆਰੇ ਜਾਂਦੇ ਹਾਂ ॥', 'aseeṁ gurduaare jaande haaṁ', 'We go to the gurdwara.'],
  ['ਮੈਂ ਹਰ ਰੋਜ਼ ਪਾਠ ਕਰਦਾ ਹਾਂ ॥', 'maiṁ har roz paaṭh karda haaṁ', 'I read paath every day.'],
  ['ਮਾਤਾ ਜੀ ਲੰਗਰ ਤਿਆਰ ਕਰਦੇ ਹਨ ॥', 'maata ji langar tiaar karde han', 'Mother prepares the langar.'],
  ['ਸੰਗਤ ਰਲ਼ ਕੇ ਕੀਰਤਨ ਕਰਦੀ ਹੈ ॥', 'sangat ral ke keertan kardi hai', 'The sangat gathers and sings kirtan.'],
];
const longS = [
  ['ਸਵੇਰੇ ਉੱਠ ਕੇ ਅਸੀਂ ਇਸ਼ਨਾਨ ਕਰਦੇ ਹਾਂ ਅਤੇ ਨਿਤਨੇਮ ਕਰਦੇ ਹਾਂ ॥', 'savere uṭṭh ke aseeṁ ishnaan karde haaṁ ate nitnem karde haaṁ', 'In the morning we rise, bathe, and do our nitnem.'],
  ['ਵਾਹਿਗੁਰੂ ਨੇ ਸਾਰੀ ਸ੍ਰਿਸ਼ਟੀ ਰਚੀ ਹੈ ਅਤੇ ਸਭ ਜੀਆਂ ਦੀ ਸੰਭਾਲ ਕਰਦਾ ਹੈ ॥', 'Waheguru ne saari srishṭi rachi hai ate sabh jeeaaṁ di sambhaal karda hai', 'Waheguru created all of creation and cares for every being.'],
];
// Short reading paragraphs (a few simple sentences each).
const paras = [
  ['ਸਾਡਾ ਪਰਿਵਾਰ ਅੰਮ੍ਰਿਤ ਵੇਲੇ ਉੱਠਦਾ ਹੈ। ਅਸੀਂ ਇਸ਼ਨਾਨ ਕਰਕੇ ਵਾਹਿਗੁਰੂ ਦਾ ਨਾਮ ਜਪਦੇ ਹਾਂ। ਫਿਰ ਅਸੀਂ ਰਲ਼ ਕੇ ਨਿਤਨੇਮ ਦੀਆਂ ਬਾਣੀਆਂ ਪੜ੍ਹਦੇ ਹਾਂ।',
   'Our family wakes at amrit vela. After bathing, we meditate on Waheguru’s Name. Then together we read the nitnem banis.'],
  ['ਗੁਰੂ ਨਾਨਕ ਦੇਵ ਜੀ ਨੇ ਸਾਨੂੰ ਇੱਕ ਅਕਾਲ ਪੁਰਖ ਦਾ ਉਪਦੇਸ਼ ਦਿੱਤਾ। ਉਨ੍ਹਾਂ ਨੇ ਸਿਖਾਇਆ ਕਿ ਸਾਰੇ ਮਨੁੱਖ ਬਰਾਬਰ ਹਨ। ਸਾਨੂੰ ਮਿਹਨਤ ਕਰਨੀ, ਨਾਮ ਜਪਣਾ ਅਤੇ ਵੰਡ ਕੇ ਛਕਣਾ ਚਾਹੀਦਾ ਹੈ।',
   'Guru Nanak Dev Ji taught us of the One Akal Purakh. He taught that all people are equal. We should work honestly, meditate on the Name, and share with others.'],
];
// Gurmukhi numerals 0–100 (glyphs are generated mechanically; names below are the common forms).
const gur = (n) => String(n).split('').map((d) => '੦੧੨੩੪੫੬੭੮੯'[+d]).join('');
const range0to100 = Array.from({ length: 101 }, (_, i) => i);
const numNames = [
  ['੦', '0', 'ਸਿਫ਼ਰ', 'sifar'], ['੧', '1', 'ਇੱਕ', 'ikk'], ['੨', '2', 'ਦੋ', 'do'], ['੩', '3', 'ਤਿੰਨ', 'tinn'],
  ['੪', '4', 'ਚਾਰ', 'chaar'], ['੫', '5', 'ਪੰਜ', 'panj'], ['੬', '6', 'ਛੇ', 'chhe'], ['੭', '7', 'ਸੱਤ', 'satt'],
  ['੮', '8', 'ਅੱਠ', 'aṭṭh'], ['੯', '9', 'ਨੌਂ', 'nauṁ'], ['੧੦', '10', 'ਦਸ', 'das'],
  ['੨੦', '20', 'ਵੀਹ', 'veeh'], ['੩੦', '30', 'ਤੀਹ', 'teeh'], ['੪੦', '40', 'ਚਾਲੀ', 'chaalee'], ['੫੦', '50', 'ਪੰਜਾਹ', 'panjaah'],
  ['੬੦', '60', 'ਸੱਠ', 'saṭh'], ['੭੦', '70', 'ਸੱਤਰ', 'sattar'], ['੮੦', '80', 'ਅੱਸੀ', 'assee'], ['੯੦', '90', 'ਨੱਬੇ', 'nabbe'], ['੧੦੦', '100', 'ਸੌ', 'sau'],
];
const wordCard = (w) => w;
---
<Base title="Baal Updesh — Learn to Read Gurmukhi | Sikh University" description="The complete beginner's primer for Gurmukhi and Punjabi: the alphabet, the Muharni, two/three/four-letter words, simple sentences, and numbers 0–100.">
  <section class="wrap py-12">
    <div class="font-sans text-sm"><a href="/santhiya" class="text-muted hover:text-navy">← Santhya pathway</a></div>
    <h1 class="mt-2 flex flex-wrap items-baseline gap-3"><span class="gur text-3xl font-bold text-navy">ਬਾਲ ਉਪਦੇਸ਼</span><span class="text-lg text-muted">Baal Updesh — learn to read Gurmukhi</span></h1>
    <p class="mt-2 max-w-2xl text-lg text-muted">A complete beginner's path. Work through it in order, saying everything aloud — the alphabet, the Muharni, then real words, sentences and numbers. This is where every reader of Gurbani begins.</p>

    <nav class="mt-5 flex flex-wrap gap-2 font-sans text-sm">
      <a href="#painti" class="rounded-full border border-line px-3 py-1 hover:border-saffron">1. The Painti</a>
      <a href="#navin" class="rounded-full border border-line px-3 py-1 hover:border-saffron">2. Extra letters</a>
      <a href="#muharni" class="rounded-full border border-line px-3 py-1 hover:border-saffron">3. The Muharni</a>
      <a href="#words" class="rounded-full border border-line px-3 py-1 hover:border-saffron">4. Words</a>
      <a href="#sentences" class="rounded-full border border-line px-3 py-1 hover:border-saffron">5. Sentences</a>
      <a href="#numbers" class="rounded-full border border-line px-3 py-1 hover:border-saffron">6. Numbers 0–100</a>
      <a href="#common-words" class="rounded-full border border-line px-3 py-1 hover:border-saffron">7. Common words</a>
    </nav>

    <details id="painti" open class="mt-8 border-t border-line pt-3">
    <summary class="cursor-pointer text-xl font-bold text-navy hover:text-saffron-deep">1. The Painti — <span class="gur">ਪੈਂਤੀ</span> (35 letters)</summary>
    <p class="mt-1 max-w-2xl text-muted">Three are vowel-bearers (<span class="gur">ੳ ਅ ੲ</span>); the rest are consonants. Say each letter aloud.</p>
    <div class="mt-5 grid grid-cols-3 gap-3 sm:grid-cols-5 lg:grid-cols-7">
      {akhar.map(([ch, name]) => (
        <div class="rounded-xl2 border border-line bg-surface p-4 text-center shadow-card">
          <div class="gur text-4xl font-bold text-navy">{ch}</div>
          <div class="mt-1 font-sans text-xs text-muted">{name}</div>
        </div>
      ))}
    </div>

    </details>

    <details id="navin" open class="mt-8 border-t border-line pt-3">
    <summary class="cursor-pointer text-xl font-bold text-navy hover:text-saffron-deep">2. The extra letters — <span class="gur">ਨਵੀਨ ਟੋਲੀ</span></summary>
    <p class="mt-1 max-w-2xl text-muted">Six later letters, written by adding a dot (<span class="gur">ਪੈਰ ਬਿੰਦੀ</span>) beneath a base letter, for sounds used in borrowed words.</p>
    <div class="mt-5 grid grid-cols-3 gap-3 sm:grid-cols-6">
      {navin.map(([ch, name]) => (
        <div class="rounded-xl2 border border-line bg-surface p-4 text-center shadow-card">
          <div class="gur text-4xl font-bold text-navy">{ch}</div>
          <div class="mt-1 font-sans text-xs text-muted">{name}</div>
        </div>
      ))}
    </div>

    </details>

    <details id="muharni" open class="mt-8 border-t border-line pt-3">
    <summary class="cursor-pointer text-xl font-bold text-navy hover:text-saffron-deep">3. The Muharni — <span class="gur">ਮੁਹਾਰਨੀ</span></summary>
    <p class="mt-1 max-w-2xl text-muted">Sound each consonant through the ten vowel signs (<span class="gur">ਲਗਾਂ-ਮਾਤਰਾਂ</span>). Read across each row aloud — this builds <span class="gur">ਸ਼ੁੱਧ ਉਚਾਰਨ</span> (correct pronunciation).</p>
    <div class="mt-5 overflow-x-auto rounded-xl2 border border-line">
      <table class="w-full border-collapse text-center">
        <thead>
          <tr class="bg-brand text-white">
            <th class="p-2 font-sans text-xs">ਅੱਖਰ</th>
            {matraNames.map((n) => <th class="p-2"><span class="gur text-sm font-normal">{n}</span></th>)}
          </tr>
        </thead>
        <tbody>
          {consonants.map((cn, r) => (
            <tr class={r % 2 ? 'bg-paper' : ''}>
              <td class="gur border border-line p-2 text-2xl font-bold text-blue">{cn}</td>
              {matras.map((m) => <td class="gur border border-line p-2 text-2xl">{cn + m}</td>)}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    </details>

    <details id="words" open class="mt-8 border-t border-line pt-3">
    <summary class="cursor-pointer text-xl font-bold text-navy hover:text-saffron-deep">4. Reading words — <span class="gur">ਸ਼ਬਦ ਜੋੜ</span></summary>
    <p class="mt-1 max-w-2xl text-muted">Now blend letters into words. Start with two letters, then three, then longer. Sound each one out, then read the whole word.</p>
    {[['Two-letter words', words2], ['Three-letter words', words3], ['Longer words', words4]].map(([label, list]) => (
      <div class="mt-5">
        <h3 class="font-sans text-sm font-bold uppercase tracking-wide text-saffron-deep">{label}</h3>
        <div class="mt-2 grid grid-cols-2 gap-3 sm:grid-cols-4">
          {list.map(([w, tr, mean]) => (
            <div class="rounded-xl2 border border-line bg-surface p-3 text-center shadow-card">
              <div class="gur text-3xl font-bold text-navy">{w}</div>
              <div class="mt-1 font-sans text-xs text-blue">{tr}</div>
              <div class="font-sans text-xs text-muted">{mean}</div>
            </div>
          ))}
        </div>
      </div>
    ))}

    </details>

    <details id="sentences" open class="mt-8 border-t border-line pt-3">
    <summary class="cursor-pointer text-xl font-bold text-navy hover:text-saffron-deep">5. Sentences & paragraphs — <span class="gur">ਵਾਕ ਤੇ ਪੈਰੇ</span></summary>
    <p class="mt-1 max-w-2xl text-muted">Read these aloud, building from greetings to short, medium and long sentences, then full paragraphs. The <span class="gur">॥</span> (danda) and <span class="gur">।</span> mark line ends.</p>
    {[['Greetings & sacred lines', sentences], ['Short sentences', shortS], ['Medium sentences', medS], ['Long sentences', longS]].map(([label, list]) => (
      <div class="mt-5">
        <h3 class="font-sans text-sm font-bold uppercase tracking-wide text-saffron-deep">{label}</h3>
        <div class="mt-2 space-y-3">
          {list.map(([s, tr, mean]) => (
            <div class="rounded-xl2 border border-line bg-surface p-4 shadow-card">
              <div class="gur text-2xl text-navy">{s}</div>
              <div class="mt-1 font-sans text-sm text-blue">{tr}</div>
              <div class="font-sans text-sm text-muted">{mean}</div>
            </div>
          ))}
        </div>
      </div>
    ))}
    <div class="mt-6">
      <h3 class="font-sans text-sm font-bold uppercase tracking-wide text-saffron-deep">Paragraphs</h3>
      <div class="mt-2 space-y-3">
        {paras.map(([p, mean]) => (
          <div class="rounded-xl2 border border-line bg-surface p-4 shadow-card">
            <p class="gur text-xl leading-loose text-navy">{p}</p>
            <p class="mt-2 font-sans text-sm text-muted">{mean}</p>
          </div>
        ))}
      </div>
    </div>

    </details>

    <details id="numbers" open class="mt-8 border-t border-line pt-3">
    <summary class="cursor-pointer text-xl font-bold text-navy hover:text-saffron-deep">6. Numbers — <span class="gur">ਅੰਕ</span> (0–100)</summary>
    <p class="mt-1 max-w-2xl text-muted">Gurmukhi has its own digits. Learn the names for 0–10 and the tens, then read every numeral from 0 to 100.</p>
    <div class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-5">
      {numNames.map(([g, n, nm, tr]) => (
        <div class="rounded-xl2 border border-line bg-surface p-3 text-center shadow-card">
          <div class="gur text-2xl font-bold text-navy">{g}</div>
          <div class="font-sans text-xs text-muted">{n}</div>
          <div class="gur mt-1 text-base text-blue">{nm}</div>
          <div class="font-sans text-[0.7rem] text-muted">{tr}</div>
        </div>
      ))}
    </div>
    <h3 class="mt-6 font-sans text-sm font-bold uppercase tracking-wide text-saffron-deep">All numerals, 0–100</h3>
    <div class="mt-2 grid grid-cols-5 gap-2 sm:grid-cols-10">
      {range0to100.map((n) => (
        <div class="rounded-lg border border-line bg-paper py-2 text-center">
          <div class="gur text-lg font-bold text-navy">{gur(n)}</div>
          <div class="font-sans text-[0.7rem] text-muted">{n}</div>
        </div>
      ))}
    </div>

    </details>

    <details id="common-words" open class="mt-8 border-t border-line pt-3">
    <summary class="cursor-pointer text-xl font-bold text-navy hover:text-saffron-deep">7. Common words of Gurbani — <span class="gur">ਸ਼ਬਦ ਭੰਡਾਰ</span></summary>
    <p class="mt-1 max-w-2xl text-muted">Some of the most-used words in Sri Guru Granth Sahib Ji. Learn a few each day; tap a word for its full meaning. Shared with permission from the <a class="underline" href="https://365gurbaniwords.blogspot.com" target="_blank" rel="noopener">365 Gurbani Words</a> project.</p>
    <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4 lg:grid-cols-5">
      {gurbaniWords.map((w) => (
        <a href={w.url} target="_blank" rel="noopener" class="rounded-xl2 border border-line bg-surface p-3 text-center shadow-card hover:border-saffron">
          <div class="gur text-2xl font-bold text-navy">{w.gur}</div>
          <div class="mt-1 font-sans text-xs text-blue">{w.tr}</div>
        </a>
      ))}
    </div>
    </details>

    <div class="mt-12 rounded-xl2 border border-line bg-gradient-to-br from-blue/5 to-surface p-6">
      <h2 class="text-xl font-bold">Next steps</h2>
      <ol class="mt-3 list-decimal space-y-1 pl-5">
        <li>Begin the daily banis — <a class="underline" href="/collection/nitnem">Nitnem</a>.</li>
        <li>Read along with Sri Guru Granth Sahib Ji — the <a class="underline" href="/read?src=sggs&ang=1">read-along reader</a>.</li>
        <li>Continue the full <a class="underline" href="/santhiya">Santhya pathway</a>.</li>
      </ol>
    </div>
  </section>
</Base>
