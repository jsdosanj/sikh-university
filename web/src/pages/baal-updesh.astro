        <div class="space-y-3 text-sm leading-relaxed">
          <div><span class="font-semibold text-navy">History: </span><span class="text-muted">${k.history}</span></div>
          <div><span class="font-semibold text-navy">Meaning: </span><span class="text-muted">${k.meaning}</span></div>
          <div><span class="font-semibold text-navy">Significance: </span><span class="text-muted">${k.significance}</span></div>
          <div class="mt-3 rounded-lg border-l-4 border-saffron bg-saffron/5 px-3 py-2">
            <p class="text-xs italic text-navy">${k.gurbani}</p>
          </div>
        </div>
      `);
    });
  });

  // Init tree when its section is first opened (lazy)
  const ftSection = document.getElementById('family-tree');
  let treeInited = false;
  if (ftSection) {
    ftSection.addEventListener('toggle', () => { if (ftSection.open && !treeInited) { treeInited = true; initFamilyTree(); } });
  }
  </script>
</Base>
