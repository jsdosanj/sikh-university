    'baba-lakhmi':    { name:'Baba Lakhmi Chand Ji', gur:'ਬਾਬਾ ਲਖਮੀ ਚੰਦ ਜੀ', role:'Son of Guru Nanak Dev Ji', born:'c. 1497 CE', died:'c. 1555 CE', parents:'Guru Nanak Dev Ji & Mata Sulakhni Ji', siblings:'Baba Sri Chand Ji', spouse:'—', children:'—', bio:'Baba Lakhmi Chand Ji was the younger son of Guru Nanak Dev Ji. He lived a householder\'s life.' },
    'pheru-mal':      { name:'Pheru Mal Ji', gur:'ਫੇਰੂ ਮਲ ਜੀ', role:'Father of Guru Angad Dev Ji', born:'c. 1470 CE', died:'Unknown', parents:'—', siblings:'—', spouse:'Mata Dhaya Kaur Ji', children:'Guru Angad Dev Ji', bio:'Pheru Mal Ji was the father of Guru Angad Dev Ji. He was a trader by profession and a devotee of the goddess Durga. He died when Guru Angad was still young.' },
    'mata-dhaya':     { name:'Mata Dhaya Kaur Ji', gur:'ਮਾਤਾ ਧਿਆ ਕੌਰ ਜੀ', role:'Mother of Guru Angad Dev Ji', born:'c. 1475 CE', died:'Unknown', parents:'—', siblings:'—', spouse:'Pheru Mal Ji', children:'Guru Angad Dev Ji', bio:'Mata Dhaya Kaur Ji was the mother of Guru Angad Dev Ji. It was largely her influence that led her son toward a life of devotion and seva.' },
    'guru-angad':     { name:'Guru Angad Dev Ji', gur:'ਗੁਰੂ ਅੰਗਦ ਦੇਵ ਜੀ', role:'2nd Sikh Guru', born:'31 March 1504 CE, Harike, Ferozpur, Punjab', died:'29 March 1552 CE, Khadur Sahib, Punjab', parents:'Pheru Mal Ji & Mata Dhaya Kaur Ji', siblings:'—', spouse:'Mata Khivi Ji', children:'Dassu Ji, Dattu Ji, Bibi Amro Ji, Bibi Anokhi (Alakhi) Ji', bio:'Guru Angad Dev Ji was selected as the second Sikh Guru by Guru Nanak Dev Ji. He standardised and popularised the Gurmukhi script, making Gurbani accessible to all. Mata Khivi Ji, his wife, is one of the only women mentioned directly in the Sri Guru Granth Sahib Ji for her seva in managing the Langar.', isGuru:true },
    'mata-khivi':     { name:'Mata Khivi Ji', gur:'ਮਾਤਾ ਖੀਵੀ ਜੀ', role:'Wife of Guru Angad Dev Ji · Langar seva', born:'c. 1506 CE', died:'c. 1582 CE', parents:'—', siblings:'—', spouse:'Guru Angad Dev Ji', children:'Dassu Ji, Dattu Ji, Bibi Amro Ji, Bibi Anokhi Ji', bio:'Mata Khivi Ji is celebrated in the Sri Guru Granth Sahib Ji (Ang 967) for her selfless service in the Langar. She managed the Langar with great devotion, serving the congregation ghee-enriched kheer.' },
    'dassu':          { name:'Dassu Ji', gur:'ਦਾਸੂ ਜੀ', role:'Son of Guru Angad Dev Ji', born:'Unknown', died:'Unknown', parents:'Guru Angad Dev Ji & Mata Khivi Ji', siblings:'Dattu Ji, Bibi Amro Ji, Bibi Anokhi Ji', spouse:'—', children:'—', bio:'Dassu Ji was the elder son of Guru Angad Dev Ji.' },
    'dattu':          { name:'Dattu Ji', gur:'ਦਾਤੂ ਜੀ', role:'Son of Guru Angad Dev Ji', born:'Unknown', died:'Unknown', parents:'Guru Angad Dev Ji & Mata Khivi Ji', siblings:'Dassu Ji, Bibi Amro Ji, Bibi Anokhi Ji', spouse:'—', children:'—', bio:'Dattu Ji was the second son of Guru Angad Dev Ji. He is known for having momentarily kicked Guru Amar Das Ji in anger when Guru-ship was passed over him.' },
    'bibi-amro':      { name:'Bibi Amro Ji', gur:'ਬੀਬੀ ਅਮਰੋ ਜੀ', role:'Daughter of Guru Angad Dev Ji · Teacher of Gurbani', born:'c. 1532 CE', died:'c. 1600 CE', parents:'Guru Angad Dev Ji & Mata Khivi Ji', siblings:'Dassu Ji, Dattu Ji, Bibi Anokhi Ji', spouse:'Jasoo (son of Guru Amar Das\'s brother)', children:'—', bio:'Bibi Amro Ji was a gifted Gurbani reciter. It was through hearing her sing Gurbani that Guru Amar Das Ji was first drawn to the spiritual path and ultimately to Guru Angad Dev Ji.' },
    'alakhi':         { name:'Bibi Anokhi (Alakhi) Ji', gur:'ਬੀਬੀ ਅਨੋਖੀ ਜੀ', role:'Daughter of Guru Angad Dev Ji', born:'Unknown', died:'Unknown', parents:'Guru Angad Dev Ji & Mata Khivi Ji', siblings:'Dassu Ji, Dattu Ji, Bibi Amro Ji', spouse:'—', children:'—', bio:'Bibi Anokhi Ji, also known as Alakhi Ji, was the youngest daughter of Guru Angad Dev Ji and Mata Khivi Ji.' },
    'tej-bhan':       { name:'Tej Bhan Ji', gur:'ਤੇਜ ਭਾਨ ਜੀ', role:'Father of Guru Amar Das Ji', born:'c. 1449 CE', died:'Unknown', parents:'—', siblings:'—', spouse:'Mata Lachmi Ji', children:'Guru Amar Das Ji', bio:'Tej Bhan Ji was a Khatri of the Bhalla clan and the father of Guru Amar Das Ji. He lived in the village of Basarke.' },
    'mata-lachmi':    { name:'Mata Lachmi Ji', gur:'ਮਾਤਾ ਲਖਮੀ ਜੀ', role:'Mother of Guru Amar Das Ji', born:'c. 1455 CE', died:'Unknown', parents:'—', siblings:'—', spouse:'Tej Bhan Ji', children:'Guru Amar Das Ji', bio:'Mata Lachmi Ji was the mother of Guru Amar Das Ji.' },
    'guru-amar-das':  { name:'Guru Amar Das Ji', gur:'ਗੁਰੂ ਅਮਰ ਦਾਸ ਜੀ', role:'3rd Sikh Guru', born:'5 May 1479 CE, Basarke, Amritsar, Punjab', died:'1 September 1574 CE, Goindwal, Punjab', parents:'Tej Bhan Ji & Mata Lachmi Ji', siblings:'—', spouse:'Mata Mansa Devi Ji', children:'Mohan Ji, Mohari Ji, Bibi Dani Ji, Bibi Bhanni Ji', bio:'Guru Amar Das Ji became the third Sikh Guru at the age of 73, after decades of devoted service to Guru Angad Dev Ji. He established the Manji and Piri systems to spread the Guru\'s teaching, abolished purdah (the veil) and sati (widow immolation), and established 22 women preachers (Manjidars). He composed the Anand Sahib and the laavan (wedding hymns).', isGuru:true },
    'mata-mansa':     { name:'Mata Mansa Devi Ji', gur:'ਮਾਤਾ ਮਾਨਸਾ ਦੇਵੀ ਜੀ', role:'Wife of Guru Amar Das Ji', born:'Unknown', died:'Unknown', parents:'—', siblings:'—', spouse:'Guru Amar Das Ji', children:'Mohan Ji, Mohari Ji, Bibi Dani Ji, Bibi Bhanni Ji', bio:'Mata Mansa Devi Ji was the devoted wife of Guru Amar Das Ji.' },
    'har-das':        { name:'Har Das Ji', gur:'ਹਰਿ ਦਾਸ ਜੀ', role:'Father of Guru Ram Das Ji', born:'c. 1505 CE', died:'Unknown', parents:'—', siblings:'—', spouse:'Mata Daya Ji', children:'Guru Ram Das Ji', bio:'Har Das Ji was the father of Guru Ram Das Ji. He was a devoted Sikh who passed away when Guru Ram Das Ji was still a child.' },
    'mata-daya':      { name:'Mata Daya Ji', gur:'ਮਾਤਾ ਦਾਇਆ ਜੀ', role:'Mother of Guru Ram Das Ji', born:'c. 1510 CE', died:'Unknown', parents:'—', siblings:'—', spouse:'Har Das Ji', children:'Guru Ram Das Ji', bio:'Mata Daya Ji was the mother of Guru Ram Das Ji. She was widowed young and raised her son in Lahore in poverty before he came to serve in the Guru\'s Langar.' },
    'mohan':          { name:'Mohan Ji', gur:'ਮੋਹਨ ਜੀ', role:'Son of Guru Amar Das Ji', born:'c. 1538 CE', died:'Unknown', parents:'Guru Amar Das Ji & Mata Mansa Devi Ji', siblings:'Mohari Ji, Bibi Dani Ji, Bibi Bhanni Ji', spouse:'—', children:'—', bio:'Mohan Ji was the elder son of Guru Amar Das Ji. He compiled a collection of bani (the Mohan Vali Pothi) that was later used by Guru Arjan Dev Ji in compiling the Adi Granth.' },
    'mohari':         { name:'Mohari Ji', gur:'ਮੋਹਰੀ ਜੀ', role:'Son of Guru Amar Das Ji', born:'c. 1541 CE', died:'Unknown', parents:'Guru Amar Das Ji & Mata Mansa Devi Ji', siblings:'Mohan Ji, Bibi Dani Ji, Bibi Bhanni Ji', spouse:'—', children:'—', bio:'Mohari Ji was the second son of Guru Amar Das Ji.' },
    'bibi-dani':      { name:'Bibi Dani Ji', gur:'ਬੀਬੀ ਦਾਨੀ ਜੀ', role:'Daughter of Guru Amar Das Ji', born:'Unknown', died:'Unknown', parents:'Guru Amar Das Ji & Mata Mansa Devi Ji', siblings:'Mohan Ji, Mohari Ji, Bibi Bhanni Ji', spouse:'—', children:'—', bio:'Bibi Dani Ji was a daughter of Guru Amar Das Ji.' },
    'bibi-bhanni':    { name:'Bibi Bhanni Ji', gur:'ਬੀਬੀ ਭਾਨੀ ਜੀ', role:'Daughter of Guru Amar Das Ji · Wife of Guru Ram Das Ji', born:'c. 1535 CE', died:'c. 1598 CE', parents:'Guru Amar Das Ji & Mata Mansa Devi Ji', siblings:'Mohan Ji, Mohari Ji, Bibi Dani Ji', spouse:'Guru Ram Das Ji', children:'Pirthi Chand Ji, Maha Dev Ji, Guru Arjan Dev Ji', bio:'Bibi Bhanni Ji was the devoted daughter of Guru Amar Das Ji and wife of Guru Ram Das Ji. She is famous for her extraordinary seva — holding a water pot still with her own hand beneath a broken leg of her father\'s seat so his meditation would not be disturbed. For this selfless seva, she was blessed that the Guruship would remain in her family.' },
    'guru-ram-das':   { name:'Guru Ram Das Ji', gur:'ਗੁਰੂ ਰਾਮ ਦਾਸ ਜੀ', role:'4th Sikh Guru · Founded Amritsar', born:'24 September 1534 CE, Lahore (Pakistan)', died:'1 September 1581 CE, Goindwal, Punjab', parents:'Har Das Ji & Mata Daya Ji', siblings:'—', spouse:'Bibi Bhanni Ji', children:'Pirthi Chand Ji, Maha Dev Ji, Guru Arjan Dev Ji', bio:'Guru Ram Das Ji was the fourth Sikh Guru. He founded the city of Ramdaspur (now Amritsar) and began excavation of the sacred Amrit Sarovar (Pool of Nectar). He composed the Laavan (wedding hymns for Anand Karaj) and a great body of Gurbani, including Bihaagra ki Vaar.', isGuru:true },
    'pirthi-chand':   { name:'Pirthi Chand Ji', gur:'ਪ੍ਰਿਥੀ ਚੰਦ ਜੀ', role:'Elder son of Guru Ram Das Ji', born:'c. 1558 CE', died:'c. 1618 CE', parents:'Guru Ram Das Ji & Bibi Bhanni Ji', siblings:'Maha Dev Ji, Guru Arjan Dev Ji', spouse:'—', children:'Miharvan Ji', bio:'Pirthi Chand Ji was the elder son of Guru Ram Das Ji. He expected to inherit the Guruship but it passed to his younger brother Guru Arjan Dev Ji. He is known historically for opposing the Sikh Gurus and composing fake bani (known as "Meena" bani) which Guru Arjan Dev Ji compiled the Adi Granth to exclude.' },
    'maha-dev':       { name:'Maha Dev Ji', gur:'ਮਹਾ ਦੇਵ ਜੀ', role:'Son of Guru Ram Das Ji', born:'c. 1560 CE', died:'Unknown', parents:'Guru Ram Das Ji & Bibi Bhanni Ji', siblings:'Pirthi Chand Ji, Guru Arjan Dev Ji', spouse:'—', children:'—', bio:'Maha Dev Ji was the second son of Guru Ram Das Ji. He lived a life of renunciation and austerity.' },
    'guru-arjan':     { name:'Guru Arjan Dev Ji', gur:'ਗੁਰੂ ਅਰਜਨ ਦੇਵ ਜੀ', role:'5th Sikh Guru · First Sikh Martyr · Compiled the Adi Granth', born:'15 April 1563 CE, Goindwal, Punjab', died:'30 May 1606 CE, Lahore (martyrdom)', parents:'Guru Ram Das Ji & Bibi Bhanni Ji', siblings:'Pirthi Chand Ji, Maha Dev Ji', spouse:'Mata Ganga Ji', children:'Guru Hargobind Sahib Ji', bio:'Guru Arjan Dev Ji compiled the Sri Guru Granth Sahib Ji (Adi Granth) and enshrined it in the newly completed Harmandar Sahib (Golden Temple) in Amritsar in 1604. He became the first Sikh martyr when he was tortured to death on the orders of the Mughal Emperor Jahangir in 1606 for refusing to convert to Islam.', isGuru:true },
    'mata-ganga':     { name:'Mata Ganga Ji', gur:'ਮਾਤਾ ਗੰਗਾ ਜੀ', role:'Wife of Guru Arjan Dev Ji', born:'c. 1565 CE', died:'c. 1621 CE', parents:'—', siblings:'—', spouse:'Guru Arjan Dev Ji', children:'Guru Hargobind Sahib Ji', bio:'Mata Ganga Ji was the devoted wife of Guru Arjan Dev Ji. She is famous for walking barefoot to seek the blessings of Baba Buddha Ji, the great Sikh elder, for a son. Baba Buddha Ji blessed her with a son who would be a warrior and a hero — Guru Hargobind Sahib Ji.' },
    'mata-dhamodari': { name:'Mata Dhamodari Ji', gur:'ਮਾਤਾ ਡਾਮੋਦਰੀ ਜੀ', role:'First wife of Guru Hargobind Sahib Ji', born:'c. 1596 CE', died:'c. 1640 CE', parents:'—', siblings:'—', spouse:'Guru Hargobind Sahib Ji', children:'Gurditta Ji, Ani Rai Ji, Atal Rai Ji, Bibi Viro Ji', bio:'Mata Dhamodari Ji was the first wife of Guru Hargobind Sahib Ji and mother of Baba Gurditta Ji.' },
    'guru-hargobind': { name:'Guru Hargobind Sahib Ji', gur:'ਗੁਰੂ ਹਰਗੋਬਿੰਦ ਸਾਹਿਬ ਜੀ', role:'6th Sikh Guru · Miri-Piri · Warrior Guru', born:'19 June 1595 CE, Guru Ki Wadali, Amritsar', died:'3 March 1644 CE, Kiratpur Sahib', parents:'Guru Arjan Dev Ji & Mata Ganga Ji', siblings:'—', spouse:'Mata Dhamodari Ji, Mata Nanki Ji (Marwahi), Mata Marvahi Ji', children:'Baba Gurditta Ji, Ani Rai Ji, Atal Rai Ji, Bibi Viro Ji, Guru Tegh Bahadur Sahib Ji', bio:'Guru Hargobind Sahib Ji was the sixth Sikh Guru who transformed the Sikh tradition by donning two swords: Miri (temporal sovereignty) and Piri (spiritual authority). He built the Akal Takht, trained a Sikh army, and fought four battles against the Mughal Empire. He was imprisoned in Gwalior Fort for two years alongside 52 Hindu kings, whom he secured release for — earning the title Bandi Chhor Divas (Diwali).', isGuru:true },
    'mata-nanki-6':   { name:'Mata Nanki Ji / Marwahi Ji', gur:'ਮਾਤਾ ਨਾਨਕੀ ਜੀ / ਮਰਵਾਹੀ ਜੀ', role:'Wife of Guru Hargobind Sahib Ji', born:'c. 1598 CE', died:'Unknown', parents:'—', siblings:'—', spouse:'Guru Hargobind Sahib Ji', children:'Guru Tegh Bahadur Sahib Ji, Suraj Mal', bio:'Mata Nanki Ji (also called Marwahi Ji) was one of the wives of Guru Hargobind Sahib Ji and the blessed mother of Guru Tegh Bahadur Sahib Ji.' },
    'gurditta':       { name:'Baba Gurditta Ji', gur:'ਬਾਬਾ ਗੁਰਦਿੱਤਾ ਜੀ', role:'Elder son of Guru Hargobind Sahib Ji', born:'16 November 1613 CE', died:'1638 CE', parents:'Guru Hargobind Sahib Ji & Mata Dhamodari Ji', siblings:'Ani Rai Ji, Atal Rai Ji, Bibi Viro Ji', spouse:'Bibi Nihal Kaur Ji', children:'Dhirmal Ji, Guru Har Rai Ji', bio:'Baba Gurditta Ji was the eldest son of Guru Hargobind Sahib Ji. He was a deeply spiritual young man who died at the young age of 24. His son Guru Har Rai Ji became the 7th Sikh Guru.' },
    'bibi-nihal':     { name:'Bibi Nihal Kaur Ji', gur:'ਬੀਬੀ ਨਿਹਾਲ ਕੌਰ ਜੀ', role:'Wife of Baba Gurditta Ji', born:'Unknown', died:'Unknown', parents:'—', siblings:'—', spouse:'Baba Gurditta Ji', children:'Dhirmal Ji, Guru Har Rai Ji', bio:'Bibi Nihal Kaur Ji was the wife of Baba Gurditta Ji and mother of Guru Har Rai Ji.' },
    'ani-rai':        { name:'Ani Rai Ji', gur:'ਅਣੀ ਰਾਇ ਜੀ', role:'Son of Guru Hargobind Sahib Ji', born:'Unknown', died:'Unknown', parents:'Guru Hargobind Sahib Ji', siblings:'Baba Gurditta Ji, Atal Rai Ji, Bibi Viro Ji', spouse:'—', children:'—', bio:'Ani Rai Ji was one of the sons of Guru Hargobind Sahib Ji.' },
    'atal-rai':       { name:'Baba Atal Rai Ji', gur:'ਬਾਬਾ ਅਟੱਲ ਰਾਇ ਜੀ', role:'Son of Guru Hargobind Sahib Ji · Child saint', born:'c. 1619 CE', died:'c. 1628 CE', parents:'Guru Hargobind Sahib Ji & Mata Dhamodari Ji', siblings:'Baba Gurditta Ji, Ani Rai Ji, Bibi Viro Ji', spouse:'—', children:'—', bio:'Baba Atal Rai Ji is celebrated as a child saint who performed a miracle, resurrecting a playmate who had died. When his father Guru Hargobind Ji reminded him that miracles should not be shown off, Baba Atal Rai Ji offered his own life in exchange. He left his body at age nine. The Baba Atal Rai tower in Amritsar stands in his honour.' },
    'bibi-viro':      { name:'Bibi Viro Ji', gur:'ਬੀਬੀ ਵੀਰੋ ਜੀ', role:'Daughter of Guru Hargobind Sahib Ji', born:'c. 1616 CE', died:'Unknown', parents:'Guru Hargobind Sahib Ji & Mata Dhamodari Ji', siblings:'Baba Gurditta Ji, Ani Rai Ji, Atal Rai Ji', spouse:'Lal Chand', children:'Mata Gujri Ji', bio:'Bibi Viro Ji was the daughter of Guru Hargobind Sahib Ji. Her daughter Mata Gujri Ji married Guru Tegh Bahadur Sahib Ji, making Bibi Viro Ji the maternal grandmother of Guru Gobind Singh Ji.' },
    'suraj-mal':      { name:'Suraj Mal', gur:'ਸੂਰਜ ਮਲ', role:'Grandson of Guru Hargobind Sahib Ji (through Mata Nanki Ji)', born:'Unknown', died:'Unknown', parents:'Mata Nanki Ji (wife of Guru Hargobind)', siblings:'Guru Tegh Bahadur Sahib Ji', spouse:'—', children:'Nand Chand', bio:'Suraj Mal was a descendant from Mata Nanki Ji\'s line.' },
    'nand-chand':     { name:'Nand Chand', gur:'ਨੰਦ ਚੰਦ', role:'Descendant of Guru Hargobind Sahib Ji', born:'Unknown', died:'Unknown', parents:'Suraj Mal', siblings:'—', spouse:'—', children:'Gulab Rai', bio:'Nand Chand was a member of the Guru\'s extended family.' },
    'gulab-rai':      { name:'Gulab Rai', gur:'ਗੁਲਾਬ ਰਾਇ', role:'Descendant of Guru Hargobind Sahib Ji', born:'Unknown', died:'Unknown', parents:'Nand Chand', siblings:'—', spouse:'—', children:'—', bio:'Gulab Rai was a member of the Guru\'s extended family.' },
    'dhirmal':        { name:'Dhirmal Ji', gur:'ਧੀਰ ਮਲ ਜੀ', role:'Elder son of Baba Gurditta Ji', born:'c. 1627 CE', died:'c. 1677 CE', parents:'Baba Gurditta Ji & Bibi Nihal Kaur Ji', siblings:'Guru Har Rai Ji', spouse:'—', children:'—', bio:'Dhirmal Ji was the elder son of Baba Gurditta Ji and elder brother of Guru Har Rai Ji. He expected the Guruship but it passed to his younger brother. He is known for his opposition to the Sikh Gurus and is said to have kept a copy of the Adi Granth (known as the Kartarpuri Bir). He conspired with enemies of the Gurus.' },
    'guru-har-rai':   { name:'Guru Har Rai Ji', gur:'ਗੁਰੂ ਹਰਿ ਰਾਇ ਜੀ', role:'7th Sikh Guru · Healer · Guardian of nature', born:'16 January 1630 CE, Kiratpur Sahib, Punjab', died:'6 October 1661 CE, Kiratpur Sahib', parents:'Baba Gurditta Ji & Bibi Nihal Kaur Ji', siblings:'Dhirmal Ji', spouse:'Bibi Krishan Kaur Ji (Mata Ram Kaur)', children:'Ram Rai Ji, Guru Harkrishan Sahib Ji', bio:'Guru Har Rai Ji was the seventh Sikh Guru and a deeply compassionate healer who maintained a large menagerie of animals and a herb garden with hundreds of medicinal plants. He treated Dara Shikoh (Mughal prince) with Ayurvedic medicines when others refused. He maintained a 2,200-strong cavalry while spreading the message of peace and love.', isGuru:true },
    'mata-ram-kaur':  { name:'Bibi Krishan Kaur Ji (Mata Ram Kaur Ji)', gur:'ਮਾਤਾ ਰਾਮ ਕੌਰ ਜੀ', role:'Wife of Guru Har Rai Ji', born:'Unknown', died:'Unknown', parents:'—', siblings:'—', spouse:'Guru Har Rai Ji', children:'Ram Rai Ji, Guru Harkrishan Sahib Ji', bio:'Mata Ram Kaur Ji (also known as Bibi Krishan Kaur) was the devoted wife of Guru Har Rai Ji and mother of Guru Harkrishan Sahib Ji.' },
    'ram-rai':        { name:'Ram Rai Ji', gur:'ਰਾਮ ਰਾਇ ਜੀ', role:'Elder son of Guru Har Rai Ji', born:'c. 1646 CE', died:'1687 CE', parents:'Guru Har Rai Ji & Mata Ram Kaur Ji', siblings:'Guru Harkrishan Sahib Ji', spouse:'—', children:'—', bio:'Ram Rai Ji was the elder son of Guru Har Rai Ji. He was sent to the court of Emperor Aurangzeb to explain Sikh scriptures. To please the Emperor, he altered a line of Gurbani, and for this Guru Har Rai Ji disowned him, saying that a person who could alter the Guru\'s word could not be the Guru\'s representative.' },
    'guru-harkrishan':{ name:'Guru Harkrishan Sahib Ji', gur:'ਗੁਰੂ ਹਰਿ ਕ੍ਰਿਸ਼ਨ ਸਾਹਿਬ ਜੀ', role:'8th Sikh Guru · Child Guru', born:'7 July 1656 CE, Kiratpur Sahib, Punjab', died:'30 March 1664 CE, Delhi (at age 8)', parents:'Guru Har Rai Ji & Mata Ram Kaur Ji', siblings:'Ram Rai Ji', spouse:'—', children:'—', bio:'Guru Harkrishan Sahib Ji became Guru at the age of five, the youngest of the Sikh Gurus. He died at eight years of age in Delhi of smallpox, having selflessly tended to thousands of smallpox victims during an epidemic in Delhi. His last words pointed to his successor: "Baba Bakale" — indicating that the next Guru was in Bakala. The Bangla Sahib Gurdwara in Delhi stands where he healed the sick.', isGuru:true },
    'mata-gujri':     { name:'Mata Gujri Ji', gur:'ਮਾਤਾ ਗੁਜਰੀ ਜੀ', role:'Wife of Guru Tegh Bahadur Sahib Ji · Grandmother of the Sahibzade', born:'c. 1624 CE, Kartarpur, Punjab', died:'27 December 1704 CE, Sirhind', parents:'Lal Chand & Bibi Viro Ji', siblings:'—', spouse:'Guru Tegh Bahadur Sahib Ji', children:'Guru Gobind Singh Ji', bio:'Mata Gujri Ji was the devoted and extraordinarily strong-willed wife of Guru Tegh Bahadur Sahib Ji and mother of Guru Gobind Singh Ji. After the Guru\'s martyrdom she raised Guru Gobind Singh Ji alone. After the evacuation of Anandpur Sahib in 1704 she was separated from Guru Gobind Singh Ji. She was imprisoned in the Cold Tower (Thanda Burj) of Sirhind with her four young grandsons. She kept the Sahibzade\'s spirits high with stories of the Gurus until her death.' },
    'guru-tegh-bahadur':{ name:'Guru Tegh Bahadur Sahib Ji', gur:'ਗੁਰੂ ਤੇਗ਼ ਬਹਾਦਰ ਸਾਹਿਬ ਜੀ', role:'9th Sikh Guru · Hind di Chaadar (Shield of Hindustan)', born:'1 April 1621 CE, Amritsar, Punjab', died:'24 November 1675 CE, Chandni Chowk, Delhi (martyrdom)', parents:'Guru Hargobind Sahib Ji & Mata Nanki Ji', siblings:'Baba Gurditta Ji, Ani Rai Ji, Atal Rai Ji, Bibi Viro Ji', spouse:'Mata Gujri Ji', children:'Guru Gobind Singh Ji', bio:'Guru Tegh Bahadur Sahib Ji was the ninth Sikh Guru and the "Hind di Chaadar" (Shield of Hindustan). He was executed on the orders of Mughal Emperor Aurangzeb in Chandni Chowk, Delhi, for refusing to convert to Islam — and for championing the right of Kashmiri Pandits (Hindus) to freely practise their own faith, even though they were of a different religion. His sacrifice stands as one of history\'s greatest acts of defending the freedom of conscience.', isGuru:true },
    'mata-sundri':    { name:'Mata Sundri Ji', gur:'ਮਾਤਾ ਸੁੰਦਰੀ ਜੀ', role:'Wife of Guru Gobind Singh Ji · Led the Panth after Guru Ji\'s departure', born:'c. 1667 CE', died:'1747 CE', parents:'—', siblings:'—', spouse:'Guru Gobind Singh Ji', children:'Sahibzada Ajit Singh Ji (adopted)', bio:'Mata Sundri Ji was the most prominent of Guru Gobind Singh Ji\'s wives. After the Guru\'s passing in 1708, she led the Sikh Panth for nearly 40 years from Delhi, issuing Hukamnamas (letters of authority) to the Khalsa. She is revered as a leader of the Panth in her own right.' },
    'guru-gobind-singh':{ name:'Guru Gobind Singh Ji', gur:'ਗੁਰੂ ਗੋਬਿੰਦ ਸਿੰਘ ਜੀ', role:'10th Sikh Guru · Founder of the Khalsa', born:'22 December 1666 CE, Patna Sahib, Bihar', died:'7 October 1708 CE, Nanded, Maharashtra', parents:'Guru Tegh Bahadur Sahib Ji & Mata Gujri Ji', siblings:'—', spouse:'Mata Jito Ji, Mata Sundri Ji, Mata Sahib Devan (Sahib Kaur Ji)', children:'Sahibzada Ajit Singh Ji, Sahibzada Jujhar Singh Ji, Sahibzada Jorawar Singh Ji, Sahibzada Fateh Singh Ji', bio:'Guru Gobind Singh Ji was the tenth and final human Sikh Guru. On Vaisakhi 1699 he created the Khalsa — the Sovereign Brotherhood of the Pure — initiating the Panj Pyare (Five Beloved) with Amrit. He composed the Dasam Granth, defeated numerous Mughal and Hill Rajah armies, and sacrificed his father, mother, and all four sons for the faith. Before his passing he declared the Sri Guru Granth Sahib Ji as the eternal living Guru of the Sikhs.', isGuru:true },
    'mata-jito':      { name:'Mata Jito Ji', gur:'ਮਾਤਾ ਜੀਤੋ ਜੀ', role:'First wife of Guru Gobind Singh Ji · Mother of three Sahibzade', born:'c. 1666 CE', died:'5 December 1700 CE', parents:'—', siblings:'—', spouse:'Guru Gobind Singh Ji', children:'Sahibzada Jujhar Singh Ji, Sahibzada Jorawar Singh Ji, Sahibzada Fateh Singh Ji', bio:'Mata Jito Ji (also known as Mata Ajit Kaur) was the first wife of Guru Gobind Singh Ji. She is believed to have ground wheat flour for the Amrit during the Vaisakhi 1699 Khalsa initiation ceremony, making a supreme contribution to that historic moment. She passed away in 1700 CE.' },
