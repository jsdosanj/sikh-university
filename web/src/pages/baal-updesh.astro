  function initFamilyTree() {
    const canvas = document.getElementById('ft-canvas');
    if (!canvas) return;
    const nodeMap = {};
    NODES.forEach(n => { nodeMap[n.id] = n; });
    // Render SVG
    const NS = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(NS, 'svg');
    svg.setAttribute('style','position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:visible');
    EDGES.forEach(e => {
      const a = nodeMap[e.f], b = nodeMap[e.t];
      if (!a || !b) return;
      const line = document.createElementNS(NS, 'path');
      const ax = a.x + 62, ay = a.y + 14, bx = b.x + 62, by = b.y + 14;
      if (e.type === 'm') {
        // horizontal dotted marriage line
        line.setAttribute('d', `M ${ax} ${ay} L ${bx} ${by}`);
        line.setAttribute('stroke','#94a3b8');
        line.setAttribute('stroke-dasharray','4,3');
        line.setAttribute('stroke-width','1.5');
      } else {
        // child: go down from parent midpoint
        const mx = (ax + bx) / 2, my = Math.max(ay, by) - 20;
        line.setAttribute('d', `M ${ax} ${ay+2} L ${ax} ${my} L ${bx} ${my} L ${bx} ${by-2}`);
        line.setAttribute('stroke','#cbd5e1');
        line.setAttribute('stroke-dasharray','none');
        line.setAttribute('stroke-width','1.5');
        line.setAttribute('fill','none');
      }
      line.setAttribute('fill','none');
      svg.appendChild(line);
    });
    canvas.appendChild(svg);
    // Render nodes
    NODES.forEach(n => {
      const p = PEOPLE[n.id]; if (!p) return;
      const btn = document.createElement('button');
      btn.className = [
        'absolute rounded-md px-2 py-1 text-xs font-bold leading-tight border transition-all',
        'hover:shadow-md hover:scale-105 active:scale-95',
        p.isGuru
          ? 'bg-saffron text-white border-saffron-deep shadow-sm'
          : 'bg-surface text-navy border-line hover:border-saffron-deep',
      ].join(' ');
      btn.style.cssText = `left:${n.x}px;top:${n.y}px;min-width:110px;max-width:145px;white-space:normal;text-align:center;z-index:1`;
      const shortName = (p.name.replace(' Ji','').replace(' Sahib','').replace('Guru ','').replace('Mata ','').replace('Bhai ','').replace('Bebe ','').replace('Bibi ','').replace('Baba ','').replace('Sahibzada ','').replace('Gurbani','') || p.name).trim();
      btn.textContent = p.isGuru ? p.name.replace(' Dev Ji','').replace(' Sahib Ji','') + ' ✦' : p.name.split('(')[0].trim().replace('Bhai Kalian Das Ji ','Mehta Kalu').replace(' Kaur Ji',' Kaur').replace(' Singh Ji',' Singh');
      btn.setAttribute('aria-label', 'Learn about ' + p.name);
      btn.addEventListener('click', () => showPersonPopup(n.id));
      canvas.appendChild(btn);
    });
  }

  function showPersonPopup(id) {
    const p = PEOPLE[id]; if (!p) return;
    openPopup(`
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-white text-sm font-bold" style="background:${p.isGuru ? '#c27d1a' : '#1d4e89'}">
          ${p.isGuru ? '✦' : (p.gur[0] || '?')}
        </div>
        <div>
          <h3 class="text-lg font-bold text-navy leading-tight">${p.name}</h3>
          <div class="gur text-base text-saffron-deep">${p.gur}</div>
          <div class="text-xs text-muted mt-0.5">${p.role}</div>
        </div>
      </div>
      <p class="text-sm leading-relaxed text-navy">${p.bio}</p>
      <dl class="mt-4 grid grid-cols-2 gap-x-4 gap-y-1.5 text-xs">
        ${p.born ? `<dt class="text-muted font-semibold">Born</dt><dd class="text-navy">${p.born}</dd>` : ''}
        ${p.died ? `<dt class="text-muted font-semibold">Passed</dt><dd class="text-navy">${p.died}</dd>` : ''}
        ${p.parents && p.parents !== '—' ? `<dt class="text-muted font-semibold">Parents</dt><dd class="text-navy">${p.parents}</dd>` : ''}
        ${p.spouse && p.spouse !== '—' ? `<dt class="text-muted font-semibold">Spouse</dt><dd class="text-navy">${p.spouse}</dd>` : ''}
        ${p.siblings && p.siblings !== '—' ? `<dt class="text-muted font-semibold">Siblings</dt><dd class="text-navy">${p.siblings}</dd>` : ''}
        ${p.children && p.children !== '—' ? `<dt class="text-muted font-semibold">Children</dt><dd class="text-navy">${p.children}</dd>` : ''}
      </dl>
    `);
  }

