---
import Base from '../layouts/Base.astro';
---
<Base title="Read-along — Gurbani | Sikh University" description="Read Gurbani Ang by Ang — Sri Guru Granth Sahib Ji with Santhya audio and word-by-word highlighting, plus the Dasam and Sarbloh Granths.">
  <section class="wrap py-8">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h1 id="title" class="text-2xl font-bold">Read-along</h1>
      <div class="flex items-center gap-2 font-sans text-sm">
        <button id="prev" class="rounded-lg border border-line px-3 py-1.5 hover:border-blue">←</button>
        <label id="anglabel">Ang <input id="angin" type="number" min="1" value="1" class="w-20 rounded-lg border border-line px-2 py-1"></label>
        <button id="next" class="rounded-lg border border-line px-3 py-1.5 hover:border-blue">→</button>
      </div>
    </div>

    <div id="audbar" class="mt-4 flex flex-wrap items-center gap-3 rounded-xl2 border border-line bg-surface p-3">
      <audio id="aud" controls preload="none" class="min-w-[260px] flex-1"></audio>
      <div id="audph" class="hidden min-w-[260px] flex-1 items-center gap-2 rounded-lg bg-paper px-3 py-2 font-sans text-sm text-muted">🔇 Audio for this Ang is being prepared.</div>
      <div class="flex items-center gap-2 font-sans text-sm">
        <button data-fs="-" class="rounded-lg border border-line px-2.5 py-1">A−</button>
        <button data-fs="+" class="rounded-lg border border-line px-2.5 py-1">A+</button>
        <button id="larivaar" class="rounded-lg border border-line px-2.5 py-1">Larivaar</button>
        <button id="bg" class="rounded-lg border border-line px-2.5 py-1">◐ Theme</button>
      </div>
    </div>
    <p id="audnote" class="mt-1 font-sans text-xs text-muted"></p>

    <div id="page" class="gur mt-6 leading-loose" style="font-size:1.9rem"></div>

    <div class="mt-8 flex items-center justify-between font-sans text-sm">
      <button id="prev2" class="rounded-lg border border-line px-3 py-1.5 hover:border-blue">← Previous</button>
      <a href="/santhiya" class="text-muted hover:text-navy">All Santhya texts</a>
      <button id="next2" class="rounded-lg border border-line px-3 py-1.5 hover:border-blue">Next →</button>
    </div>
  </section>

  <style is:global>
    #page .w { transition: color .08s, background-color .08s; padding: 0 .04em; border-radius: 4px; }
    #page .w.on { background: #ffe69a; color: #1a1205; font-weight: 700; box-shadow: 0 0 0 2px #ffe69a; }
    #page .ln { margin: .35rem 0; }
    #page.lari .ln { word-spacing: -0.25em; }
    body.read-dark { background: #0f1115; color: #e8e8ea; }
    body.read-dark #page .w.on { background: #f4b21a; color: #0a0d14; }
    /* Dark theme: the controls bar uses a light surface token by default, which
       leaves its light-text buttons unreadable. Re-skin it for dark mode. */
    body.read-dark #audbar { background: #171a21; border-color: #2a3140; }
    body.read-dark #audbar button { color: #e8e8ea; border-color: #3a4252; }
    body.read-dark #audbar button:hover { border-color: #6b8cff; }
    body.read-dark .wrap button { color: #e8e8ea; border-color: #3a4252; }
    body.read-dark .wrap button:hover { border-color: #6b8cff; }
    body.read-dark #angin { background: #171a21; color: #e8e8ea; border-color: #3a4252; }
    body.read-dark #audph { background: #1f2430; color: #aeb4c0; }
    body.read-sepia { background: #f3e9d2; }
  </style>

  <script>
    var SRC = {
      sggs: { name: 'Sri Guru Granth Sahib Ji', unit: 'Ang', max: 1430, audio: true },
      dasam: { name: 'Dasam Granth', unit: 'Ang', max: 1428, audio: false },
      sarbloh: { name: 'Sarbloh Granth (excerpt)', unit: 'Section', max: 1, audio: false },
    };
    var P = 'su_v1_';
    var get = function (k, d) { try { var v = localStorage.getItem(P + k); return v == null ? d : JSON.parse(v); } catch (e) { return d; } };
    var set = function (k, v) { try { localStorage.setItem(P + k, JSON.stringify(v)); } catch (e) {} };
    var qp = new URLSearchParams(location.search);
    var src = SRC[qp.get('src')] ? qp.get('src') : 'sggs';
    var cfg = SRC[src];
    var page = document.getElementById('page'), aud = document.getElementById('aud'), angin = document.getElementById('angin'), note = document.getElementById('audnote'), audph = document.getElementById('audph');
    document.getElementById('title').textContent = cfg.name;
    document.getElementById('anglabel').childNodes[0].nodeValue = cfg.unit + ' ';
    angin.max = cfg.max;
    var ang = parseInt(qp.get('ang') || get(src + '_ang', 1), 10) || 1;
    var words = [], cum = [], total = 0, curIdx = -1;

    // SGGS Santhya audio (Bhindran Taksal) is a set of recordings each covering
    // a RANGE of Angs, streamed directly from gurmatveechar.com. We map the
    // current Ang to the recording that contains it.
    var santhya = null, curUrl = '';
    function trackFor(n) {
      if (!santhya || !santhya.length) return null;
      var best = null;
      for (var i = 0; i < santhya.length; i++) {
        var r = santhya[i];
        if (n >= r.start && n <= r.end) return r;     // exact cover
        if (r.start <= n) best = r;                    // else nearest recording in progress
      }
      return best || santhya[0];
    }
    function setAudio(n) {
      if (!cfg.audio) { aud.style.display = 'none'; audph.style.display = 'none'; note.textContent = 'Text read-along (no audio for this Granth yet).'; return; }
      var t = trackFor(n);
      if (!t) return;                                  // index not loaded yet
      aud.style.display = ''; audph.style.display = 'none';
      if (t.url !== curUrl) { curUrl = t.url; aud.src = t.url; aud.load(); }
      note.textContent = '🎧 Santhya · ' + t.title + ' — Bhindrān Taksāl (gurmatveechar.com)';
    }

    function vishramWeight(w) { if (w.indexOf('॥') !== -1) return 3.2; if (w.indexOf(';') !== -1) return 1.6; if (w.indexOf('.') !== -1) return 0.9; return 0; }
    function buildTiming() { cum = []; total = 0; for (var i = 0; i < words.length; i++) { var w = words[i].textContent || ''; total += 0.6 + 0.22 * w.replace(/[॥;.]/g, '').length + vishramWeight(w); cum.push(total); } }
    function highlight(t) {
      if (!aud.duration || !total) return;
      var target = (t / aud.duration) * total, i = curIdx < 0 ? 0 : curIdx;
      while (i < cum.length && cum[i] < target) i++;
      while (i > 0 && cum[i - 1] >= target) i--;
      if (i === curIdx) return;
      if (curIdx >= 0 && words[curIdx]) words[curIdx].classList.remove('on');
      curIdx = i; if (words[i]) { words[i].classList.add('on'); words[i].scrollIntoView({ block: 'center', behavior: 'smooth' }); }
    }
    function render(data) {
      page.innerHTML = ''; words = [];
      data.lines.forEach(function (line) {
        var ln = document.createElement('div'); ln.className = 'ln';
        line.split(/\s+/).forEach(function (tok) { if (!tok) return; var s = document.createElement('span'); s.className = 'w'; s.textContent = tok; ln.appendChild(s); ln.appendChild(document.createTextNode(' ')); words.push(s); });
        page.appendChild(ln);
      });
      curIdx = -1; buildTiming();
    }
    function load(n) {
      n = Math.max(1, Math.min(cfg.max, n)); ang = n; angin.value = n; set(src + '_ang', n);
      history.replaceState(null, '', '/read?src=' + src + '&ang=' + n);
      note.textContent = '';
      fetch('/assets/gurbani/' + src + '/' + n + '.json').then(function (r) { return r.json(); }).then(render).catch(function () { page.innerHTML = '<p class="text-muted" style="font-size:1rem">Could not load this ' + cfg.unit + '.</p>'; });
      setAudio(n);
    }
    // The santhya recordings span many Angs, so the per-word timing heuristic
    // can't sync to them — highlight only runs if a single-Ang track is ever used.
    aud.addEventListener('timeupdate', function () { if (curUrl && curUrl.indexOf('gurmatveechar') === -1) highlight(aud.currentTime); });
    aud.addEventListener('error', function () { if (cfg.audio && curUrl) { aud.style.display = 'none'; audph.style.display = 'flex'; note.textContent = 'This Santhya recording could not be reached just now — text read-along still works.'; } });
    aud.addEventListener('ended', function () {
      if (!santhya) return;
      for (var i = 0; i < santhya.length; i++) { if (santhya[i].url === curUrl) { var nx = santhya[i + 1]; if (nx) { load(nx.start); aud.play().catch(function () {}); } return; } }
    });
    function go(n) { load(n); }
    document.getElementById('next').onclick = document.getElementById('next2').onclick = function () { go(ang + 1); };
    document.getElementById('prev').onclick = document.getElementById('prev2').onclick = function () { go(ang - 1); };
    angin.addEventListener('change', function () { go(parseInt(angin.value, 10) || 1); });
    var fs = get('read_fs', 1.9); page.style.fontSize = fs + 'rem';
    document.querySelectorAll('[data-fs]').forEach(function (b) { b.onclick = function () { fs = Math.max(1.1, Math.min(3.2, fs + (b.dataset.fs === '+' ? 0.2 : -0.2))); page.style.fontSize = fs + 'rem'; set('read_fs', fs); }; });
    document.getElementById('larivaar').onclick = function () { page.classList.toggle('lari'); };
    var themes = ['', 'read-dark', 'read-sepia'], ti = get('read_theme', 0);
    function applyTheme() { document.body.classList.remove('read-dark', 'read-sepia'); if (themes[ti]) document.body.classList.add(themes[ti]); }
    applyTheme();
    document.getElementById('bg').onclick = function () { ti = (ti + 1) % themes.length; set('read_theme', ti); applyTheme(); };
    load(ang);
    if (cfg.audio) {
      note.textContent = 'Loading Santhya audio…';
      fetch('/assets/gurbani/santhya-sggs-index.json').then(function (r) { return r.json(); }).then(function (d) { santhya = d; setAudio(ang); }).catch(function () { note.textContent = 'Santhya audio is unavailable right now — text read-along still works.'; });
    }
  </script>
</Base>
