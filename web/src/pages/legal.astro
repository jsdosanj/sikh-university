---
import Base from '../layouts/Base.astro';
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
// Single source: reuse the existing legal content (GDPR/CCPA-aligned drafts).
// Resolve the source from a few candidate locations so the static build (which may
// run the module from a temp dir) reliably finds site/legal.html at the repo root.
const candidates = [
  fileURLToPath(new URL('../../../site/legal.html', import.meta.url)),
  path.resolve(process.cwd(), '../site/legal.html'),
  path.resolve(process.cwd(), 'site/legal.html'),
];
let inner = '';
for (const c of candidates) {
  try {
    const raw = fs.readFileSync(c, 'utf8');
    const m = raw.match(/<main[^>]*>([\s\S]*?)<\/main>/i);
    inner = (m ? m[1] : '').replace(/\.html/g, '');
    if (inner) break;
  } catch (e) { /* try next candidate */ }
}
if (!inner) inner = '<p>Terms &amp; Privacy are being prepared.</p>';
---
<Base title="Terms & Privacy — Sikh University" description="Sikh University Terms of Service and Privacy Policy (GDPR/CCPA-aligned drafts).">
  <section class="wrap py-12">
    <article class="legal mx-auto max-w-3xl" set:html={inner} />
  </section>
  <style is:global>
    @reference "../styles/global.css";
    .legal h2 { @apply mt-10 text-2xl font-bold text-navy; }
    .legal h3 { @apply mt-6 text-lg font-bold text-navy; }
    .legal p, .legal li { @apply my-2 leading-relaxed; }
    .legal ul { @apply list-disc pl-6; }
    .legal a { @apply text-navy underline; }
    .legal .callout { @apply my-4 rounded-xl border border-line border-l-4 border-l-saffron bg-surface p-4 font-sans text-sm; }
    .legal .sans { @apply font-sans; }
  </style>
</Base>
