---
import Base from '../layouts/Base.astro';
const courses = [
  {
    name: 'Sikhism Through Its Scriptures', provider: 'HarvardX (edX) · Prof. Harpreet Singh',
    cost: 'Free to audit (optional $149 certificate) · 4 weeks · self-paced',
    desc: "A scholarly examination of Sikh scripture from doctrinal and historical angles — the Japji, the role of Sri Guru Granth Sahib Ji, the musical traditions, and the scripture's influence on Sikh communities.",
    href: 'https://pll.harvard.edu/course/sikhism-through-its-scriptures-0',
  },
  {
    name: 'SikhRI Online Courses', provider: 'Sikh Research Institute',
    cost: 'Free & paid courses',
    desc: 'University-style courses on Gurbani, Sikh history, Gurmat and Kirtan from a respected non-profit research institute.',
    href: 'https://sikhri.org/courses',
  },
  {
    name: 'Sikh Dharma 101', provider: 'Sikh Dharma International',
    cost: 'Free · self-paced',
    desc: 'An introductory self-study overview of the Sikh path for beginners and interfaith learners.',
    href: 'https://www.sikhdharma.org/sd-101/',
  },
  {
    name: 'Study Sikhi', provider: 'Study Sikhi',
    cost: 'Free & paid',
    desc: 'University-level study of Sikh history, Gurbani, poetics and grammar.',
    href: 'https://www.studysikhi.com/',
  },
  {
    name: 'The Sikh Archive', provider: 'Sikh Archive (our partner)',
    cost: 'Free',
    desc: 'A growing digital library of Sikh sources, history and free courses — Sikh University works alongside it.',
    href: 'https://sikharchive.net',
  },
];
---
<Base title="Recommended external courses — Sikh University" description="Reputable free and university Sikhi courses elsewhere — including Harvard's 'Sikhism Through Its Scriptures' — to study alongside Sikh University.">
  <section class="wrap py-12">
    <h1 class="text-3xl font-bold">Study further, elsewhere</h1>
    <p class="mt-2 max-w-2xl text-lg text-muted">Sikh University is one part of a wider world of Sikhi learning. These are reputable courses hosted by other institutions — we link to them so you can keep going. (Their content stays on their own sites; we don't rehost it.)</p>
    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      {courses.map((c) => (
        <a href={c.href} target="_blank" rel="noopener" class="card flex flex-col">
          <h3 class="text-lg font-bold text-navy">{c.name}</h3>
          <div class="mt-0.5 font-sans text-xs text-muted">{c.provider}</div>
          <div class="mt-1 font-sans text-xs font-semibold text-saffron-deep">{c.cost}</div>
          <p class="mt-2 flex-1 text-[0.95rem]">{c.desc}</p>
          <div class="mt-3 font-sans text-sm font-semibold text-navy">Open on their site ↗</div>
        </a>
      ))}
    </div>
    <p class="mt-8 font-sans text-sm text-muted">A reputable free Sikhi course we should add here? Tell us via <a class="underline" href="/feedback">feedback</a>.</p>
  </section>
</Base>
