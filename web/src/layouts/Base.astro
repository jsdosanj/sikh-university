---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props { title: string; description?: string; canonical?: string; ogType?: string; }
const { title, description = 'A free, open online university for Sikhi and modern skills — open to all, worldwide.', canonical, ogType = 'website' } = Astro.props;
const SITE = 'https://sikh-university.dosanjhlabs.com';
// Normalise to the extensionless URLs the site is actually served/linked at
// (e.g. /catalog, not /catalog.html; / for the homepage).
const cleanPath = Astro.url.pathname.replace(/index\.html$/, '').replace(/\.html$/, '');
const canon = canonical || SITE + (cleanPath === '' ? '/' : cleanPath);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <script is:inline>
    // Set the colour theme before first paint to avoid a flash. Honours a
    // saved choice, else the OS preference.
    (function () {
      try {
        var t = localStorage.getItem('su_v1_theme');
        if (t !== 'light' && t !== 'dark') t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t);
        var lang = localStorage.getItem('su_v1_lang') || 'en';
        document.documentElement.setAttribute('lang', lang);
        document.documentElement.setAttribute('dir', lang === 'ar' ? 'rtl' : 'ltr');
      } catch (e) {}
    })();
  </script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#16335c" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0d1016" media="(prefers-color-scheme: dark)" />
  <link rel="canonical" href={canon} />
  <link rel="icon" href="/assets/icon.svg" />
  <link rel="icon" type="image/png" sizes="192x192" href="/assets/icon-192.png" />
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Sikh University" />
  <meta name="mobile-web-app-capable" content="yes" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Sikh University" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canon} />
  <meta property="og:image" content={`${SITE}/assets/og-image.png`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="1200" />
  <meta property="og:image:alt" content="Sikh University — free, open learning in Sikhi" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${SITE}/assets/og-image.png`} />
  <slot name="head" />
</head>
<body>
  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:left-3 focus:top-3 focus:z-[100] focus:rounded-lg focus:bg-brand focus:px-4 focus:py-2 focus:text-white">Skip to content</a>
  <Nav />
  <main id="main">
    <slot />
  </main>
  <Footer />

  <button id="a11y-fab" aria-label="Accessibility options" aria-expanded="false" aria-controls="a11y-panel" class="fixed right-[max(1rem,env(safe-area-inset-right))] bottom-[max(1rem,env(safe-area-inset-bottom))] z-50 h-12 w-12 rounded-full bg-brand text-white text-xl shadow-lift hover:bg-brand-strong print:hidden">♿</button>
  <div id="a11y-panel" class="fixed right-4 bottom-20 z-50 hidden w-56 flex-col gap-1 rounded-xl2 border border-line bg-surface p-3 shadow-lift print:hidden">
    <strong class="font-sans text-xs uppercase tracking-wide text-muted">Accessibility</strong>
    <button data-a="smaller" class="rounded-lg border border-line px-3 py-2 text-left font-sans text-sm hover:border-saffron">A− Smaller text</button>
    <button data-a="bigger" class="rounded-lg border border-line px-3 py-2 text-left font-sans text-sm hover:border-saffron">A+ Larger text</button>
    <button data-a="contrast" class="rounded-lg border border-line px-3 py-2 text-left font-sans text-sm hover:border-saffron">◐ High contrast</button>
    <button data-a="read" class="rounded-lg border border-line px-3 py-2 text-left font-sans text-sm hover:border-saffron">🔊 Read this page</button>
    <button data-a="stop" class="rounded-lg border border-line px-3 py-2 text-left font-sans text-sm hover:border-saffron">⏹ Stop reading</button>
    <button data-a="reset" class="rounded-lg border border-line px-3 py-2 text-left font-sans text-sm hover:border-saffron">↺ Reset</button>
  </div>
  <script>
    const P = 'su_v1_a11y';
    const get = () => { try { return JSON.parse(localStorage.getItem(P) || '{}'); } catch { return {}; } };
    const apply = () => { const p = get(); document.documentElement.style.fontSize = (p.scale || 100) + '%'; document.body.classList.toggle('hc', !!p.contrast); };
    apply();
    const fab = document.getElementById('a11y-fab'); const panel = document.getElementById('a11y-panel');
    fab?.addEventListener('click', () => { const hidden = panel?.classList.toggle('hidden'); fab.setAttribute('aria-expanded', String(!hidden)); });
    panel?.addEventListener('click', (e) => {
      const t = e.target.closest('button'); if (!t) return; const p = get(); const a = t.dataset.a;
      if (a === 'smaller') p.scale = Math.max(80, (p.scale || 100) - 10);
      else if (a === 'bigger') p.scale = Math.min(170, (p.scale || 100) + 10);
      else if (a === 'contrast') p.contrast = !p.contrast;
      else if (a === 'read') { if (window.speechSynthesis) { speechSynthesis.cancel(); const m = document.querySelector('main'); speechSynthesis.speak(new SpeechSynthesisUtterance((m?.innerText || '').slice(0, 9000))); } return; }
      else if (a === 'stop') { window.speechSynthesis && speechSynthesis.cancel(); return; }
      else if (a === 'reset') { localStorage.removeItem(P); apply(); return; }
      localStorage.setItem(P, JSON.stringify(p)); apply();
    });
    if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js').catch(() => {});
  </script>
  <script>
    // Lightweight UI i18n: swaps text/placeholders of [data-i18n*] elements from a
    // per-language dictionary in /assets/i18n/<lang>.json. English is the in-markup
    // source (no fetch). Gurbani/Gurmukhi content is never tagged, so it's preserved.
    (function () {
      const RTL = new Set(['ar']);
      const orig = new WeakMap();
      const nodes = () => document.querySelectorAll('[data-i18n],[data-i18n-ph],[data-i18n-aria]');
      function snapshot() {
        nodes().forEach((el) => {
          if (orig.has(el)) return;
          orig.set(el, {
            t: el.hasAttribute('data-i18n') ? el.textContent : null,
            ph: el.hasAttribute('data-i18n-ph') ? el.getAttribute('placeholder') : null,
            aria: el.hasAttribute('data-i18n-aria') ? el.getAttribute('aria-label') : null,
          });
        });
      }
      async function dict(lang) {
        if (lang === 'en') return {};
        try { const r = await fetch('/assets/i18n/' + lang + '.json'); return r.ok ? await r.json() : {}; } catch (e) { return {}; }
      }
      async function apply(lang) {
        snapshot();
        document.documentElement.setAttribute('lang', lang);
        document.documentElement.setAttribute('dir', RTL.has(lang) ? 'rtl' : 'ltr');
        const d = await dict(lang);
        nodes().forEach((el) => {
          const o = orig.get(el) || {};
          const kt = el.getAttribute('data-i18n'); if (kt) el.textContent = d[kt] != null ? d[kt] : o.t;
          const kp = el.getAttribute('data-i18n-ph'); if (kp) el.setAttribute('placeholder', d[kp] != null ? d[kp] : o.ph);
          const ka = el.getAttribute('data-i18n-aria'); if (ka) el.setAttribute('aria-label', d[ka] != null ? d[ka] : o.aria);
        });
      }
      let lang = 'en';
      try { lang = localStorage.getItem('su_v1_lang') || 'en'; } catch (e) {}
      const switches = document.querySelectorAll('[data-lang-switch]');
      switches.forEach((sel) => {
        sel.value = lang;
        sel.addEventListener('change', () => {
          const v = sel.value;
          try { localStorage.setItem('su_v1_lang', v); } catch (e) {}
          switches.forEach((s) => { s.value = v; });
          apply(v);
        });
      });
      apply(lang);
    })();
  </script>
  <style is:global>
    body.hc { background: #000; color: #fff; }
    body.hc .card, body.hc .bg-surface, body.hc nav, body.hc footer { background: #000 !important; color: #fff !important; border-color: #fff !important; }
    body.hc a, body.hc h1, body.hc h2, body.hc h3 { color: #ffd479 !important; }
  </style>
</body>
</html>
