{
  "name": "sikh-university-web",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "sync-data": "node -e \"const fs=require('fs');fs.mkdirSync('public/assets/data',{recursive:true});['courses.json','professors.json'].forEach(f=>fs.copyFileSync('../site/assets/data/'+f,'public/assets/data/'+f));console.log('synced data')\"",
    "build": "npm run sync-data && astro build",
    "preview": "astro preview",
    "deploy-data": "wrangler r2 object put sikh-university-media/courses.json --file ../site/assets/data/courses.json --remote --config ../wrangler.toml"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "astro": "^6.4.6",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "tailwindcss": "^4.1.13"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
